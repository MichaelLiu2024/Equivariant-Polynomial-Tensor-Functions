 Cell[BoxData[
  FormBox["\[Gamma]", TraditionalForm]],ExpressionUUID->
  "3df24508-f1f3-4641-b198-5e22e91e6006"],
 " ranges over all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", ":=",
    RowBox[{
     RowBox[{"(",
      RowBox[{
       SubscriptBox["\[Gamma]", "1"], ",", "\[Ellipsis]", ",",
       SubscriptBox["\[Gamma]", "d"]}], ")"}], "\[Element]",
     SuperscriptBox["\[CapitalLambda]", "d"]}]}], TraditionalForm]],
  ExpressionUUID->"05df0652-f558-1a44-a0cf-3cea37ab3ff7"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]",
     RowBox[{
      SubscriptBox["\[Lambda]", "j"], "-",
      SubscriptBox["\[Lambda]",
       RowBox[{"j", "+", "1"}]]}], "\[RightBracketingBar]"}], "<=",
    SubscriptBox["\[Gamma]",
     RowBox[{"j", "+", "1"}]], "<=",
    RowBox[{
     SubscriptBox["\[Lambda]", "j"], "+",
     SubscriptBox["\[Lambda]",
      RowBox[{"j", "+", "1"}]]}]}], TraditionalForm]],ExpressionUUID->
  "81c173aa-b2cc-db4e-bcd6-4f2351062630"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Gamma]", "d"],
    RowBox[{" ",
     RowBox[{"=", " "}]}], "\[Mu]"}], TraditionalForm]],ExpressionUUID->
  "b3766896-66d1-3946-ba17-cb98a36fd2f6"],
 "."
}], "Text",
 CellChangeTimes->{{3.9660929300457573`*^9, 3.966093047346157*^9}, {
  3.9677354613386*^9, 3.967735497912756*^9}, {3.971014966848055*^9,
  3.9710150108708324`*^9}, {3.9710150669306087`*^9, 3.9710150727486134`*^9}, {
  3.971015111565445*^9, 3.971015161614685*^9}, {3.977846582980732*^9,
  3.977846589917078*^9}, {3.977846622134674*^9,
  3.97784666045315*^9}},ExpressionUUID->"080ce997-ace6-614e-9f75-\
c54e4be23f67"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Remark", "Subsubsection",
 CellChangeTimes->{{3.971006747404461*^9, 3.971006749053339*^9}, {
   3.9710069051427784`*^9, 3.971006908904007*^9},
   3.9778461385807304`*^9},ExpressionUUID->"c6832814-53fa-2e49-bd90-\
c8efc291b991"],

Cell[TextData[{
 "The coordinates of the Clebsch-Gordan tensor in the angular momentum basis \
are well known. For any ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], ",",
    SubscriptBox["\[Lambda]", "2"], ",",
    RowBox[{
     SubscriptBox["\[Lambda]", "3"], "\[Element]", "\[CapitalLambda]"}]}],
   TraditionalForm]],ExpressionUUID->"05b06487-13a6-fe48-8130-0b52320c0f27"],
 " and any ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "1"], ",",
    SubscriptBox["m", "2"], ",",
    RowBox[{
     SubscriptBox["m", "3"], "\[Element]",
     TemplateBox[{},
      "Integers"]}]}], TraditionalForm]],ExpressionUUID->
  "5ff9db6b-536c-d04a-9341-d738ee9e9353"],
 ", denote by"
}], "Text",
 CellChangeTimes->{{3.971006949112484*^9, 3.971006967328972*^9}, {
  3.9710070085718346`*^9, 3.971007051351015*^9}, {3.971013070580021*^9,
  3.9710130854220257`*^9}, {3.971013126048889*^9, 3.9710131270550156`*^9}, {
  3.9710131995006676`*^9, 3.9710132173894405`*^9}, {3.9710133498945255`*^9,
  3.9710133526336517`*^9}, {3.977846145461401*^9, 3.9778461578710537`*^9}, {
  3.9779236250048676`*^9,
  3.977923630979969*^9}},ExpressionUUID->"7b077ca8-0999-d64c-bb53-\
96abd82727b7"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"(", GridBox[{
      {
       SubscriptBox["\[Lambda]", "1"],
       SubscriptBox["\[Lambda]", "2"],
       SubscriptBox["\[Lambda]", "3"]},
      {
       SubscriptBox["m", "1"],
       SubscriptBox["m", "2"],
       SubscriptBox["m", "3"]}
     }], ")"}], "\[Element]",
   TemplateBox[{},
    "Reals"]}], TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
   3.9630770753080597`*^9, 3.963077080156849*^9}, {3.9630886760630875`*^9,
   3.9630886760630875`*^9}, {3.963334237475191*^9, 3.963334237475191*^9}, {
   3.96333432456596*^9, 3.9633343428223953`*^9}, {3.9635025685698624`*^9,
   3.963502589460739*^9}, {3.9648990659278145`*^9, 3.9648990728059845`*^9}, {
   3.9657345259987183`*^9, 3.9657345285015583`*^9}, {3.9681523539586983`*^9,
   3.968152420351982*^9}, {3.968152552203848*^9, 3.9681526612255497`*^9}, {
   3.971006737591732*^9, 3.9710067399290867`*^9}, {3.971006863156561*^9,
   3.971006881008383*^9}, {3.9710069781897106`*^9, 3.971006979743969*^9}, {
   3.9710070200535927`*^9, 3.9710070456999893`*^9}, {3.9710130886461067`*^9,
   3.9710130896048985`*^9}, 3.9710132029628105`*^9, {3.9778440303577824`*^9,
   3.9778440409718895`*^9}},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"0f313ec2-a702-ec43-8504-0c0e6bc67ad9"],

Cell[TextData[{
 "the corresponding ",
 StyleBox["Clebsch-Gordan coefficient",
  FontSlant->"Italic"],
 ", which can be computed using the ClebschGordan function in Mathematica. \
Note that the Clebsch-Gordan coefficient is nonzero iff ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]",
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], "-",
      SubscriptBox["\[Lambda]", "2"]}], "\[RightBracketingBar]"}], "<=",
    SubscriptBox["\[Lambda]", "3"], "<=",
    RowBox[{
     SubscriptBox["\[Lambda]", "1"], "+",
     SubscriptBox["\[Lambda]", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "ad77c8ce-7138-9d40-bf50-1cbf221a3fbf"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]",
     SubscriptBox["m", "j"], "\[RightBracketingBar]"}], "<=",
    SubscriptBox["\[Lambda]", "j"]}], TraditionalForm]],ExpressionUUID->
  "1b51c065-f12a-9148-a816-b953649c1e5e"],
 " for all ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "4ba6a310-de7b-1f41-a39c-160d388d101d"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "3"],
    RowBox[{" ",
     RowBox[{"=", " "}]}],
    RowBox[{
     SubscriptBox["m", "1"], "+",
     SubscriptBox["m", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "b13c8f24-f5ad-fe43-b013-1724609ee239"],
 ". Then for any valid ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", ",",
    RowBox[{"\[Gamma]", "\[Element]",
     SuperscriptBox["\[CapitalLambda]", "d"]}]}], TraditionalForm]],
  ExpressionUUID->"51d78268-b75b-964f-aed8-3b8039e5cf0a"],
 ", we have in coordinates"
}], "Text",
 CellChangeTimes->{{3.9710130909515247`*^9, 3.971013095042532*^9}, {
   3.9710131314310246`*^9, 3.9710131327823067`*^9}, {3.9710132197187767`*^9,
   3.9710132203108025`*^9}, {3.971013354571657*^9, 3.971013354886324*^9},
   3.971013740397934*^9, {3.9725622359635506`*^9, 3.972562268663*^9}, {
   3.977844052163862*^9, 3.977844072008341*^9}, {3.977846177310774*^9,
   3.9778461948871193`*^9}, {3.9779233776763573`*^9,
   3.9779233889421043`*^9}, {3.9780958032161465`*^9,
   3.9780958098347073`*^9}},ExpressionUUID->"d4538447-fa8b-404c-be57-\
940811e9c282"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"CG", "(",
      RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}],
     RowBox[{" ",
      RowBox[{"=", " "}]}],
     RowBox[{
      UnderoverscriptBox["\[Product]",
       RowBox[{"j",
        RowBox[{" ",
         RowBox[{"=", " "}]}], "1"}],
       RowBox[{"d", "-", "1"}]],
      RowBox[{"(", GridBox[{
         {
          SubscriptBox["\[Gamma]", "j"],
          SubscriptBox["\[Lambda]",
           RowBox[{"j", "+", "1"}]],
          SubscriptBox["\[Gamma]",
           RowBox[{"j", "+", "1"}]]},
         {
          SubscriptBox["s", "j"],
          SubscriptBox["m",
           RowBox[{"j", "+", "1"}]],
          SubscriptBox["s",
           RowBox[{"j", "+", "1"}]]}
        }], ")"}]}]}], "\[Element]",
    RowBox[{
     SuperscriptBox[
      TemplateBox[{},
       "Reals"],
      RowBox[{
       RowBox[{"2",
        SubscriptBox["\[Lambda]", "1"]}], "+", "1"}]], "\[CircleTimes]",
     "\[Ellipsis]", "\[CircleTimes]",
     SuperscriptBox[
      TemplateBox[{},
       "Reals"],
      RowBox[{
       RowBox[{"2",
        SubscriptBox["\[Lambda]", "d"]}], "+", "1"}]], "\[CircleTimes]",
     SuperscriptBox[
      TemplateBox[{},
       "Reals"],
      RowBox[{
       RowBox[{"2",
        SubscriptBox["\[Gamma]", "d"]}], "+", "1"}]]}]}], ","}],
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
   3.9630770753080597`*^9, 3.963077080156849*^9}, {3.9630886760630875`*^9,
   3.9630886760630875`*^9}, {3.963334237475191*^9, 3.963334237475191*^9}, {
   3.96333432456596*^9, 3.9633343428223953`*^9}, {3.9635025685698624`*^9,
   3.963502589460739*^9}, {3.9648990659278145`*^9, 3.9648990728059845`*^9}, {
   3.9657345259987183`*^9, 3.9657345285015583`*^9}, {3.9681523539586983`*^9,
   3.968152420351982*^9}, {3.968152552203848*^9, 3.9681526612255497`*^9}, {
   3.971006737591732*^9, 3.9710067399290867`*^9}, {3.971006863156561*^9,
   3.971006881008383*^9}, {3.9710069781897106`*^9, 3.971006979743969*^9}, {
   3.9710133805749264`*^9, 3.971013414312376*^9}, 3.9710140215956345`*^9, {
   3.9725625184735107`*^9, 3.972562689140465*^9}, 3.9778462227172623`*^9},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"6dc2b178-b9d5-1e41-9bbe-cde46c2f45bb"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["s", "j"], ":=",
    RowBox[{
     SubscriptBox["m", "1"], "+", "\[Ellipsis]", "+",
     SubscriptBox["m", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "24b9ffc4-07e2-8d44-bb1a-7cd837613254"],
 ", and the free indices are ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "1"], ",", "\[Ellipsis]", ",",
    SubscriptBox["m", "d"]}], TraditionalForm]],ExpressionUUID->
  "e82a1f0c-2fc2-4340-9a2d-c46b4e446a1b"],
 " along with the last index ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["s", "d"], TraditionalForm]],ExpressionUUID->
  "2f174180-8c15-cb48-be54-693d5822aaec"],
 ", which is completely determined by the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "j"], TraditionalForm]],ExpressionUUID->
  "90c8899d-b515-ab4b-9668-80b3f8439ea2"],
 ". Note that the Clebsch-Gordan tensor ",
 Cell[BoxData[
  FormBox[
   RowBox[{"CG", "(",
    RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}], TraditionalForm]],
  ExpressionUUID->"6f90bbc4-ccec-c748-a23d-2b5ed5d446b0"],
 " is nonzero iff ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]",
     RowBox[{
      SubscriptBox["\[Gamma]", "j"], "-",
      SubscriptBox["\[Gamma]",
       RowBox[{"j", "+", "1"}]]}], "\[RightBracketingBar]"}], "<=",
    SubscriptBox["\[Lambda]",
     RowBox[{"j", "+", "1"}]], "<=",
    RowBox[{
     SubscriptBox["\[Gamma]", "j"], "+",
     SubscriptBox["\[Gamma]",
      RowBox[{"j", "+", "1"}]]}]}], TraditionalForm]],ExpressionUUID->
  "08fbd5a1-9157-0a4b-bcac-0b25bf999da7"],
 " for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "<=", "j", "<=",
    RowBox[{"d", "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "33afe1d9-442d-ab4b-adbc-2f64a3ff76fa"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[LeftBracketingBar]",
      SubscriptBox["m", "j"], "\[RightBracketingBar]"}], "<=",
     SubscriptBox["\[Lambda]", "j"]}], " ", ",",
    RowBox[{
     RowBox[{"\[LeftBracketingBar]",
      SubscriptBox["s", "j"], "\[RightBracketingBar]"}], "<=",
     SubscriptBox["\[Gamma]", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "ca3f0edc-ed7a-fe49-b13c-94a2eecaad71"],
 " for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "<=", "j", "<=", "d"}], TraditionalForm]],ExpressionUUID->
  "6623e79c-0c83-0640-bec1-ed7b6557a5f2"],
 ". Moreover, it is always the case that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(",
      RowBox[{"1", ",", "2"}], ")"}],
     RowBox[{"CG", "(",
      RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}]}],
    RowBox[{" ",
     RowBox[{"=", " "}]}],
    RowBox[{
     SuperscriptBox[
      RowBox[{"(",
       RowBox[{"-", "1"}], ")"}],
      SubscriptBox["\[Gamma]", "2"]],
     RowBox[{"CG", "(",
      RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"df76e79e-999d-a64d-8348-13726627bca5"],
 "."
}], "Text",
 CellChangeTimes->{{3.971014022953123*^9, 3.9710140233214607`*^9}, {
   3.972562424790661*^9, 3.9725624360710697`*^9}, {3.9725626857045383`*^9,
   3.9725626939187527`*^9}, 3.972562745323324*^9, {3.978095850535099*^9,
   3.97809590384062*^9}},ExpressionUUID->"8f2be3e5-9634-7d42-bf53-\
d2041db5a2fa"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Remark", "Subsubsection",
 CellChangeTimes->{{3.977923469788824*^9,
  3.9779234702073307`*^9}},ExpressionUUID->"3901bbf6-dcf9-7040-a2ea-\
70b14f6e5765"],

Cell[TextData[{
 "In our setting, Schur-Weyl duality provides a clean way to bookkeep irrep \
multiplicity in the input space ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "d303d57a-8c9b-4740-94e7-67872f48e8f9"],
 "."
}], "Text",
 CellChangeTimes->{{3.9779235411276226`*^9, 3.977923607818363*^9},
   3.977923640639326*^9, {3.9779248099275208`*^9, 3.977924900307287*^9}, {
   3.9779249362914047`*^9, 3.9779249413473015`*^9}, {3.981123779458267*^9,
   3.9811237947224255`*^9}},ExpressionUUID->"4dc4ab09-50f3-c742-a4c3-\
3334a1f110a1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Definition (Young symmetrizer)", "Subsubsection",
 CellChangeTimes->{{3.971017265109833*^9,
  3.9710172695365353`*^9}},ExpressionUUID->"ec754421-1876-1841-a70d-\
ecfff171c37f"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[Pi]", TraditionalForm]],ExpressionUUID->
  "19cdcca6-c963-b347-ac23-61979b6360b8"],
 " be an integer partition of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "\[Element]", "\[DoubleStruckCapitalN]"}], TraditionalForm]],
  ExpressionUUID->"5c8eccbc-fa6f-884f-a50a-ffa7060f590c"],
 ", and let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "\[Pi]"], TraditionalForm]],ExpressionUUID->
  "47344d47-b46a-8b44-ae50-bf368a375c67"],
 " be the associated standard Young tableau filled in English-reading order. \
Define"
}], "Text",
 CellChangeTimes->{{3.963085273008539*^9, 3.9630853669347687`*^9}, {
  3.963085433880514*^9, 3.9630854454088573`*^9}, {3.9630854793595467`*^9,
  3.963085658336643*^9}, {3.9630880738647194`*^9, 3.9630881461384106`*^9}, {
  3.9630881908155403`*^9, 3.9630881949978237`*^9}, {3.963088676078766*^9,
  3.963088676126631*^9}, {3.9631942978630543`*^9, 3.9631943001346855`*^9}, {
  3.9633315120444202`*^9, 3.9633315193775578`*^9}, {3.963332640347378*^9,
  3.9633326762040615`*^9}, {3.963332719396036*^9, 3.963332719396036*^9}, {
  3.9646147627111797`*^9, 3.964614781978733*^9}, {3.964614999310545*^9,
  3.9646150006784515`*^9}, {3.9665178153078747`*^9, 3.9665178170134144`*^9}, {
  3.971017413198841*^9, 3.9710174154541473`*^9}, {3.971282650763308*^9,
  3.971282660315783*^9}, {3.9725649985141544`*^9, 3.972565009999399*^9}, {
  3.9779240354235*^9, 3.977924036427601*^9}},
 Background->None,ExpressionUUID->"8ec6c464-7d66-f74c-b360-280f2f695948"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["R", "\[Pi]"], ":=",
    RowBox[{"{",
     RowBox[{
      RowBox[{"\[Sigma]", "\[Element]",
       SubscriptBox["\[GothicCapitalS]", "d"]}], "|",
      RowBox[{
      "\[Sigma]", " ", "preserves", " ", "every", " ", "row", " ", "of", " ",

       SubscriptBox["T", "\[Pi]"]}]}], "}"}]}], ",", "\[IndentingNewLine]",
   RowBox[{
    SubscriptBox["C", "\[Pi]"], ":=",
    RowBox[{
     RowBox[{"{",
      RowBox[{
       RowBox[{"\[Sigma]", "\[Element]",
        SubscriptBox["\[GothicCapitalS]", "d"]}], "|",
       RowBox[{
       "\[Sigma]", " ", "preserves", " ", "every", " ", "column", " ", "of", " ",
        SubscriptBox["T", "\[Pi]"]}]}], "}"}], "."}]}]}],
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
  3.9630770753080597`*^9, 3.963077080156849*^9}, {3.963085636997587*^9,
  3.963085679066036*^9}, {3.9630859576108856`*^9, 3.9630859805296955`*^9}, {
  3.9630881179481335`*^9, 3.963088123609167*^9}, {3.963088676126631*^9,
  3.9630886761426716`*^9}, {3.9646147874914017`*^9, 3.9646149240548077`*^9}, {
  3.971282680411571*^9, 3.971282690395651*^9}, {3.977924571526453*^9,
  3.97792457456176*^9}},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"861fc9b0-df43-0641-8b02-cc7f285ff26e"],

Cell[TextData[{
 "The ",
 StyleBox["row antisymmetrizer",
  FontSlant->"Italic"],
 ", ",
 StyleBox["column symmetrizer",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["Young symmetrizer",
  FontSlant->"Italic"],
 " are, respectively,"
}], "Text",
 CellChangeTimes->{{3.963085273008539*^9, 3.9630853669347687`*^9}, {
   3.963085433880514*^9, 3.9630854454088573`*^9}, {3.9630854793595467`*^9,
   3.963085658336643*^9}, {3.9630880738647194`*^9, 3.9630881461384106`*^9}, {
   3.9630881908155403`*^9, 3.9630881949978237`*^9}, {3.963088676078766*^9,
   3.963088676126631*^9}, {3.9631942978630543`*^9, 3.9631943001346855`*^9}, {
   3.9633315120444202`*^9, 3.9633315193775578`*^9}, {3.963332640347378*^9,
   3.9633326762040615`*^9}, {3.963332719396036*^9, 3.963332719396036*^9}, {
   3.9646147627111797`*^9, 3.9646147807337685`*^9}, {3.9646149295495377`*^9,
   3.964614997382187*^9}, {3.9665174811103687`*^9, 3.9665175124025784`*^9}, {
   3.966517841074278*^9, 3.966517846294323*^9}, 3.9712826945713053`*^9, {
   3.9725650313846855`*^9, 3.9725650319776745`*^9}, {3.977924122730953*^9,
   3.9779241362592297`*^9}, {3.9779258218580265`*^9, 3.977925822102606*^9}},
 Background->None,ExpressionUUID->"b131882a-77e8-bb40-bad1-2f8528473cd2"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["r", "\[Pi]"], ":=",
    RowBox[{
     FractionBox["1",
      RowBox[{"\[LeftBracketingBar]",
       SubscriptBox["R", "\[Pi]"], "\[RightBracketingBar]"}]],
     RowBox[{
      UnderscriptBox["\[Sum]",
       RowBox[{"\[Sigma]", "\[Element]",
        SubscriptBox["R", "\[Pi]"]}]],
      RowBox[{
       RowBox[{"sgn", "(", "\[Sigma]", ")"}], "\[Sigma]"}]}]}]}], ",",
   "\[IndentingNewLine]",
   RowBox[{
    SubscriptBox["c", "\[Pi]"], ":=",
    RowBox[{
     FractionBox["1",
      RowBox[{"\[LeftBracketingBar]",
       SubscriptBox["C", "\[Pi]"], "\[RightBracketingBar]"}]],
     RowBox[{
      UnderscriptBox["\[Sum]",
       RowBox[{"\[Sigma]", "\[Element]",
        SubscriptBox["C", "\[Pi]"]}]], "\[Sigma]"}]}]}], ",", "\n",
   RowBox[{
    SubscriptBox["e", "\[Pi]"], ":=",
    RowBox[{
     FractionBox[
      RowBox[{
       RowBox[{"\[LeftBracketingBar]",
        SubscriptBox["R", "\[Pi]"], "\[RightBracketingBar]"}],
       RowBox[{"\[LeftBracketingBar]",
        SubscriptBox["C", "\[Pi]"], "\[RightBracketingBar]"}]}],
      SubscriptBox["HL", "\[Pi]"]],
     SubscriptBox["c", "\[Pi]"],
     SubscriptBox["r", "\[Pi]"]}]}], ","}],
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
