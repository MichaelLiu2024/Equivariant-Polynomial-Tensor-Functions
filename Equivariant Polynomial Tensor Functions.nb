Cell[TextData[{
 "Our approach is to explicitly compute the isotypic decomposition of the \
symmetric power of a finite dimensional ",
 Cell[BoxData[
  FormBox[
   RowBox[{"SO", "(", "3", ")"}], TraditionalForm]],ExpressionUUID->
  "217722c6-9f51-604a-a463-ddf06f19a7d9"],
 "-representation using Schur-Weyl duality and Clebsch-Gordan theory. We then \
extract generators degree by degree using Nakayama\[CloseCurlyQuote]s lemma."
}], "Text",
 CellChangeTimes->{{3.9683418663686733`*^9, 3.9683419828732147`*^9}, {
