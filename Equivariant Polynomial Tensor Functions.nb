Cell[TextData[{
 "We provide an algorithm that enumerates minimal integrity bases for the set \
of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"SO", "(", "3", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "938f085f-2281-9e4f-9fb6-70eb317842e1"],
 "-equivariant polynomials between finite dimensional ",
 Cell[BoxData[
  FormBox[
   RowBox[{"SO", "(", "3", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5c27780f-f159-6744-9e78-ef9b0ce6208d"],
 "-representations in time polynomial in TODO and space polynomial in TODO."
}], "Text",
