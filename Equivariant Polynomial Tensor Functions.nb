Cell[TextData[{
 "where the third line is due to the Cauchy decomposition. Since each \
intermediate isomorphism is unitary and ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "df67806e-71b8-2741-8caa-8c50f4e519f2"],
 "-equivariant, so is the composition."
}], "Text",
