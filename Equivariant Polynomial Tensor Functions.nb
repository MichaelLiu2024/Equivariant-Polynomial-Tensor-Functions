Cell[TextData[{
 "Theorem (Isotypic decomposition of the tensor product of two ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "ac5c3da3-cac4-9449-aec0-b7c63d9ce22c"],
