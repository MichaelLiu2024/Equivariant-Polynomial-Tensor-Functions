Cell[CellGroupData[{

Cell["Definition (Elementary Clebsch-Gordan tensor)", "Subsubsection",
 CellChangeTimes->{{3.971006577122019*^9, 3.9710065823838882`*^9}, {
  3.9778442336588745`*^9, 
  3.977844234999901*^9}},ExpressionUUID->"d7c5a3d1-d87d-5d4a-a969-\
c80445e1f55a"],

Cell[TextData[{
 "For any ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Lambda]", ":=", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Lambda]", "1"], ",", 
       SubscriptBox["\[Lambda]", "2"]}], ")"}]}], ",", 
    RowBox[{"\[Gamma]", ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[Gamma]", "1"], ",", 
        SubscriptBox["\[Gamma]", "2"]}], ")"}], "\[Element]", 
      SuperscriptBox["\[CapitalLambda]", "2"]}]}]}], TraditionalForm]],
  ExpressionUUID->"21e5f9d7-71d1-d848-9605-f1edfea8bb9d"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], "=", 
    SubscriptBox["\[Gamma]", "1"]}], TraditionalForm]],ExpressionUUID->
  "cc74a834-10f0-f144-a9f5-364afb767ed5"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], "-", 
      SubscriptBox["\[Lambda]", "2"]}], "\[RightBracketingBar]"}], "<=", 
    SubscriptBox["\[Gamma]", "2"], "<=", 
    RowBox[{
     SubscriptBox["\[Lambda]", "1"], "+", 
     SubscriptBox["\[Lambda]", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "678fe966-417a-2249-b5cc-ba0757dde475"],
 ", the ",
 StyleBox["elementary Clebsch-Gordan tensor",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"CG", "(", 
    RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}], TraditionalForm]],
  ExpressionUUID->"637b4ea8-633e-9347-a8b9-038839628ae6"],
 " is the unique element in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["H", 
       SubscriptBox["\[Lambda]", "1"]], "\[CircleTimes]", 
      SubscriptBox["H", 
       SubscriptBox["\[Lambda]", "2"]], "\[CircleTimes]", 
      SubscriptBox["H", 
       SubscriptBox["\[Gamma]", "2"]]}], ")"}], "G"], TraditionalForm]],
  ExpressionUUID->"e06f8446-0b46-6545-9067-e50a79a538ce"],
 " normalized via the Condon\[Dash]Shortley phase convention."
}], "Text",
 CellChangeTimes->{{3.971006619536833*^9, 3.9710066430040836`*^9}, {
   3.9710066781060104`*^9, 3.9710067221026955`*^9}, {3.9710069235613403`*^9, 
   3.97100692749271*^9}, {3.9710137024596615`*^9, 3.9710137210363636`*^9}, {
   3.971015845836649*^9, 3.9710158531522713`*^9}, {3.972562389141632*^9, 
   3.9725623939795647`*^9}, {3.9778441120931396`*^9, 3.977844113449047*^9}, {
   3.977844299658266*^9, 3.977844299658266*^9}, {3.977844938051195*^9, 
   3.9778449667371235`*^9}, {3.977845516976509*^9, 3.9778455879095955`*^9}, {
   3.977845714573208*^9, 3.977845741499737*^9}, {3.9778457718465633`*^9, 
   3.9778457771815987`*^9}, {3.977845930477886*^9, 3.9778459310296516`*^9}, 
   3.9778461252948856`*^9, {3.9779230604434757`*^9, 
   3.977923070357628*^9}},ExpressionUUID->"b4f4c018-0f8e-e542-84a8-\
389055370ed1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Definition (Iterated Clebsch-Gordan tensor)", "Subsubsection",
 CellChangeTimes->{{3.971006577122019*^9, 3.9710065823838882`*^9}, {
  3.977844237099571*^9, 
  3.9778442379579525`*^9}},ExpressionUUID->"37b0adf8-ad6d-4442-ac5b-\
a3ed53d92f0f"],

Cell[TextData[{
 "For any ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Lambda]", ":=", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Lambda]", "1"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[Lambda]", "d"]}], ")"}]}], ",", 
    RowBox[{"\[Gamma]", ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[Gamma]", "1"], ",", "\[Ellipsis]", ",", 
        SubscriptBox["\[Gamma]", "d"]}], ")"}], "\[Element]", 
      SuperscriptBox["\[CapitalLambda]", "d"]}]}]}], TraditionalForm]],
  ExpressionUUID->"6eb888ab-d37f-b64e-b5b7-b9dcc4d08c5b"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], "=", 
    SubscriptBox["\[Gamma]", "1"]}], TraditionalForm]],ExpressionUUID->
  "ceee791f-bf4d-2840-af91-05fac5c44675"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      SubscriptBox["\[Lambda]", "j"], "-", 
      SubscriptBox["\[Lambda]", 
       RowBox[{"j", "+", "1"}]]}], "\[RightBracketingBar]"}], "<=", 
    SubscriptBox["\[Gamma]", 
     RowBox[{"j", "+", "1"}]], "<=", 
    RowBox[{
     SubscriptBox["\[Lambda]", "j"], "+", 
     SubscriptBox["\[Lambda]", 
      RowBox[{"j", "+", "1"}]]}]}], TraditionalForm]],ExpressionUUID->
  "134a9c9f-31bb-3443-9638-558266e07837"],
 " for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "<=", "j", "<=", 
    RowBox[{"d", "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "f3fa4115-e620-bb45-92a7-f5a5dac0b53f"],
 ", the ",
 StyleBox["Clebsch-Gordan tensor",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"CG", "(", 
    RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}], TraditionalForm]],
  ExpressionUUID->"8ec767f2-4789-f445-80e1-2bc5bdb49314"],
 " is the unique element in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["H", 
       SubscriptBox["\[Lambda]", "1"]], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
      SubscriptBox["H", 
       SubscriptBox["\[Lambda]", "d"]], "\[CircleTimes]", 
      SubscriptBox["H", 
       SubscriptBox["\[Gamma]", "d"]]}], ")"}], "G"], TraditionalForm]],
  ExpressionUUID->"157ed7d4-650f-754e-b253-d0e9d6cb9883"],
 " with the tensor train factorization"
}], "Text",
 CellChangeTimes->{{3.971006619536833*^9, 3.9710066430040836`*^9}, {
  3.9710066781060104`*^9, 3.9710067221026955`*^9}, {3.9710069235613403`*^9, 
  3.97100692749271*^9}, {3.9710137024596615`*^9, 3.9710137210363636`*^9}, {
  3.971015845836649*^9, 3.9710158531522713`*^9}, {3.972562389141632*^9, 
  3.9725623939795647`*^9}, {3.9778441120931396`*^9, 3.977844113449047*^9}, {
  3.9778453245612373`*^9, 3.9778453520887356`*^9}, {3.977845788118374*^9, 
  3.977845828185961*^9}, {3.977845932243593*^9, 3.9778460371561527`*^9}, {
  3.9779231124167423`*^9, 
  3.9779231197816925`*^9}},ExpressionUUID->"0b18156d-e149-2f47-99c9-\
de0c82bc57b0"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"CG", "(", 
     RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}], ":=", 
    RowBox[{
     UnderoverscriptBox["\[Product]", 
      RowBox[{"j", "=", "1"}], 
      RowBox[{"d", "-", "1"}]], 
     RowBox[{"CG", "(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Gamma]", "j"], ",", 
         SubscriptBox["\[Lambda]", 
          RowBox[{"j", "+", "1"}]]}], ")"}], ",", 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Gamma]", "j"], ",", 
         SubscriptBox["\[Gamma]", 
          RowBox[{"j", "+", "1"}]]}], ")"}]}], ")"}]}]}], ","}], 
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
   3.9630770753080597`*^9, 3.963077080156849*^9}, {3.9630886760630875`*^9, 
