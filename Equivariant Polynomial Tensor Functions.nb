Cell[CellGroupData[{

Cell["Overview", "Section",
 CellChangeTimes->{{3.9809560123832703`*^9, 
  3.9809560135362988`*^9}},ExpressionUUID->"c0d40002-6e9d-bf47-a640-\
73b8c0dab720"],

Cell[TextData[{
 "Write ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "\[TildeFullEqual]", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", 
      RowBox[{"D", "\[Element]", 
       TemplateBox[{},
        "NonNegativeIntegers"]}]], 
     SuperscriptBox["M", "D"]}]}], TraditionalForm]],ExpressionUUID->
  "9699658d-14da-3946-82d9-c09116be4f0a"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "\[TildeFullEqual]", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", 
      RowBox[{"D", "\[Element]", 
       TemplateBox[{},
        "NonNegativeIntegers"]}]], 
     SuperscriptBox["R", "D"]}]}], TraditionalForm]],ExpressionUUID->
  "edba9bdb-c1ba-6d41-b06b-e0cb936d3801"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["M", "D"], ":=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox["\[ScriptCapitalS]", "D"], "(", 
        SuperscriptBox["X", "*"], ")"}], "\[CircleTimes]", "Y"}], ")"}], 
     "G"]}], TraditionalForm]], "DisplayFormula",
  CellChangeTimes->{{3.971002790255043*^9, 3.9710027918797283`*^9}, {
   3.971002973488472*^9, 3.971002973663662*^9}, {3.97100307613105*^9, 
   3.9710030766647224`*^9}},
  TextAlignment->Center,ExpressionUUID->
  "f570efb0-20cf-8b42-a789-27dbab7c2ccf"],
 " is the set of degree ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "a8ea3f17-a19f-c940-ab60-91c04cfc3d8b"],
 " homogeneous ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "6f23575b-79c9-174b-8954-e2388c9e14ef"],
 "-equivariant polynomials from ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],
  FontSlant->"Plain",ExpressionUUID->"c2bc0a71-76d0-9648-9267-984b414b861d"],
 " to ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],
  FontSlant->"Plain",ExpressionUUID->"641565e5-21c6-d34a-b477-f16c8f1422bd"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["R", "D"], ":=", 
    SuperscriptBox[
     RowBox[{
      SuperscriptBox["\[ScriptCapitalS]", "D"], "(", 
      SuperscriptBox["X", "*"], ")"}], "G"]}], TraditionalForm]], 
  "DisplayFormula",
  CellChangeTimes->{{3.971002790255043*^9, 3.9710027918797283`*^9}, {
   3.971002973488472*^9, 3.971002973663662*^9}, {3.97100307613105*^9, 
   3.9710030766647224`*^9}},
  TextAlignment->Center,ExpressionUUID->
  "79a4470f-dca3-8449-8c9e-d2b49e14a116"],
 " is the set of degree ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "bc472cd2-cbd2-5c4d-8dc3-41ee4ba324d1"],
 " homogeneous ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "7b1e1ebc-01bd-764d-b870-fee178467533"],
 "-invariant polynomials on ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],
  FontSlant->"Plain",ExpressionUUID->"b6b54e8f-e95e-9c4a-aa74-85c2824906fb"],
 ". Now, suppose that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Y", "=", 
    SubscriptBox["H", "\[Nu]"]}], TraditionalForm]],ExpressionUUID->
  "a4092436-93ad-5c41-943e-e0d58f3462e2"],
 ". Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["M", "D"], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[ScriptCapitalS]", "D"], "(", 
         SuperscriptBox["X", "*"], ")"}], "\[CircleTimes]", 
        SubscriptBox["H", "\[Nu]"]}], ")"}], "G"], "\[TildeFullEqual]", 
     RowBox[{
      SubscriptBox["Hom", "G"], "(", 
      RowBox[{
       SubscriptBox["H", "\[Nu]"], ",", 
       RowBox[{
        SuperscriptBox["\[ScriptCapitalS]", "D"], "(", 
        SuperscriptBox["X", "*"], ")"}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"468def2d-bada-374f-b4aa-d8311fba8f16"],
 ", which is precisely the multiplicity space corresponding to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", "\[Nu]"], TraditionalForm]],ExpressionUUID->
  "e3885652-0fa8-694d-a57d-eea5431da793"],
 " in the isotypic decomposition of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalS]", "D"], "(", 
     SuperscriptBox["X", "*"], ")"}], "\[TildeFullEqual]", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", 
      RowBox[{"\[Nu]", "\[Element]", "\[CapitalLambda]"}]], 
     RowBox[{
      SubscriptBox["H", "\[Nu]"], "\[CircleTimes]", 
      RowBox[{
       SubscriptBox["Hom", "G"], "(", 
       RowBox[{
        SubscriptBox["H", "\[Nu]"], ",", 
        RowBox[{
         SuperscriptBox["\[ScriptCapitalS]", "D"], "(", 
         SuperscriptBox["X", "*"], ")"}]}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"3836ed10-f777-8942-9b8c-6de5948cb80c"],
 ". Similarly, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["R", "D"], "\[TildeFullEqual]", 
    RowBox[{
     SubscriptBox["Hom", "G"], "(", 
     RowBox[{
      SubscriptBox["H", "0"], ",", 
      RowBox[{
       SuperscriptBox["\[ScriptCapitalS]", "D"], "(", 
       SuperscriptBox["X", "*"], ")"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"4e182947-a951-bc4f-9d91-725d04b00cce"],
 " is precisely the multiplicity space corresponding to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", "0"], TraditionalForm]],ExpressionUUID->
  "590515f1-99c1-9147-a045-e321c91cc5f8"],
 " in the isotypic decomposition of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalS]", "D"], "(", 
    SuperscriptBox["X", "*"], ")"}], TraditionalForm]],ExpressionUUID->
  "092ab824-2ba9-664b-8b8f-cce67d40ea75"],
 ". Therefore, our first goal is to explicitly determine the isotypic \
decomposition of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalS]", "D"], "(", 
    SuperscriptBox["X", "*"], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8d8e85ae-f1a7-a047-85a0-4114c435937e"],
 "."
}], "Text",
 CellChangeTimes->{{3.9809565273301735`*^9, 3.9809566230266743`*^9}, {
  3.9809566545420895`*^9, 3.9809566704909153`*^9}, {3.9809567069230366`*^9, 
  3.980956952676771*^9}, {3.980957001170788*^9, 3.980957040466976*^9}, {
  3.9809570890526752`*^9, 3.9809571021503773`*^9}, {3.980957152487383*^9, 
  3.980957174031868*^9}},ExpressionUUID->"941ba06f-2915-8c4c-8df9-\
fba165a0387e"],

Cell[CellGroupData[{

Cell[TextData[{
 "Theorem 1 (Isotypic decomposition of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalS]", "D"], "(", 
    SuperscriptBox["X", "*"], ")"}], TraditionalForm]],ExpressionUUID->
  "b5c8323d-062c-7348-b10e-a1b31f6e1880"],
 ")"
}], "Subsubsection",
 CellChangeTimes->{{3.970582252027788*^9, 3.970582255578652*^9}, {
  3.97058361993813*^9, 3.970583629107135*^9}, {3.971453823587208*^9, 
  3.971453823650774*^9}, {3.972144487744378*^9, 3.972144488527927*^9}, {
  3.980950111165825*^9, 3.9809501117801094`*^9}, {3.9809572579251785`*^9, 
  3.980957275055357*^9}},ExpressionUUID->"1d6d6fad-1088-4af3-be79-\
2c9fa2675c22"],

Cell[TextData[{
 "Write ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["X", "\[Lambda]"], ":=", 
    RowBox[{
     SubscriptBox["Hom", "G"], "(", 
     RowBox[{
      SubscriptBox["H", "\[Lambda]"], ",", "X"}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0c386c23-2550-7441-b902-f29a8e06d510"],
 " for convenience. There exists a ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "97575381-6602-9642-95d9-f9d9bb064d89"],
 "-equivariant isomorphism"
}], "Text",
 CellChangeTimes->{{3.9687631403371353`*^9, 3.968763141036047*^9}, {
   3.9687633072572613`*^9, 3.9687633422499504`*^9}, {3.968771520102394*^9, 
   3.9687715557493896`*^9}, {3.968775528711878*^9, 3.9687755419589176`*^9}, {
   3.968775617638569*^9, 3.9687756408876686`*^9}, 3.970582338842451*^9, {
   3.970582575087944*^9, 3.97058257533815*^9}, {3.970582987063113*^9, 
   3.970583008070634*^9}, {3.971366989812829*^9, 3.971366991188349*^9}, {
   3.972144744190754*^9, 3.972144771934545*^9}, {3.9725670768366985`*^9, 
   3.972567078311039*^9}, {3.972580770156933*^9, 3.9725807727511272`*^9}, {
   3.9725829578427753`*^9, 3.9725829589801693`*^9}, {3.9809575802264824`*^9, 
   3.9809575852241344`*^9}},ExpressionUUID->"8a778b3f-9235-464d-99ee-\
4e8342a41fd3"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalS]", "D"], "(", 
     SuperscriptBox["X", "*"], ")"}], "\[TildeFullEqual]", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", 
      RowBox[{"\[Nu]", "\[Element]", "\[CapitalLambda]"}]], 
     RowBox[{
      SubscriptBox["H", "\[Nu]"], "\[CircleTimes]", 
      RowBox[{"(", 
       RowBox[{
        UnderscriptBox["\[CirclePlus]", 
         SubscriptBox[
          RowBox[{"(", 
           SubscriptBox["d", "\[Lambda]"], ")"}], "\[Lambda]"]], 
        RowBox[{
         UnderscriptBox["\[CirclePlus]", 
          SubscriptBox[
           RowBox[{"(", 
            SubscriptBox["\[Pi]", "\[Lambda]"], ")"}], "\[Lambda]"]], 
         RowBox[{
          UnderscriptBox["\[CirclePlus]", 
           SubscriptBox[
            RowBox[{"(", 
             SubscriptBox["\[Mu]", "\[Lambda]"], ")"}], "\[Lambda]"]], 
          RowBox[{
           RowBox[{
            SubscriptBox["Hom", "G"], "(", 
            RowBox[{
             SubscriptBox["H", "\[Nu]"], ",", 
             RowBox[{
              UnderscriptBox["\[CircleTimes]", "\[Lambda]"], 
              SubscriptBox["H", 
               SubscriptBox["\[Mu]", "\[Lambda]"]]}]}], ")"}], "\[CircleTimes]", 
           RowBox[{"(", 
            RowBox[{
             UnderscriptBox["\[CircleTimes]", "\[Lambda]"], 
             RowBox[{
              SubscriptBox["Hom", "G"], "(", 
              RowBox[{
               SubscriptBox["H", 
                SubscriptBox["\[Mu]", "\[Lambda]"]], ",", 
               RowBox[{
                SubscriptBox["e", 
                 SubscriptBox["\[Pi]", "\[Lambda]"]], "(", 
                SubsuperscriptBox["H", "\[Lambda]", 
                 RowBox[{"\[CircleTimes]", 
                  SubscriptBox["d", "\[Lambda]"]}]], ")"}]}], ")"}]}], ")"}], 
           "\[CircleTimes]", 
           RowBox[{"(", 
            RowBox[{
             UnderscriptBox["\[CircleTimes]", "\[Lambda]"], 
             RowBox[{
              SubsuperscriptBox["e", 
               SubscriptBox["\[Pi]", "\[Lambda]"], "*"], "(", 
              SubsuperscriptBox["X", "\[Lambda]", 
               RowBox[{"\[CircleTimes]", 
                SubscriptBox["d", "\[Lambda]"]}]], ")"}]}], ")"}]}]}]}]}], 
       ")"}]}]}]}], ","}], TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9627488855059834`*^9, 3.962748887091898*^9}, {
   3.96298416400049*^9, 3.9629841970599346`*^9}, {3.96298433040728*^9, 
   3.9629843687252007`*^9}, 3.9629845748442993`*^9, {3.9629846225756702`*^9, 
   3.962984622593195*^9}, {3.9629846636633415`*^9, 3.962984747312292*^9}, {
   3.962984801633169*^9, 3.962984819495487*^9}, {3.962984853239086*^9, 
   3.962984857460287*^9}, {3.9629848882536488`*^9, 3.9629848898290577`*^9}, 
   3.9629868997007904`*^9, {3.9630700739716244`*^9, 3.9630700798365593`*^9}, {
   3.9630870895910034`*^9, 3.963087089687145*^9}, {3.9633342409557667`*^9, 
   3.963334243550709*^9}, {3.963334343835724*^9, 3.9633343441863384`*^9}, {
   3.9641030455485973`*^9, 3.964103051401596*^9}, {3.964808770822912*^9, 
   3.964808815764282*^9}, {3.965298082616085*^9, 3.965298090226063*^9}, {
   3.965298128270773*^9, 3.965298128490053*^9}, {3.9705814967054853`*^9, 
   3.970581511744609*^9}, {3.970582142716488*^9, 3.970582153499732*^9}, {
   3.970582285259131*^9, 3.970582288971987*^9}, {3.970582380202836*^9, 
   3.970582528602455*^9}, 3.970582618873745*^9, {3.970583288805018*^9, 
   3.970583295557033*^9}, {3.9725807506110725`*^9, 3.972580767223896*^9}, {
   3.972580947646263*^9, 3.9725809476841946`*^9}, 3.972582962199732*^9, {
   3.9809573807489758`*^9, 3.9809573890582867`*^9}, {3.980957625097763*^9, 
   3.9809576251459675`*^9}},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"30f76cf0-f42d-4e06-b038-a1cc507a0380"],

Cell["where", "Text",
 CellChangeTimes->{{3.972142713291314*^9, 3.9721427582024508`*^9}, {
  3.972142970426324*^9, 3.9721429706656923`*^9}, {3.972566264098608*^9, 
  3.972566277438122*^9}, {3.9809576636413994`*^9, 3.9809576783783226`*^9}, {
  3.980957739542631*^9, 
  3.980957803283743*^9}},ExpressionUUID->"35453032-3cc3-4446-b668-\
6498813d58dc"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9ac746c9-1d1b-8942-a42b-6ed1518f3b6a"],
 " ranges over all nonnegative integers such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["X", "\[Lambda]"], "!=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e0ae8bf7-eb8c-444b-94dd-7201ebe0ee55"],
 ","
}], "Item",
 CellChangeTimes->{{3.972142713291314*^9, 3.9721427582024508`*^9}, {
  3.972142970426324*^9, 3.9721429706656923`*^9}, {3.972566264098608*^9, 
  3.972566277438122*^9}, {3.9809576636413994`*^9, 3.9809576783783226`*^9}, {
  3.980957739542631*^9, 3.980957806576252*^9}, {3.9809578639016438`*^9, 
  3.980957867470934*^9}},ExpressionUUID->"11fc72cf-631b-6c4a-85f5-\
90c67b62f803"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["d", "\[Lambda]"], ")"}], "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"79d0a3e7-8611-c247-a40b-9ff9f4b54909"],
 " ranges over all sequences of nonnegative integers such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderscriptBox["\[Sum]", "\[Lambda]"], 
     SubscriptBox["d", "\[Lambda]"]}], "=", "D"}], TraditionalForm]],
  ExpressionUUID->"9b343e3d-9dd6-7045-a65c-10d6ed6e7053"],
 ","
}], "Item",
 CellChangeTimes->{{3.972142713291314*^9, 3.9721427582024508`*^9}, {
  3.972142970426324*^9, 3.9721429706656923`*^9}, {3.972566264098608*^9, 
  3.972566277438122*^9}, {3.9809576636413994`*^9, 3.9809576783783226`*^9}, {
  3.980957739542631*^9, 
  3.980957810627592*^9}},ExpressionUUID->"b667b1f7-0e0a-b649-afaa-\
83843fb62541"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["\[Pi]", "\[Lambda]"], ")"}], "\[Lambda]"], 
   TraditionalForm]],ExpressionUUID->"05ffa153-5728-8e4f-88f0-849a58eaf9c5"],
 " ranges over all sequences of integer partitions ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Pi]", "\[Lambda]"], "\[RightTee]", 
    SubscriptBox["d", "\[Lambda]"]}], TraditionalForm]],ExpressionUUID->
  "66db4b02-4aa1-5d4a-877b-34dd0efefcba"],
 " such that each partition has largest part at most ",
 Cell[BoxData[
  FormBox[
   RowBox[{"min", "(", 
    RowBox[{
     RowBox[{"dim", " ", 
      SubscriptBox["H", "\[Lambda]"]}], ",", 
     RowBox[{"dim", " ", 
      SubscriptBox["X", "\[Lambda]"]}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"59061f9a-141d-5b44-b0e7-a7d6786784ac"],
 ", and"
}], "Item",
 CellChangeTimes->{{3.972142713291314*^9, 3.9721427582024508`*^9}, {
  3.972142970426324*^9, 3.9721429706656923`*^9}, {3.972566264098608*^9, 
  3.972566277438122*^9}, {3.9809576636413994`*^9, 3.9809576783783226`*^9}, {
  3.980957739542631*^9, 
  3.9809578453757343`*^9}},ExpressionUUID->"a87a8861-ee84-7b47-842c-\
221acd88bf08"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["\[Mu]", "\[Lambda]"], ")"}], "\[Lambda]"], 
   TraditionalForm]],ExpressionUUID->"18561475-194f-9045-aecc-f96b2f1e7ddd"],
 " ranges over all sequences of nonnegative integers such that all ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(", 
    RowBox[{
     SubscriptBox["H", 
      SubscriptBox["\[Mu]", "\[Lambda]"]], ",", 
     RowBox[{
      SubscriptBox["e", 
       SubscriptBox["\[Pi]", "\[Lambda]"]], "(", 
      SubsuperscriptBox["H", "\[Lambda]", 
       RowBox[{"\[CircleTimes]", 
        SubscriptBox["d", "\[Lambda]"]}]], ")"}]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ff446b83-e76f-e14d-9393-a7feddc12ae1"],
 " are nonzero and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(", 
    RowBox[{
     SubscriptBox["H", "\[Nu]"], ",", 
     RowBox[{
      UnderscriptBox["\[CircleTimes]", "\[Lambda]"], 
      SubscriptBox["H", 
       SubscriptBox["\[Mu]", "\[Lambda]"]]}]}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6f35eb5a-aee5-254f-9927-495a6aa53622"],
 " is nonzero."
}], "Item",
 CellChangeTimes->{{3.972142713291314*^9, 3.9721427582024508`*^9}, {
  3.972142970426324*^9, 3.9721429706656923`*^9}, {3.972566264098608*^9, 
  3.972566277438122*^9}, {3.9809576636413994`*^9, 3.9809576783783226`*^9}, {
  3.980957739542631*^9, 3.980957815083647*^9}, {3.9809578991409626`*^9, 
  3.9809579299436283`*^9}},ExpressionUUID->"7e3bdf94-416d-d94e-a14d-\
b8d0db8b66f2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Proof", "Subsubsection",
 CellChangeTimes->{{3.980958203962511*^9, 
  3.980958204444048*^9}},ExpressionUUID->"015084b6-ce31-a044-bd91-\
284aa2dc8c6a"],

Cell["See Appendix A.", "Text",
 CellChangeTimes->{{3.9809582064489975`*^9, 
  3.980958222272806*^9}},ExpressionUUID->"81b30c67-a076-454a-837c-\
6e2fac1d4c6e"]
