 TextAlignment->Center,
 Background->None,ExpressionUUID->"861fc9b0-df43-0641-8b02-cc7f285ff26e"],

Cell[TextData[{
 "The ",
 StyleBox["row antisymmetrizer",
  FontSlant->"Italic"],
 ", ",
 StyleBox["column symmetrizer",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["Young symmetrizer",
  FontSlant->"Italic"],
 " are, respectively,"
}], "Text",
 CellChangeTimes->{{3.963085273008539*^9, 3.9630853669347687`*^9}, {
   3.963085433880514*^9, 3.9630854454088573`*^9}, {3.9630854793595467`*^9, 
