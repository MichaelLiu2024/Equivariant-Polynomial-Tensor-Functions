  "\n",
  RowBox[{
   RowBox[{
    RowBox[{"SchurSS", "::", "usage"}],
    RowBox[{" ",
     RowBox[{
     "=", " "}]}], "\"\<gives the Schur polynomial corresponding to the \
integer partition p in the variables vars.\>\""}], "\n",
   RowBox[{
    RowBox[{"SchurSS", "[",
     RowBox[{
      RowBox[{"{", "}"}], ",",
      RowBox[{"vars_List", "?", "VectorQ"}]}], "]"}], ":=", "1"}], "\n",
   RowBox[{
    RowBox[{"SchurSS", "[",
     RowBox[{
      RowBox[{"p_List", "?", "VectorQ"}], ",",
      RowBox[{"vars_List", "?", "VectorQ"}]}], "]"}], ":=", "\n", " ",
    RowBox[{"With", "[", "\n", "  ",
     RowBox[{
      RowBox[{"{",
       RowBox[{
        RowBox[{"n",
         RowBox[{" ",
          RowBox[{"=", " "}]}],
         RowBox[{"Length",
          RowBox[{" ",
           RowBox[{"@", " "}]}], "vars"}]}], ",",
        RowBox[{"id",
         RowBox[{" ",
          RowBox[{"=", " "}]}],
         RowBox[{"Range",
          RowBox[{" ",
           RowBox[{"@", " "}]}],
          RowBox[{"Length",
           RowBox[{" ",
            RowBox[{"@", " "}]}], "p"}]}]}]}], "}"}], ",", "\n", "  ",
      RowBox[{"{",
       RowBox[{"elist",
        RowBox[{" ",
         RowBox[{"=", " "}]}],
        RowBox[{"Table", "[",
         RowBox[{
          RowBox[{"SymmetricPolynomial", "[",
           RowBox[{"k", ",", "vars"}], "]"}], ",",
          RowBox[{"{",
           RowBox[{"k", ",", "n"}], "}"}]}], "]"}]}], "}"}], ",", "\n", "  ",
      "\n", "  ",
      RowBox[{
       RowBox[{"If", "[",
        RowBox[{
         RowBox[{
          RowBox[{"First",
           RowBox[{" ",
            RowBox[{"@", " "}]}], "p"}], ">", "n"}], ",",
         RowBox[{"Return",
          RowBox[{" ",
           RowBox[{"@", " "}]}], "0"}]}], "]"}], ";", "\n", "  ", "\n", "  ",

       RowBox[{"(*",
        RowBox[{"Det", " ", "is", " ", "the", " ",
         RowBox[{"bottleneck", ".", " ", "Symbolic"}], " ", "determinant", " ",
          "of", " ", "a", " ", "matrix", " ", "with", " ", "polynomial", " ",
         "entries"}], "*)"}], "\n", "  ",
       RowBox[{
        RowBox[{"Det",
         RowBox[{" ",
          RowBox[{"@", " "}]}],
         RowBox[{"Outer", "[", "\n", "   ",
          RowBox[{
           RowBox[{
            RowBox[{"With", "[",
             RowBox[{
              RowBox[{"{",
               RowBox[{"r",
                RowBox[{" ",
                 RowBox[{"=", " "}]}],
                RowBox[{"Plus",
                 RowBox[{" ",
                  RowBox[{"@", " "}]}], "##"}]}], "}"}], ",",
              RowBox[{"Which", "[",
               RowBox[{
                RowBox[{"r", "==", "0"}], ",", "1", ",",
                RowBox[{"0", "<", "r", "<=", "n"}], ",",
                RowBox[{"e", "[", "r", "]"}], ",", "True", ",", "0"}],
               "]"}]}], "]"}], "&"}], ",", "\n", "   ",
           RowBox[{"p", "-", "id"}], ",", "\n", "   ", "id"}], "\n", "  ",
          "]"}]}], "/.",
        RowBox[{
         RowBox[{"e", "[", "r_", "]"}], ":>",
         RowBox[{"elist", "[",
          RowBox[{"[", "r", "]"}], "]"}]}]}]}]}], "\n", " ",
     "]"}]}]}]}]], "Input",
