Cell[CellGroupData[{

Cell["Remark", "Subsubsection",
 CellChangeTimes->{{3.9811211528644505`*^9,
  3.9811211532622776`*^9}},ExpressionUUID->"0148959b-9e7c-d24e-8e89-\
34c5bcf0a023"],

Cell["An elementary tensor in", "Text",
 CellChangeTimes->{{3.981121219446369*^9,
  3.9811212253141384`*^9}},ExpressionUUID->"76eb9288-2c04-2c4b-a688-\
bf4d26bf2e73"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["Hom", "G"], "(",
    RowBox[{
     SubscriptBox["H", "\[Nu]"], ",",
     RowBox[{
      UnderscriptBox["\[CircleTimes]", "\[Lambda]"],
      SubscriptBox["H",
       SubscriptBox["\[Mu]", "\[Lambda]"]]}]}], ")"}], "\[CircleTimes]",
   RowBox[{"(",
    RowBox[{
     UnderscriptBox["\[CircleTimes]", "\[Lambda]"],
     RowBox[{
      SubscriptBox["Hom", "G"], "(",
      RowBox[{
       SubscriptBox["H",
        SubscriptBox["\[Mu]", "\[Lambda]"]], ",",
       RowBox[{
        SubscriptBox["e",
         SubscriptBox["\[Pi]", "\[Lambda]"]], "(",
        SubsuperscriptBox["H", "\[Lambda]",
         RowBox[{"\[CircleTimes]",
          SubscriptBox["d", "\[Lambda]"]}]], ")"}]}], ")"}]}], ")"}], "\[CircleTimes]",
   RowBox[{"(",
    RowBox[{
     UnderscriptBox["\[CircleTimes]", "\[Lambda]"],
     RowBox[{
      SubsuperscriptBox["e",
       SubscriptBox["\[Pi]", "\[Lambda]"], "*"], "(",
      SubsuperscriptBox["X", "\[Lambda]",
       RowBox[{"\[CircleTimes]",
        SubscriptBox["d", "\[Lambda]"]}]], ")"}]}], ")"}]}],
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.9627488855059834`*^9, 3.962748887091898*^9}, {
   3.96298416400049*^9, 3.9629841970599346`*^9}, {3.96298433040728*^9,
   3.9629843687252007`*^9}, 3.9629845748442993`*^9, {3.9629846225756702`*^9,
   3.962984622593195*^9}, {3.9629846636633415`*^9, 3.962984747312292*^9}, {
   3.962984801633169*^9, 3.962984819495487*^9}, {3.962984853239086*^9,
   3.962984857460287*^9}, {3.9629848882536488`*^9, 3.9629848898290577`*^9},
   3.9629868997007904`*^9, {3.9630700739716244`*^9, 3.9630700798365593`*^9}, {
   3.9630870895910034`*^9, 3.963087089687145*^9}, {3.9633342409557667`*^9,
   3.963334243550709*^9}, {3.963334343835724*^9, 3.9633343441863384`*^9}, {
   3.9641030455485973`*^9, 3.964103051401596*^9}, {3.964808770822912*^9,
   3.964808815764282*^9}, {3.965298082616085*^9, 3.965298090226063*^9}, {
   3.965298128270773*^9, 3.965298128490053*^9}, {3.9705814967054853`*^9,
   3.970581511744609*^9}, {3.970582142716488*^9, 3.970582153499732*^9}, {
   3.970582285259131*^9, 3.970582288971987*^9}, {3.970582380202836*^9,
   3.970582528602455*^9}, 3.970582618873745*^9, {3.970583288805018*^9,
   3.970583295557033*^9}, {3.9725807506110725`*^9, 3.972580767223896*^9}, {
   3.972580947646263*^9, 3.9725809476841946`*^9}, 3.972582962199732*^9, {
   3.9809573807489758`*^9, 3.9809573890582867`*^9}, {3.980957625097763*^9,
   3.9809576251459675`*^9}, {3.9811212467462025`*^9, 3.98112124797126*^9}},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"bccc0e22-3c71-7e41-ac0f-0e77725343d6"],

Cell[TextData[{
 "can be viewed as a tensor tree along with a SSYT. We say that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "\[Element]",
    RowBox[{
     SuperscriptBox["S", "D"], "(", "X", ")"}]}], TraditionalForm]],
  ExpressionUUID->"3c8077e1-5724-e24c-911b-30d0bfc50b38"],
 " corresponds to the ",
 StyleBox["isotypic data",
  FontSlant->"Italic"],
 " in the spaces ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(",
    RowBox[{
     SubscriptBox["H", "\[Nu]"], ",",
     RowBox[{
      UnderscriptBox["\[CircleTimes]", "\[Lambda]"],
      SubscriptBox["H",
       SubscriptBox["\[Mu]", "\[Lambda]"]]}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"79b56665-0177-2946-983c-c42d1125eff8"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(",
    RowBox[{
     SubscriptBox["H",
      SubscriptBox["\[Mu]", "\[Lambda]"]], ",",
     RowBox[{
      SubscriptBox["e",
       SubscriptBox["\[Pi]", "\[Lambda]"]], "(",
      SubsuperscriptBox["H", "\[Lambda]",
       RowBox[{"\[CircleTimes]",
        SubscriptBox["d", "\[Lambda]"]}]], ")"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"3faffcdf-7f8b-c74f-9d83-b11a17bf095d"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["e",
     SubscriptBox["\[Pi]", "\[Lambda]"], "*"], "(",
    SubsuperscriptBox["X", "\[Lambda]",
     RowBox[{"\[CircleTimes]",
      SubscriptBox["d", "\[Lambda]"]}]], ")"}], TraditionalForm]],
  ExpressionUUID->"06d69be1-bc3c-974d-84a4-703c9b85d996"],
 " if ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "70c2a99e-be27-4e4a-97a1-31b8afc65c43"],
 " is the image of this data under the isomorphism in Eq. (1)."
}], "Text",
 CellChangeTimes->{{3.981121251021803*^9, 3.981121271052599*^9}, {
  3.981121303167694*^9,
  3.981121309201288*^9}},ExpressionUUID->"6d15d8e2-e51e-1c46-a2b2-\
1798acdf32f1"]
}, Open  ]],

Cell[CellGroupData[{

