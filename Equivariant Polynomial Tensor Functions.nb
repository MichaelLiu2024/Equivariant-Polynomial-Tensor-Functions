Cell[CellGroupData[{

Cell["\<\
Appendix: Preliminaries (honestly, this is more like algorithm stuff)\
\>", "Section",
 CellChangeTimes->{{3.9634177078536434`*^9, 3.9634177098173466`*^9}, {
  3.963505133001383*^9, 3.963505142754999*^9}, {3.9635915459277*^9, 
