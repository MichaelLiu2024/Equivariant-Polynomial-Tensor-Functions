14af4b4f7ea4"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "7fcc747b-c909-d142-855a-5120580163fa"],
 " be a vector space with basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["v", "1"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["v", "n"]}], "}"}], TraditionalForm]],
  CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
   3.9630770753080597`*^9, 3.963077080156849*^9}, {3.963085636997587*^9, 
   3.963085679066036*^9}, {3.9630859576108856`*^9, 3.9630859805296955`*^9}, {
   3.9630881179481335`*^9, 3.963088123609167*^9}, {3.963088676126631*^9, 
   3.9630886761426716`*^9}, {3.96461500730884*^9, 3.9646150084008102`*^9}, {
   3.9646150655624046`*^9, 3.9646150728171883`*^9}, {3.966517516183874*^9, 
   3.9665175228249073`*^9}, {3.966517625230261*^9, 3.9665176468873444`*^9}},
  TextAlignment->Center,
  Background->None,ExpressionUUID->"5f522ca4-6a3b-cd4b-b2c9-adf41d4e5a0f"],
