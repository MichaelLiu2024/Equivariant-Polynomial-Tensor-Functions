  TextAlignment->Center,
  Background->None,ExpressionUUID->"d0d7b432-9bdc-c846-a97c-cedfb844bb0b"],
 " is given by the Clebsch-Gordan tensors ",
 Cell[BoxData[
  FormBox[
   RowBox[{"CG", "(",
    RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}], TraditionalForm]],
  ExpressionUUID->"f965f716-35da-5a4c-b4b6-00f05e4e8673"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", ":=",
    RowBox[{"(",
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",", "\[Ellipsis]", ",",
