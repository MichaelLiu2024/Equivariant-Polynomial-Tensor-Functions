7cd2fa6397ab"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H",
     SubscriptBox["\[Lambda]", "1"]], ",",
    SubscriptBox["H",
     SubscriptBox["\[Lambda]", "2"]]}], TraditionalForm]],
  CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
