 Background->None,ExpressionUUID->"7d3326f5-de32-ad41-a048-aa778be1c6b2"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["H",
     SubscriptBox["\[Lambda]", "1"]], "\[CircleTimes]",
    SubscriptBox["H",
     SubscriptBox["\[Lambda]", "2"]]}], "\[TildeFullEqual]",
   RowBox[{
    UnderoverscriptBox["\[CirclePlus]",
     RowBox[{
      SubscriptBox["\[Gamma]", "2"],
      RowBox[{" ",
       RowBox[{"=", " "}]}],
      RowBox[{"\[LeftBracketingBar]",
       RowBox[{
        SubscriptBox["\[Lambda]", "1"], "-",
        SubscriptBox["\[Lambda]", "2"]}], "\[RightBracketingBar]"}]}],
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], "+",
      SubscriptBox["\[Lambda]", "2"]}]],
    RowBox[{
     SubscriptBox["H",
      SubscriptBox["\[Gamma]", "2"]], "\[CircleTimes]",
     RowBox[{
      RowBox[{
       SubscriptBox["Hom", "G"], "(",
       RowBox[{
        SubscriptBox["H",
         SubscriptBox["\[Gamma]", "2"]], ",",
        RowBox[{
         SubscriptBox["H",
          SubscriptBox["\[Lambda]", "1"]], "\[CircleTimes]",
         SubscriptBox["H",
          SubscriptBox["\[Lambda]", "2"]]}]}], ")"}], "."}]}]}]}],
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
  3.9630770753080597`*^9, 3.963077080156849*^9}, {3.9630886760630875`*^9,
