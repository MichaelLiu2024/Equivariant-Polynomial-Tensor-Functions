Cell[CellGroupData[{

Cell["Old Stuff", "Section",
 CellChangeTimes->{{3.963011088560196*^9, 3.96301108969734*^9}, {
  3.9737866412935944`*^9, 3.97378664214159*^9}},
 Background->None,ExpressionUUID->"e9b67bf4-3823-ed43-8c39-ef85d2aa921e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"SpinListToSpinTree", "[", 
   RowBox[{"{", 
    RowBox[{"\[Lambda]s_List", ",", "\[Gamma]s_List"}], "}"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"If", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Depth", "[", "\[Lambda]s", "]"}], ">", "2"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"SpinListToSpinTree", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"SpinListToSpinTree", "/@", "\[Lambda]s"}], ",", "\[Gamma]s"}],
       "}"}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Fold", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Tree", "[", 
        RowBox[{
         RowBox[{"Last", "@", "#2"}], ",", 
         RowBox[{"{", 
          RowBox[{"#1", ",", 
           RowBox[{"First", "@", "#2"}]}], "}"}]}], "]"}], "&"}], ",", 
      RowBox[{"First", "[", "\[Lambda]s", "]"}], ",", 
      RowBox[{"Rest", "@", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"\[Lambda]s", ",", "\[Gamma]s"}], "}"}], "]"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}]}], "\n", 
 RowBox[{
  RowBox[{"SpinListToSpinTree", "[", "\[Gamma]s_List", "]"}], ":=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Lambda]", "=", 
      RowBox[{"First", "@", "\[Gamma]s"}]}], "}"}], ",", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "\[Gamma]s", "]"}], "==", "1"}], ",", 
      RowBox[{"Tree", "[", 
       RowBox[{"\[Lambda]", ",", 
        RowBox[{"{", "\[Lambda]", "}"}]}], "]"}], ",", 
      RowBox[{"Fold", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Tree", "[", 
          RowBox[{"#2", ",", 
           RowBox[{"{", 
            RowBox[{"#1", ",", "\[Lambda]"}], "}"}]}], "]"}], "&"}], ",", 
        "\[Gamma]s"}], "]"}]}], "]"}]}], "]"}]}]}], "Input",
