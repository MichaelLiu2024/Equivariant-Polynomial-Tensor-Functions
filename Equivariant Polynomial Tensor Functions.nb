 "-irreps. Then"
}], "Text",
 CellChangeTimes->{{3.9710148553622265`*^9,
  3.9710148633449*^9}},ExpressionUUID->"e5ecca4b-e428-9549-84a4-503629ea63e2"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["H",
      SubscriptBox["\[Lambda]", "1"]], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]",
     SubscriptBox["H",
      SubscriptBox["\[Lambda]", "d"]]}], "\[TildeFullEqual]",
    RowBox[{
     UnderoverscriptBox["\[CirclePlus]",
      RowBox[{"\[Mu]",
       RowBox[{" ",
        RowBox[{"=", " "}]}],
       RowBox[{"Max", "[",
        RowBox[{"0", ",",
         RowBox[{
          RowBox[{"2", "m"}], "-", "s"}]}], "]"}]}], "s"],
     RowBox[{
      SubscriptBox["H", "\[Mu]"], "\[CircleTimes]",
      RowBox[{
       SubscriptBox["Hom", "G"], "(",
       RowBox[{
        SubscriptBox["H", "\[Mu]"], ",",
        RowBox[{
         SubscriptBox["H",
          SubscriptBox["\[Lambda]", "1"]], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]",
         SubscriptBox["H",
          SubscriptBox["\[Lambda]", "d"]]}]}], ")"}]}]}]}], ","}],
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
  3.9630770753080597`*^9, 3.963077080156849*^9}, {3.9630886760630875`*^9,
