Cell[TextData[{
 "Next, we contract the tensor tree with the Young-symmetrized SSYT monomial \
in the input tensors to obtain an equivariant polynomial. This produces a \
basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(",
    RowBox[{
     SubscriptBox["H", "0"], ",",
     RowBox[{
      SuperscriptBox["\[ScriptCapitalS]", "3"], "(",
      RowBox[{
       SubscriptBox["H", "1"], "\[CirclePlus]",
       SubscriptBox["H", "2"]}], ")"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"978cd5ea-4baa-344f-9e96-027ca6e13232"],
 "."
}], "Text",
