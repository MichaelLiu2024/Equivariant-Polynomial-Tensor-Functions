Cell[TextData[{
 "Write ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "\[TildeFullEqual]",
    RowBox[{
     UnderscriptBox["\[CirclePlus]",
      RowBox[{"D", "\[Element]",
       TemplateBox[{},
        "NonNegativeIntegers"]}]],
     SuperscriptBox["M", "D"]}]}], TraditionalForm]],ExpressionUUID->
  "9699658d-14da-3946-82d9-c09116be4f0a"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "\[TildeFullEqual]",
    RowBox[{
     UnderscriptBox["\[CirclePlus]",
      RowBox[{"D", "\[Element]",
       TemplateBox[{},
        "NonNegativeIntegers"]}]],
     SuperscriptBox["R", "D"]}]}], TraditionalForm]],ExpressionUUID->
  "edba9bdb-c1ba-6d41-b06b-e0cb936d3801"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["M", "D"], ":=",
    SuperscriptBox[
     RowBox[{"(",
      RowBox[{
       RowBox[{
        SuperscriptBox["\[ScriptCapitalS]", "D"], "(",
        SuperscriptBox["X", "*"], ")"}], "\[CircleTimes]", "Y"}], ")"}],
     "G"]}], TraditionalForm]], "DisplayFormula",
  CellChangeTimes->{{3.971002790255043*^9, 3.9710027918797283`*^9}, {
   3.971002973488472*^9, 3.971002973663662*^9}, {3.97100307613105*^9,
   3.9710030766647224`*^9}},
  TextAlignment->Center,ExpressionUUID->
  "f570efb0-20cf-8b42-a789-27dbab7c2ccf"],
 " is the set of degree ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "a8ea3f17-a19f-c940-ab60-91c04cfc3d8b"],
 " homogeneous ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "6f23575b-79c9-174b-8954-e2388c9e14ef"],
 "-equivariant polynomials from ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],
  FontSlant->"Plain",ExpressionUUID->"c2bc0a71-76d0-9648-9267-984b414b861d"],
 " to ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],
  FontSlant->"Plain",ExpressionUUID->"641565e5-21c6-d34a-b477-f16c8f1422bd"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["R", "D"], ":=",
    SuperscriptBox[
     RowBox[{
      SuperscriptBox["\[ScriptCapitalS]", "D"], "(",
      SuperscriptBox["X", "*"], ")"}], "G"]}], TraditionalForm]],
  "DisplayFormula",
  CellChangeTimes->{{3.971002790255043*^9, 3.9710027918797283`*^9}, {
   3.971002973488472*^9, 3.971002973663662*^9}, {3.97100307613105*^9,
   3.9710030766647224`*^9}},
  TextAlignment->Center,ExpressionUUID->
  "79a4470f-dca3-8449-8c9e-d2b49e14a116"],
 " is the set of degree ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "bc472cd2-cbd2-5c4d-8dc3-41ee4ba324d1"],
 " homogeneous ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "7b1e1ebc-01bd-764d-b870-fee178467533"],
 "-invariant polynomials on ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],
  FontSlant->"Plain",ExpressionUUID->"b6b54e8f-e95e-9c4a-aa74-85c2824906fb"],
 ". Now, suppose that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Y",
    RowBox[{" ",
     RowBox[{"=", " "}]}],
    SubscriptBox["H", "\[Nu]"]}], TraditionalForm]],ExpressionUUID->
  "a4092436-93ad-5c41-943e-e0d58f3462e2"],
 ". Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["M", "D"],
    RowBox[{" ",
     RowBox[{"=", " "}]}],
    RowBox[{
     SuperscriptBox[
      RowBox[{"(",
       RowBox[{
        RowBox[{
         SuperscriptBox["\[ScriptCapitalS]", "D"], "(",
         SuperscriptBox["X", "*"], ")"}], "\[CircleTimes]",
        SubscriptBox["H", "\[Nu]"]}], ")"}], "G"], "\[TildeFullEqual]",
     RowBox[{
      SubscriptBox["Hom", "G"], "(",
      RowBox[{
       SubscriptBox["H", "\[Nu]"], ",",
       RowBox[{
        SuperscriptBox["\[ScriptCapitalS]", "D"], "(",
        SuperscriptBox["X", "*"], ")"}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"468def2d-bada-374f-b4aa-d8311fba8f16"],
 ", which is precisely the multiplicity space corresponding to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", "\[Nu]"], TraditionalForm]],ExpressionUUID->
  "e3885652-0fa8-694d-a57d-eea5431da793"],
 " in the isotypic decomposition of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalS]", "D"], "(",
     SuperscriptBox["X", "*"], ")"}], "\[TildeFullEqual]",
    RowBox[{
     UnderscriptBox["\[CirclePlus]",
      RowBox[{"\[Nu]", "\[Element]", "\[CapitalLambda]"}]],
     RowBox[{
      SubscriptBox["H", "\[Nu]"], "\[CircleTimes]",
      RowBox[{
       SubscriptBox["Hom", "G"], "(",
       RowBox[{
        SubscriptBox["H", "\[Nu]"], ",",
        RowBox[{
         SuperscriptBox["\[ScriptCapitalS]", "D"], "(",
         SuperscriptBox["X", "*"], ")"}]}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"3836ed10-f777-8942-9b8c-6de5948cb80c"],
 ". Similarly, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["R", "D"], "\[TildeFullEqual]",
    RowBox[{
     SubscriptBox["Hom", "G"], "(",
     RowBox[{
      SubscriptBox["H", "0"], ",",
      RowBox[{
       SuperscriptBox["\[ScriptCapitalS]", "D"], "(",
       SuperscriptBox["X", "*"], ")"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"4e182947-a951-bc4f-9d91-725d04b00cce"],
 " is precisely the multiplicity space corresponding to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", "0"], TraditionalForm]],ExpressionUUID->
  "590515f1-99c1-9147-a045-e321c91cc5f8"],
 " in the isotypic decomposition of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalS]", "D"], "(",
    SuperscriptBox["X", "*"], ")"}], TraditionalForm]],ExpressionUUID->
  "092ab824-2ba9-664b-8b8f-cce67d40ea75"],
 ". Therefore, our first goal is to explicitly determine the isotypic \
decomposition of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalS]", "D"], "(",
    SuperscriptBox["X", "*"], ")"}], TraditionalForm]],ExpressionUUID->
  "8d8e85ae-f1a7-a047-85a0-4114c435937e"],
 "."
}], "Text",
 CellChangeTimes->{{3.9809565273301735`*^9, 3.9809566230266743`*^9}, {
  3.9809566545420895`*^9, 3.9809566704909153`*^9}, {3.9809567069230366`*^9,
  3.980956952676771*^9}, {3.980957001170788*^9, 3.980957040466976*^9}, {
  3.9809570890526752`*^9, 3.9809571021503773`*^9}, {3.980957152487383*^9,
  3.980957174031868*^9}},ExpressionUUID->"941ba06f-2915-8c4c-8df9-\
fba165a0387e"],

Cell[CellGroupData[{

Cell[TextData[{
 "Theorem 1 (Isotypic decomposition of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalS]", "D"], "(",
    SuperscriptBox["X", "*"], ")"}], TraditionalForm]],ExpressionUUID->
  "b5c8323d-062c-7348-b10e-a1b31f6e1880"],
 ")"
}], "Subsubsection",
 CellChangeTimes->{{3.970582252027788*^9, 3.970582255578652*^9}, {
  3.97058361993813*^9, 3.970583629107135*^9}, {3.971453823587208*^9,
  3.971453823650774*^9}, {3.972144487744378*^9, 3.972144488527927*^9}, {
  3.980950111165825*^9, 3.9809501117801094`*^9}, {3.9809572579251785`*^9,
  3.980957275055357*^9}},ExpressionUUID->"1d6d6fad-1088-4af3-be79-\
2c9fa2675c22"],

Cell[TextData[{
 "Write ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["X", "\[Lambda]"], ":=",
    RowBox[{
     SubscriptBox["Hom", "G"], "(",
     RowBox[{
      SubscriptBox["H", "\[Lambda]"], ",", "X"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"0c386c23-2550-7441-b902-f29a8e06d510"],
 " for convenience. There exists a ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "97575381-6602-9642-95d9-f9d9bb064d89"],
 "-equivariant isomorphism"
}], "Text",
 CellChangeTimes->{{3.9687631403371353`*^9, 3.968763141036047*^9}, {
   3.9687633072572613`*^9, 3.9687633422499504`*^9}, {3.968771520102394*^9,
   3.9687715557493896`*^9}, {3.968775528711878*^9, 3.9687755419589176`*^9}, {
   3.968775617638569*^9, 3.9687756408876686`*^9}, 3.970582338842451*^9, {
   3.970582575087944*^9, 3.97058257533815*^9}, {3.970582987063113*^9,
   3.970583008070634*^9}, {3.971366989812829*^9, 3.971366991188349*^9}, {
   3.972144744190754*^9, 3.972144771934545*^9}, {3.9725670768366985`*^9,
   3.972567078311039*^9}, {3.972580770156933*^9, 3.9725807727511272`*^9}, {
   3.9725829578427753`*^9, 3.9725829589801693`*^9}, {3.9809575802264824`*^9,
   3.9809575852241344`*^9}},ExpressionUUID->"8a778b3f-9235-464d-99ee-\
4e8342a41fd3"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalS]", "D"], "(",
     SuperscriptBox["X", "*"], ")"}], "\[TildeFullEqual]",
    RowBox[{
     UnderscriptBox["\[CirclePlus]",
      RowBox[{"\[Nu]", "\[Element]", "\[CapitalLambda]"}]],
     RowBox[{
      SubscriptBox["H", "\[Nu]"], "\[CircleTimes]",
      RowBox[{"(",
       RowBox[{
        UnderscriptBox["\[CirclePlus]",
         SubscriptBox[
          RowBox[{"(",
           SubscriptBox["d", "\[Lambda]"], ")"}], "\[Lambda]"]],
        RowBox[{
         UnderscriptBox["\[CirclePlus]",
          SubscriptBox[
           RowBox[{"(",
            SubscriptBox["\[Pi]", "\[Lambda]"], ")"}], "\[Lambda]"]],
         RowBox[{
          UnderscriptBox["\[CirclePlus]",
           SubscriptBox[
            RowBox[{"(",
             SubscriptBox["\[Mu]", "\[Lambda]"], ")"}], "\[Lambda]"]],
          RowBox[{
           RowBox[{
            SubscriptBox["Hom", "G"], "(",
            RowBox[{
             SubscriptBox["H", "\[Nu]"], ",",
             RowBox[{
              UnderscriptBox["\[CircleTimes]", "\[Lambda]"],
              SubscriptBox["H",
               SubscriptBox["\[Mu]", "\[Lambda]"]]}]}], ")"}], "\[CircleTimes]",
           RowBox[{"(",
            RowBox[{
             UnderscriptBox["\[CircleTimes]", "\[Lambda]"],
             RowBox[{
              SubscriptBox["Hom", "G"], "(",
              RowBox[{
               SubscriptBox["H",
                SubscriptBox["\[Mu]", "\[Lambda]"]], ",",
               RowBox[{
                SubscriptBox["e",
                 SubscriptBox["\[Pi]", "\[Lambda]"]], "(",
                SubsuperscriptBox["H", "\[Lambda]",
                 RowBox[{"\[CircleTimes]",
                  SubscriptBox["d", "\[Lambda]"]}]], ")"}]}], ")"}]}], ")"}],
           "\[CircleTimes]",
           RowBox[{"(",
            RowBox[{
             UnderscriptBox["\[CircleTimes]", "\[Lambda]"],
             RowBox[{
              SubsuperscriptBox["e",
               SubscriptBox["\[Pi]", "\[Lambda]"], "*"], "(",
              SubsuperscriptBox["X", "\[Lambda]",
               RowBox[{"\[CircleTimes]",
                SubscriptBox["d", "\[Lambda]"]}]], ")"}]}], ")"}]}]}]}]}],
       ")"}]}]}]}], ","}], TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9627488855059834`*^9, 3.962748887091898*^9}, {
   3.96298416400049*^9, 3.9629841970599346`*^9}, {3.96298433040728*^9,
   3.9629843687252007`*^9}, 3.9629845748442993`*^9, {3.9629846225756702`*^9,
   3.962984622593195*^9}, {3.9629846636633415`*^9, 3.962984747312292*^9}, {
   3.962984801633169*^9, 3.962984819495487*^9}, {3.962984853239086*^9,
   3.962984857460287*^9}, {3.9629848882536488`*^9, 3.9629848898290577`*^9},
   3.9629868997007904`*^9, {3.9630700739716244`*^9, 3.9630700798365593`*^9}, {
   3.9630870895910034`*^9, 3.963087089687145*^9}, {3.9633342409557667`*^9,
   3.963334243550709*^9}, {3.963334343835724*^9, 3.9633343441863384`*^9}, {
   3.9641030455485973`*^9, 3.964103051401596*^9}, {3.964808770822912*^9,
   3.964808815764282*^9}, {3.965298082616085*^9, 3.965298090226063*^9}, {
   3.965298128270773*^9, 3.965298128490053*^9}, {3.9705814967054853`*^9,
   3.970581511744609*^9}, {3.970582142716488*^9, 3.970582153499732*^9}, {
   3.970582285259131*^9, 3.970582288971987*^9}, {3.970582380202836*^9,
   3.970582528602455*^9}, 3.970582618873745*^9, {3.970583288805018*^9,
   3.970583295557033*^9}, {3.9725807506110725`*^9, 3.972580767223896*^9}, {
   3.972580947646263*^9, 3.9725809476841946`*^9}, 3.972582962199732*^9, {
   3.9809573807489758`*^9, 3.9809573890582867`*^9}, {3.980957625097763*^9,
   3.9809576251459675`*^9}},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"30f76cf0-f42d-4e06-b038-a1cc507a0380"],

Cell["where", "Text",
 CellChangeTimes->{{3.972142713291314*^9, 3.9721427582024508`*^9}, {
  3.972142970426324*^9, 3.9721429706656923`*^9}, {3.972566264098608*^9,
  3.972566277438122*^9}, {3.9809576636413994`*^9, 3.9809576783783226`*^9}, {
  3.980957739542631*^9,
  3.980957803283743*^9}},ExpressionUUID->"35453032-3cc3-4446-b668-\
6498813d58dc"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "9ac746c9-1d1b-8942-a42b-6ed1518f3b6a"],
 " ranges over all nonnegative integers such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["X", "\[Lambda]"], "!=", "0"}], TraditionalForm]],
  ExpressionUUID->"e0ae8bf7-eb8c-444b-94dd-7201ebe0ee55"],
 ","
}], "Item",
 CellChangeTimes->{{3.972142713291314*^9, 3.9721427582024508`*^9}, {
  3.972142970426324*^9, 3.9721429706656923`*^9}, {3.972566264098608*^9,
  3.972566277438122*^9}, {3.9809576636413994`*^9, 3.9809576783783226`*^9}, {
  3.980957739542631*^9, 3.980957806576252*^9}, {3.9809578639016438`*^9,
  3.980957867470934*^9}},ExpressionUUID->"11fc72cf-631b-6c4a-85f5-\
90c67b62f803"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(",
     SubscriptBox["d", "\[Lambda]"], ")"}], "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"79d0a3e7-8611-c247-a40b-9ff9f4b54909"],
 " ranges over all sequences of nonnegative integers such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderscriptBox["\[Sum]", "\[Lambda]"],
     SubscriptBox["d", "\[Lambda]"]}],
    RowBox[{" ",
     RowBox[{"=", " "}]}], "D"}], TraditionalForm]],ExpressionUUID->
  "9b343e3d-9dd6-7045-a65c-10d6ed6e7053"],
 ","
}], "Item",
 CellChangeTimes->{{3.972142713291314*^9, 3.9721427582024508`*^9}, {
  3.972142970426324*^9, 3.9721429706656923`*^9}, {3.972566264098608*^9,
  3.972566277438122*^9}, {3.9809576636413994`*^9, 3.9809576783783226`*^9}, {
  3.980957739542631*^9,
  3.980957810627592*^9}},ExpressionUUID->"b667b1f7-0e0a-b649-afaa-\
83843fb62541"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(",
     SubscriptBox["\[Pi]", "\[Lambda]"], ")"}], "\[Lambda]"],
   TraditionalForm]],ExpressionUUID->"05ffa153-5728-8e4f-88f0-849a58eaf9c5"],
 " ranges over all sequences of integer partitions ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Pi]", "\[Lambda]"], "\[RightTee]",
    SubscriptBox["d", "\[Lambda]"]}], TraditionalForm]],ExpressionUUID->
  "66db4b02-4aa1-5d4a-877b-34dd0efefcba"],
 " such that each partition has largest part at most ",
 Cell[BoxData[
  FormBox[
   RowBox[{"min", "(",
    RowBox[{
     RowBox[{"dim", " ",
      SubscriptBox["H", "\[Lambda]"]}], ",",
     RowBox[{"dim", " ",
      SubscriptBox["X", "\[Lambda]"]}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"59061f9a-141d-5b44-b0e7-a7d6786784ac"],
 ", and"
}], "Item",
 CellChangeTimes->{{3.972142713291314*^9, 3.9721427582024508`*^9}, {
  3.972142970426324*^9, 3.9721429706656923`*^9}, {3.972566264098608*^9,
  3.972566277438122*^9}, {3.9809576636413994`*^9, 3.9809576783783226`*^9}, {
  3.980957739542631*^9,
  3.9809578453757343`*^9}},ExpressionUUID->"a87a8861-ee84-7b47-842c-\
221acd88bf08"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(",
     SubscriptBox["\[Mu]", "\[Lambda]"], ")"}], "\[Lambda]"],
   TraditionalForm]],ExpressionUUID->"18561475-194f-9045-aecc-f96b2f1e7ddd"],
 " ranges over all sequences of nonnegative integers such that all ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(",
    RowBox[{
     SubscriptBox["H",
      SubscriptBox["\[Mu]", "\[Lambda]"]], ",",
     RowBox[{
      SubscriptBox["e",
       SubscriptBox["\[Pi]", "\[Lambda]"]], "(",
      SubsuperscriptBox["H", "\[Lambda]",
       RowBox[{"\[CircleTimes]",
        SubscriptBox["d", "\[Lambda]"]}]], ")"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"ff446b83-e76f-e14d-9393-a7feddc12ae1"],
 " are nonzero and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(",
    RowBox[{
     SubscriptBox["H", "\[Nu]"], ",",
     RowBox[{
      UnderscriptBox["\[CircleTimes]", "\[Lambda]"],
      SubscriptBox["H",
       SubscriptBox["\[Mu]", "\[Lambda]"]]}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"6f35eb5a-aee5-254f-9927-495a6aa53622"],
 " is nonzero."
}], "Item",
 CellChangeTimes->{{3.972142713291314*^9, 3.9721427582024508`*^9}, {
  3.972142970426324*^9, 3.9721429706656923`*^9}, {3.972566264098608*^9,
  3.972566277438122*^9}, {3.9809576636413994`*^9, 3.9809576783783226`*^9}, {
  3.980957739542631*^9, 3.980957815083647*^9}, {3.9809578991409626`*^9,
  3.9809579299436283`*^9}},ExpressionUUID->"7e3bdf94-416d-d94e-a14d-\
b8d0db8b66f2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Proof", "Subsubsection",
 CellChangeTimes->{{3.980958203962511*^9,
  3.980958204444048*^9}},ExpressionUUID->"015084b6-ce31-a044-bd91-\
284aa2dc8c6a"],

Cell["See Appendix A.", "Text",
 CellChangeTimes->{{3.9809582064489975`*^9,
  3.980958222272806*^9}},ExpressionUUID->"81b30c67-a076-454a-837c-\
6e2fac1d4c6e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Remark", "Subsubsection",
 CellChangeTimes->{{3.981120166301546*^9,
  3.9811201668881893`*^9}},ExpressionUUID->"a135db5b-64cb-534e-ac67-\
17f9eb047a45"],

Cell[TextData[{
 "In Eq. (1), the nested direct sums over ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(",
     SubscriptBox["d", "\[Lambda]"], ")"}], "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"59e6861b-c1bb-fd4e-a338-3ba07cd9b6f6"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(",
     SubscriptBox["\[Pi]", "\[Lambda]"], ")"}], "\[Lambda]"],
   TraditionalForm]],ExpressionUUID->"5272c334-44bc-0d4a-9fe4-478e3a6585fc"],
 ", and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(",
     SubscriptBox["\[Mu]", "\[Lambda]"], ")"}], "\[Lambda]"],
   TraditionalForm]],ExpressionUUID->"56100a1f-7b73-9243-9f0f-064fbd30b5cc"],
 " are naturally represented with a tree structure. At each leaf of this tree \
structure, the spaces ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(",
    RowBox[{
     SubscriptBox["H", "\[Nu]"], ",",
     RowBox[{
      UnderscriptBox["\[CircleTimes]", "\[Lambda]"],
      SubscriptBox["H",
       SubscriptBox["\[Mu]", "\[Lambda]"]]}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"7f2214f6-7748-3b48-91bb-cc6ffe79bcf0"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(",
    RowBox[{
     SubscriptBox["H",
      SubscriptBox["\[Mu]", "\[Lambda]"]], ",",
     RowBox[{
      SubscriptBox["e",
       SubscriptBox["\[Pi]", "\[Lambda]"]], "(",
      SubsuperscriptBox["H", "\[Lambda]",
       RowBox[{"\[CircleTimes]",
        SubscriptBox["d", "\[Lambda]"]}]], ")"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"2701e7c0-7de6-6d44-8398-3873060d5d45"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["e",
     SubscriptBox["\[Pi]", "\[Lambda]"], "*"], "(",
    SubsuperscriptBox["X", "\[Lambda]",
     RowBox[{"\[CircleTimes]",
      SubscriptBox["d", "\[Lambda]"]}]], ")"}], TraditionalForm]],
  ExpressionUUID->"22603fe0-ec20-bb49-b1ca-0ab4e996af87"],
 " are most efficiently represented with corresponding vector space bases. \
Thus, for any given ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "ad78da41-a390-b44d-830f-74810acbe611"],
 " and ",
 Cell[BoxData[
  FormBox["\[Nu]", TraditionalForm]],ExpressionUUID->
  "c98f72a2-c328-6c49-bbba-9b75a9a21b90"],
 ", we obtain a representation of the multiplicity space ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(",
    RowBox[{
     SubscriptBox["H", "\[Nu]"], ",",
     RowBox[{
      SuperscriptBox["\[ScriptCapitalS]", "D"], "(",
      SuperscriptBox["X", "*"], ")"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"41e23249-a7e7-0844-827a-23390a286114"],
 " as an ",
 StyleBox["isotypic data tree",
  FontSlant->"Italic"],
 " (see Example 1)."
}], "Text",
 CellChangeTimes->{{3.973426763249817*^9, 3.9734268646720257`*^9}, {
  3.97342691454208*^9, 3.973426915037445*^9}, {3.9734269504216614`*^9,
  3.9734269514417133`*^9}, {3.9737740898468895`*^9, 3.9737741174629593`*^9}, {
  3.9779326809545784`*^9, 3.9779326994497986`*^9}, {3.977933641300558*^9,
  3.977933642176277*^9}, {3.981117540463032*^9, 3.981117540924198*^9}, {
  3.9811179621624126`*^9, 3.9811180213127823`*^9}, {3.9811181058395824`*^9,
  3.981118184591013*^9}, {3.98112019451223*^9,
  3.981120398329317*^9}},ExpressionUUID->"1214b89e-b6ae-384a-a4ae-\
aafd264c1f9d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Remark", "Subsubsection",
 CellChangeTimes->{{3.9705838117126427`*^9,
  3.970583812784687*^9}},ExpressionUUID->"f067336a-a0f5-479b-ba1f-\
9df992cdad47"],

Cell[TextData[{
 "By enumerating a basis for the right-hand-side of Eq. (1) and passing this \
basis through the isomorphism in Eq. (1), we obtain a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalS]", "D"], "(",
    SuperscriptBox["X", "*"], ")"}], TraditionalForm]],ExpressionUUID->
  "0ac07496-6050-7d4c-aaad-d531e8c16cf0"],
 " that corresponds to the isotypic decomposition of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalS]", "D"], "(",
    SuperscriptBox["X", "*"], ")"}], TraditionalForm]],ExpressionUUID->
  "4f8296a6-e7d2-1e46-a379-d016c4c97c8e"],
 ". In particular, we may use the angular momentum basis for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", "\[Nu]"], TraditionalForm]],ExpressionUUID->
  "656bd3e2-40a5-7945-b85e-9fbaf99bca12"],
 ", the Clebsch-Gordan tensor basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(",
    RowBox[{
     SubscriptBox["H", "\[Nu]"], ",",
     RowBox[{
      UnderscriptBox["\[CircleTimes]", "\[Lambda]"],
      SubscriptBox["H",
       SubscriptBox["\[Mu]", "\[Lambda]"]]}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"48ebd75d-4e8e-664f-8c84-f3e1679de20d"],
 ", and the SSYT basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["e",
     SubscriptBox["\[Pi]", "\[Lambda]"], "*"], "(",
    SubsuperscriptBox["X", "\[Lambda]",
     RowBox[{"\[CircleTimes]",
      SubscriptBox["d", "\[Lambda]"]}]], ")"}], TraditionalForm]],
  ExpressionUUID->"d9e2a4e6-8b21-4d40-a776-2f2124c0da94"],
 ". The only space for which a basis is not currently on hand is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(",
    RowBox[{
     SubscriptBox["H",
      SubscriptBox["\[Mu]", "\[Lambda]"]], ",",
     RowBox[{
      SubscriptBox["e",
       SubscriptBox["\[Pi]", "\[Lambda]"]], "(",
      SubsuperscriptBox["H", "\[Lambda]",
       RowBox[{"\[CircleTimes]",
        SubscriptBox["d", "\[Lambda]"]}]], ")"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"1a9af711-af4a-074a-ad12-9acfdbcf6312"],
 ". Thus, we describe how to obtain such a basis using Clebsch-Gordan tensor \
trees."
}], "Text",
 CellChangeTimes->{{3.970583815682938*^9, 3.9705838612647676`*^9}, {
  3.970584857418535*^9, 3.970584861705845*^9}, {3.9714471567690067`*^9,
  3.971447180336097*^9}, {3.9725810751926937`*^9, 3.972581079897976*^9}, {
  3.972582304872219*^9, 3.972582504646406*^9}, {3.9725832525232277`*^9,
  3.9725832527156353`*^9}, {3.9779337515816765`*^9, 3.9779337530433655`*^9}, {
  3.9779337888224964`*^9, 3.9779337906608715`*^9}, {3.981121065489311*^9,
  3.981121070707432*^9}},ExpressionUUID->"8c026307-e5d8-41f2-b1e6-\
d42ab552dfc6"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Theorem 2 (Isotypic decomposition of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["e",
     SubscriptBox["\[Pi]", "\[Lambda]"]], "(",
    SubsuperscriptBox["H", "\[Lambda]",
     RowBox[{"\[CircleTimes]",
      SubscriptBox["d", "\[Lambda]"]}]], ")"}], TraditionalForm]],
  ExpressionUUID->"ee5e034a-cb8b-6b4e-92b9-9de382a5a638"],
 ")"
}], "Subsubsection",
 CellChangeTimes->{{3.966948451437723*^9, 3.966948451866291*^9}, {
  3.968763557291807*^9, 3.9687635588714867`*^9}, {3.9687760342360115`*^9,
  3.9687760346684856`*^9}, {3.9705816415519543`*^9, 3.970581646767091*^9}, {
  3.970583615954358*^9, 3.97058363895245*^9}, {3.971453821651183*^9,
  3.971453821730332*^9}, {3.972396204538671*^9, 3.972396205098158*^9}, {
  3.980958355367399*^9,
  3.9809583560104465`*^9}},ExpressionUUID->"75df8d59-8bfe-c249-a632-\
6c260d7ad668"],

Cell[TextData[{
 "There exists a ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "cb4ec192-1b65-8045-83e7-56d4ca22ef9a"],
 "-equivariant isomorphism"
}], "Text",
 CellChangeTimes->{{3.9687719708377895`*^9, 3.9687721113279285`*^9}, {
   3.9687723383125153`*^9, 3.9687723383125153`*^9}, {3.968772480697939*^9,
   3.968772480697939*^9}, {3.96877255162718*^9, 3.9687725752072067`*^9}, {
   3.9687726221742783`*^9, 3.9687726576964436`*^9}, {3.968772899540037*^9,
   3.9687729629978504`*^9}, {3.970580783398847*^9, 3.9705808274462223`*^9}, {
   3.970583687843177*^9, 3.970583759697344*^9}, {3.970583960337091*^9,
   3.970583960497192*^9}, {3.970586361666175*^9, 3.9705863632796907`*^9}, {
   3.970586428335926*^9, 3.970586428543675*^9},
   3.9809583864791374`*^9},ExpressionUUID->"4c11a447-3552-d640-9ddd-\
88811259a820"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["e",
      SubscriptBox["\[Pi]", "\[Lambda]"]], "(",
     SubsuperscriptBox["H", "\[Lambda]",
      RowBox[{"\[CircleTimes]",
       SubscriptBox["d", "\[Lambda]"]}]], ")"}], "\[TildeFullEqual]",
    RowBox[{
     UnderscriptBox["\[CirclePlus]",
      SubscriptBox["\[Mu]", "\[Lambda]"]],
     RowBox[{
      SubscriptBox["H",
       SubscriptBox["\[Mu]", "\[Lambda]"]], "\[CircleTimes]",
      RowBox[{
       SubscriptBox["r",
        SubscriptBox["\[Pi]", "\[Lambda]"]], "(",
       RowBox[{
        UnderscriptBox["\[CirclePlus]",
         SubscriptBox[
          RowBox[{"(",
           SubscriptBox["\[Xi]",
            RowBox[{"\[Lambda]", ",", "p"}]], ")"}], "p"]],
        RowBox[{
         RowBox[{
          SubscriptBox["Hom", "G"], "(",
          RowBox[{
           SubscriptBox["H",
            SubscriptBox["\[Mu]", "\[Lambda]"]], ",",
           RowBox[{
            UnderscriptBox["\[CircleTimes]", "p"],
            SubscriptBox["H",
             SubscriptBox["\[Xi]",
              RowBox[{"\[Lambda]", ",", "p"}]]]}]}], ")"}], "\[CircleTimes]",

         RowBox[{"(",
          RowBox[{
           UnderscriptBox["\[CircleTimes]", "p"],
           RowBox[{
            SubscriptBox["Hom", "G"], "(",
            RowBox[{
             SubscriptBox["H",
              SubscriptBox["\[Xi]",
               RowBox[{"\[Lambda]", ",", "p"}]]], ",",
             RowBox[{
              SuperscriptBox["\[CapitalLambda]",
               SubscriptBox["\[Pi]",
                RowBox[{"\[Lambda]", ",", "p"}]]], "(",
              SubscriptBox["H", "\[Lambda]"], ")"}]}], ")"}]}], ")"}]}]}],
       ")"}]}]}]}], ","}], TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
   3.9630770753080597`*^9, 3.963077080156849*^9}, {3.9630886760630875`*^9,
   3.9630886760630875`*^9}, {3.963334237475191*^9, 3.963334237475191*^9}, {
   3.96333432456596*^9, 3.9633343428223953`*^9}, {3.9635025685698624`*^9,
   3.963502589460739*^9}, {3.96350804325531*^9, 3.963508066843014*^9}, {
   3.9635856628128147`*^9, 3.9635856875826283`*^9}, {3.96359268755571*^9,
   3.963592748233423*^9}, {3.963592795011265*^9, 3.9635928030139923`*^9}, {
   3.963593056689377*^9, 3.9635930578759136`*^9}, {3.9635932770170174`*^9,
   3.963593277051424*^9}, {3.9635936894406586`*^9, 3.9635936974830017`*^9}, {
   3.9648975582188873`*^9, 3.9648975682597904`*^9}, 3.9648986495221863`*^9, {
   3.9652995533961296`*^9, 3.9652995533981304`*^9}, {3.9653119351830235`*^9,
   3.9653119612019844`*^9}, {3.9653176267553787`*^9,
   3.9653176351672745`*^9}, {3.965728608278126*^9, 3.9657286284949436`*^9}, {
   3.9657287345731373`*^9, 3.9657287346191807`*^9}, {3.9657287828218117`*^9,
   3.9657287931636906`*^9}, 3.9657351203601513`*^9, 3.9659138430092754`*^9, {
   3.9662518438622665`*^9, 3.9662518439037533`*^9}, {3.966515464534727*^9,
   3.966515465406498*^9}, {3.9678920591504574`*^9, 3.967892068345545*^9},
   3.9678921594442635`*^9, 3.967892230337963*^9, {3.967892289588253*^9,
   3.967892294668869*^9}, {3.96789250927363*^9, 3.967892509387804*^9}, {
   3.968579584055561*^9, 3.9685798070734787`*^9}, {3.968583094982847*^9,
   3.9685831300143547`*^9}, {3.96876002163431*^9, 3.968760033971571*^9}, {
   3.9687601592023106`*^9, 3.9687601637347145`*^9}, 3.9687603104263496`*^9, {
   3.9687607501264553`*^9, 3.9687607516526546`*^9}, {3.9687608759269695`*^9,
   3.9687608843906136`*^9}, {3.9687609171405907`*^9,
   3.9687609185109787`*^9}, {3.96876125264065*^9, 3.9687613057543926`*^9}, {
   3.9687613403955593`*^9, 3.968761340554638*^9}, {3.968761433924778*^9,
   3.968761438662983*^9}, {3.968761567937725*^9, 3.968761624562151*^9}, {
   3.9687721251896706`*^9, 3.968772147783268*^9}, 3.9687733505275764`*^9,
   3.9687769355446835`*^9, 3.970580806677631*^9, {3.970580842500491*^9,
   3.970580849285054*^9}, {3.970583897247493*^9, 3.970583937823556*^9}, {
   3.970584026287092*^9, 3.970584029872053*^9}, {3.970584524284992*^9,
   3.970584554287389*^9}, {3.972582981008316*^9, 3.972582993444866*^9}, {
   3.977933929365492*^9, 3.977933929932579*^9}, {3.9809584026025963`*^9,
   3.98095840266082*^9}},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"bd594830-cf18-3846-ad0b-3cde839ec5c4"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(",
     SubscriptBox["\[Xi]",
      RowBox[{"\[Lambda]", ",", "p"}]], ")"}], "p"], TraditionalForm]],
  ExpressionUUID->"277a7752-03cf-8746-984d-ab0b8f9ce07b"],
 " ranges over all sequences of nonnegative integers such that all ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(",
    RowBox[{
     SubscriptBox["H",
      SubscriptBox["\[Xi]",
       RowBox[{"\[Lambda]", ",", "p"}]]], ",",
     RowBox[{
      SuperscriptBox["\[CapitalLambda]",
       SubscriptBox["\[Pi]",
        RowBox[{"\[Lambda]", ",", "p"}]]], "(",
      SubscriptBox["H", "\[Lambda]"], ")"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"d8fa7d95-da56-ed41-b317-f59773ec600c"],
 " are nonzero and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(",
    RowBox[{
     SubscriptBox["H",
      SubscriptBox["\[Mu]", "\[Lambda]"]], ",",
     RowBox[{
      UnderscriptBox["\[CircleTimes]", "p"],
      SubscriptBox["H",
       SubscriptBox["\[Xi]",
        RowBox[{"\[Lambda]", ",", "p"}]]]}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"4ded2819-222a-5d40-b44f-46d66ba20247"],
 " is nonzero."
}], "Text",
 CellChangeTimes->{{3.9687631855287876`*^9, 3.968763270908972*^9}, {
  3.9687633458637905`*^9, 3.9687633677268257`*^9}, {3.9687715664778214`*^9,
  3.9687716115770874`*^9}, {3.970582632297068*^9, 3.970582639145082*^9}, {
  3.970582676729411*^9, 3.9705826772563953`*^9}, {3.970582708441777*^9,
  3.970582768841083*^9}, {3.970582801480036*^9, 3.9705828512387543`*^9}, {
  3.9705828979751368`*^9, 3.9705829011590223`*^9}, {3.970582950135762*^9,
  3.97058295186294*^9}, {3.97058303632644*^9, 3.970583036470171*^9}, {
  3.970583994383857*^9, 3.970584034593185*^9}, {3.9725826459588966`*^9,
  3.972582652592495*^9}, {3.977934011064535*^9, 3.977934029525221*^9}, {
  3.97800330164291*^9, 3.97800330919985*^9}, {3.978003368142498*^9,
  3.978003368725395*^9}, {3.9809584152255898`*^9,
  3.980958443082485*^9}},ExpressionUUID->"235e56b5-7032-4700-becd-\
6658959274d1"]
}, Open  ]],

