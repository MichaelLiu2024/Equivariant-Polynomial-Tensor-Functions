6266c4055e1e"],

Cell["We check the isotypic multiplicities by brute force.", "Text",
 CellChangeTimes->{{3.971453749107276*^9, 
  3.971453769571246*^9}},ExpressionUUID->"6ff9252d-c009-42db-9f40-\
23346d1c4d9f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"IsotypicMultiplicityExteriorPower", "[", 
      RowBox[{"\[Lambda]", ",", "d", ",", "\[Mu]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Lambda]", ",", "0", ",", "3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"d", ",", "1", ",", 
       RowBox[{
        RowBox[{"2", "\[Lambda]"}], "+", "1"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Mu]", ",", "0", ",", 
       RowBox[{"Sum", "[", 
        RowBox[{"i", ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"\[Lambda]", "-", "d", "+", "1"}], ",", "\[Lambda]"}], 
          "}"}]}], "]"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Grid", "[", 
  RowBox[{"data", ",", 
   RowBox[{"ItemSize", "->", "Full"}]}], "]"}]}], "Input",
