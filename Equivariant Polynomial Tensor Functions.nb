Cell[CellGroupData[{

Cell["Lemma", "Subsubsection",
 CellChangeTimes->{{3.97800345598641*^9, 
  3.978003456404854*^9}},ExpressionUUID->"f3399fad-995a-4d4e-99ce-\
731a8ccbfb07"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"wt", "(", 
    SubscriptBox["\[Mu]", "\[Lambda]"], ")"}], TraditionalForm]],
  ExpressionUUID->"1f502df2-1c34-3e45-9c36-3f07fa9c6437"],
 " be the number of SSYT filled from ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "\[Lambda]"}], ",", "...", ",", "\[Lambda]"}], "}"}], 
   TraditionalForm]],ExpressionUUID->"d08f4421-fe1d-c44b-a7f9-f8f3f2ece633"],
 " with total of the boxes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Mu]", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "fcc42cb4-194c-6048-b9df-457da35395d0"],
 ". The multiplicity of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", 
    SubscriptBox["\[Mu]", "\[Lambda]"]], TraditionalForm]],ExpressionUUID->
  "e8681a37-c3bb-3249-92f4-cdb8966d7e9d"],
 " in the isotypic decomposition of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["e", 
     SubscriptBox["\[Pi]", "\[Lambda]"]], "(", 
    SubsuperscriptBox["H", "\[Lambda]", 
     RowBox[{"\[CircleTimes]", 
      SubscriptBox["d", "\[Lambda]"]}]], ")"}], TraditionalForm]],
  ExpressionUUID->"fb39af00-1226-6747-8ec1-750050e4876d"],
 " is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"wt", "(", 
     SubscriptBox["\[Mu]", "\[Lambda]"], ")"}], "-", 
    RowBox[{"wt", "(", 
     RowBox[{
      SubscriptBox["\[Mu]", "\[Lambda]"], "+", "1"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"e6cef2a9-94fb-7d42-bfa1-5cba5a836c47"],
 ". In particular, if ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["s", "\[Pi]"], TraditionalForm]],ExpressionUUID->
  "a712d6cb-bdab-c941-b9d6-d2271e4a6611"],
 " the Schur polynomial corresponding to ",
 Cell[BoxData[
  FormBox["\[Pi]", TraditionalForm]],ExpressionUUID->
  "c8334b81-ad15-ec40-949d-59256ab548c0"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"wt", "(", 
    SubscriptBox["\[Mu]", "\[Lambda]"], ")"}], TraditionalForm]],
  ExpressionUUID->"ba2dbb99-0231-504f-926f-eb62d26e2ea6"],
 " is the coefficient of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["x", 
    SubscriptBox["\[Mu]", "\[Lambda]"]], TraditionalForm]],ExpressionUUID->
  "1188b193-4b7e-c645-84bf-55128e9a34fa"],
 " in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["s", "\[Pi]"], "(", 
    RowBox[{
     SuperscriptBox["x", 
      RowBox[{"-", "\[Lambda]"}]], ",", 
     SuperscriptBox["x", 
      RowBox[{
       RowBox[{"-", "\[Lambda]"}], "+", "1"}]], ",", "...", ",", 
     SuperscriptBox["x", "\[Lambda]"]}], ")"}], TraditionalForm]],
  ExpressionUUID->"16b31316-7f7f-b240-9f15-2fd2a8578e60"],
 "."
}], "Text",
 CellChangeTimes->{{3.978003471050785*^9, 3.9780035723380985`*^9}, {
  3.9780038865621376`*^9, 3.9780040461870995`*^9}, {3.97800416331328*^9, 
  3.9780041658160667`*^9}},ExpressionUUID->"60cdff0e-60bf-6347-9577-\
fcf1d786afef"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Lemma (Polarization identity for symmetric tensors) \
https://math.stackexchange.com/questions/481167/polarization-formula\
\>", "Subsubsection",
 CellChangeTimes->{{3.972476004801016*^9, 3.972476015808689*^9}, {
  3.972745842979257*^9, 
  3.9727458431132383`*^9}},ExpressionUUID->"0550eb99-4698-493a-920c-\
19d38ce253da"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[CapitalPhi]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6aa3e54b-1993-2a46-bbfc-3b084e995c48"],
 " be a tensor. Then"
}], "Text",
 CellChangeTimes->{{3.9811245473560276`*^9, 
  3.981124555432873*^9}},ExpressionUUID->"b6eb071a-8b0e-304a-8358-\
484951255a4f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    TemplateBox[{
      RowBox[{"Sym", " ", "\[CapitalPhi]"}], 
      RowBox[{
        SubscriptBox["v", "1"], "\[CircleTimes]", "\[Ellipsis]", 
        "\[CircleTimes]", 
        SubscriptBox["v", "d"]}]},
     "BraKet"], "=", 
    RowBox[{
     FractionBox[
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "d"], 
      RowBox[{"d", "!"}]], 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       RowBox[{"A", "\[SubsetEqual]", 
        RowBox[{"{", 
         RowBox[{"1", ",", "\[Ellipsis]", ",", "d"}], "}"}]}]], 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], 
        RowBox[{"\[LeftBracketingBar]", "A", "\[RightBracketingBar]"}]], 
       RowBox[{"\[Phi]", "(", 
        RowBox[{
         UnderscriptBox["\[Sum]", 
          RowBox[{"a", "\[Element]", "A"}]], 
         SubscriptBox["v", "a"]}], ")"}]}]}]}]}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Phi]", "(", "v", ")"}], ":=", 
    RowBox[{
     TemplateBox[{"\[CapitalPhi]", 
       SuperscriptBox["v", 
        RowBox[{"\[CircleTimes]", "d"}]]},
      "BraKet"], "."}]}]}], TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.972476057685408*^9, 3.972476310591394*^9}, 
   3.972476352207329*^9, {3.981124557849783*^9, 3.9811245918603115`*^9}},
 TextAlignment->Center,ExpressionUUID->"32f05232-3f6e-4c3d-8ff3-54ee05188ee7"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Appendix: Future Directions", "Section",
 CellChangeTimes->{{3.980269429065275*^9, 3.980269429805193*^9}, {
  3.9802702631523952`*^9, 3.980270266290945*^9}, {3.980956103238777*^9, 
  3.980956107174963*^9}},ExpressionUUID->"29bcd7e3-334a-d044-bd21-\
8ab28e7df357"],

Cell[TextData[{
 "Do the sequences ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"{", 
     RowBox[{"dim", " ", 
      SubscriptBox["R", "D"]}], "}"}], "D"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ef4726c8-9341-eb4e-83cf-11474e077ec9"],
 " or ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"{", 
     RowBox[{"dim", " ", 
      SubscriptBox["M", "D"]}], "}"}], "D"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "82a77cfa-e0c8-f641-9bfe-a552554b4731"],
 " appear in OEIS? What kinds of connections can be made?"
}], "Item",
 CellChangeTimes->{{3.9811240575718365`*^9, 
  3.9811241849718304`*^9}},ExpressionUUID->"7b297484-cd04-1342-8994-\
30eeacc51a36"],

Cell["\<\
Would the algorithm work better using the polarization identity in place of \
the CP decomposition for partially symmetrized monomials?\
\>", "Item",
 CellChangeTimes->{{3.9811240575718365`*^9, 3.981124223337841*^9}, {
  3.981124291610964*^9, 
  3.98112429162866*^9}},ExpressionUUID->"0946093f-92cb-474c-a7bc-\
585df242ab4e"],

Cell["\<\
What precisely is the importance of the SSYT? Can some algebra or module \
redundancy be detected purely by looking at the spin trees?\
\>", "Item",
 CellChangeTimes->{{3.9811240575718365`*^9, 3.981124223337841*^9}, 
   3.9811242919204082`*^9, {3.981124333095875*^9, 
   3.981124463607847*^9}},ExpressionUUID->"51bb0757-f8c9-cf46-a45c-\
bd659b5b1781"],

Cell["\<\
In particular, any spin tree with a zero interior node is a product of lower \
degree invariants and covariants. Can this be utilized to improve our \
algorithm?\
\>", "Item",
 CellChangeTimes->{{3.9811240575718365`*^9, 3.981124223337841*^9}, 
   3.9811242919204082`*^9, {3.981124333095875*^9, 3.981124428007532*^9}, {
   3.9811244690535145`*^9, 
   3.981124472792824*^9}},ExpressionUUID->"8df0ab7c-9271-5b48-9db7-\
46fcece6efbd"]
}, Open  ]],

