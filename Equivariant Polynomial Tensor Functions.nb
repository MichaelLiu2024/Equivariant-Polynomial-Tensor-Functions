d4d4bced71df"],

Cell[BoxData[
 FormBox[GridBox[{
    {"Level", "Symbol", "Meaning"},
    {"0",
     RowBox[{"{",
      RowBox[{
       SubscriptBox[
        RowBox[{"(", "\[Lambda]", ")"}], "\[Lambda]"], ",",
       SubscriptBox[
        RowBox[{"(",
         RowBox[{"dim", " ",
          SubscriptBox["X", "\[Lambda]"]}], ")"}], "\[Lambda]"], ",",
       "\[Nu]"}], "}"}],
     RowBox[{"X",
      RowBox[{" ",
       RowBox[{"=", " "}]}],
      RowBox[{
       RowBox[{
        UnderscriptBox["\[CirclePlus]", "\[Lambda]"],
        RowBox[{
         RowBox[{
          SubscriptBox["H", "\[Lambda]"], "\[CircleTimes]",
          SubscriptBox["X", "\[Lambda]"]}], " ", "and", " ", "Y"}]}],
       RowBox[{" ",
        RowBox[{"=", " "}]}],
       SubscriptBox["H", "\[Nu]"]}]}]},
    {"1", "D",
     RowBox[{"total", " ", "polynomial", " ", "degree"}]},
    {"2",
     SubscriptBox[
      RowBox[{"(",
       SubscriptBox["d", "\[Lambda]"], ")"}], "\[Lambda]"],
     RowBox[{"multidegree", " ", "in", " ", "the", " ",
      SubscriptBox["H", "\[Lambda]"]}]},
    {"3",
     SubscriptBox[
      RowBox[{"(",
       SubscriptBox["\[Pi]", "\[Lambda]"], ")"}], "\[Lambda]"],
     RowBox[{
     "partitions", " ", "determining", " ", "the", " ", "partial", " ",
      "symmetry", " ", "of", " ", "tensors"}]},
    {"4",
     SubscriptBox[
      RowBox[{"(",
       SubscriptBox["\[Mu]", "\[Lambda]"], ")"}], "\[Lambda]"],
     RowBox[{"intermediate", " ", "spins", " ", "coupled", " ", "to", " ",
      SubscriptBox["H", "\[Nu]"]}]},
    {"5",
     RowBox[{"<|", "\[Ellipsis]", "|>"}],
     RowBox[{
      RowBox[{"bases", " ", "for",
       RowBox[{
        SubscriptBox["Hom", "G"], "(",
        RowBox[{
         SubscriptBox["H", "\[Nu]"], ",",
         RowBox[{
          UnderscriptBox["\[CircleTimes]", "\[Lambda]"],
          SubscriptBox["H",
           SubscriptBox["\[Mu]", "\[Lambda]"]]}]}], ")"}]}], ",",
      RowBox[{
       SubscriptBox["Hom", "G"], "(",
       RowBox[{
        SubscriptBox["H",
         SubscriptBox["\[Mu]", "\[Lambda]"]], ",",
        RowBox[{
         SubscriptBox["e",
          SubscriptBox["\[Pi]", "\[Lambda]"]], "(",
         SubsuperscriptBox["H", "\[Lambda]",
          RowBox[{"\[CircleTimes]",
           SubscriptBox["d", "\[Lambda]"]}]], ")"}]}], ")"}], ",",
      RowBox[{"and", " ",
       RowBox[{
        SubsuperscriptBox["e",
         SubscriptBox["\[Pi]", "\[Lambda]"], "*"], "(",
        SubsuperscriptBox["X", "\[Lambda]",
         RowBox[{"\[CircleTimes]",
          SubscriptBox["d", "\[Lambda]"]}]], ")"}]}]}]}
   }], TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.9627488855059834`*^9, 3.962748887091898*^9}, {
