Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["r", "\[Pi]"], ":=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"\[LeftBracketingBar]", 
       SubscriptBox["R", "\[Pi]"], "\[RightBracketingBar]"}]], 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       RowBox[{"\[Sigma]", "\[Element]", 
        SubscriptBox["R", "\[Pi]"]}]], 
      RowBox[{
       RowBox[{"sgn", "(", "\[Sigma]", ")"}], "\[Sigma]"}]}]}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    SubscriptBox["c", "\[Pi]"], ":=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"\[LeftBracketingBar]", 
       SubscriptBox["C", "\[Pi]"], "\[RightBracketingBar]"}]], 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       RowBox[{"\[Sigma]", "\[Element]", 
        SubscriptBox["C", "\[Pi]"]}]], "\[Sigma]"}]}]}], ",", "\n", 
   RowBox[{
    SubscriptBox["e", "\[Pi]"], ":=", 
    RowBox[{
     FractionBox[
      RowBox[{
       RowBox[{"\[LeftBracketingBar]", 
        SubscriptBox["R", "\[Pi]"], "\[RightBracketingBar]"}], 
       RowBox[{"\[LeftBracketingBar]", 
        SubscriptBox["C", "\[Pi]"], "\[RightBracketingBar]"}]}], 
      SubscriptBox["HL", "\[Pi]"]], 
     SubscriptBox["c", "\[Pi]"], 
     SubscriptBox["r", "\[Pi]"]}]}], ","}], 
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
