 FormBox[
  RowBox[{
   RowBox[{
    SubsuperscriptBox["x", "\[Lambda]", 
     RowBox[{"\[CircleTimes]", 
      SubscriptBox["d", "\[Lambda]"]}]], "=", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", 
      SubscriptBox[
       RowBox[{"(", 
        SubscriptBox["k", 
         RowBox[{"\[Lambda]", " ", "l"}]], ")"}], "l"]], 
     RowBox[{
      UnderoverscriptBox["\[CircleTimes]", 
       RowBox[{"l", "=", "1"}], 
       SubscriptBox["d", "\[Lambda]"]], 
      RowBox[{
       SubscriptBox["h", 
