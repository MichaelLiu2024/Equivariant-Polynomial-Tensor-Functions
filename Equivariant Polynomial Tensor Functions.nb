Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubsuperscriptBox["e", "\[Pi]", "*"], "(", 
     RowBox[{"f", "(", "T", ")"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["e", "\[Pi]", "*"], "(", 
      RowBox[{
       SuperscriptBox["\[CapitalPhi]", 
        RowBox[{"\[CircleTimes]", "d"}]], 
       RowBox[{"g", "(", "T", ")"}]}], ")"}], "=", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[CapitalPhi]", 
        RowBox[{"\[CircleTimes]", "d"}]], 
       RowBox[{
        SubsuperscriptBox["e", "\[Pi]", "*"], "(", 
        RowBox[{"g", "(", "T", ")"}], ")"}]}], "=", 
      RowBox[{
       RowBox[{
        SuperscriptBox["\[CapitalPhi]", 
         RowBox[{"\[CircleTimes]", "d"}]], 
        RowBox[{
         UnderscriptBox["\[Sum]", "k"], 
         RowBox[{
          RowBox[{"g", "(", 
           SubscriptBox["U", "k"], ")"}], 
          TemplateBox[{
            RowBox[{
              SubsuperscriptBox["e", "\[Pi]", "*"], "(", 
              RowBox[{"g", "(", "T", ")"}], ")"}], 
            RowBox[{"g", "(", 
              SubscriptBox["U", "k"], ")"}]},
           "BraKet"]}]}]}], "=", 
       RowBox[{
        UnderscriptBox["\[Sum]", "k"], 
        RowBox[{
         RowBox[{"f", "(", 
          SubscriptBox["U", "k"], ")"}], 
         TemplateBox[{
           RowBox[{
             SubsuperscriptBox["e", "\[Pi]", "*"], "(", 
             RowBox[{"g", "(", "T", ")"}], ")"}], 
           RowBox[{"g", "(", 
             SubscriptBox["U", "k"], ")"}]},
          "BraKet"]}]}]}]}]}]}], ","}], TraditionalForm]], "DisplayFormula",
