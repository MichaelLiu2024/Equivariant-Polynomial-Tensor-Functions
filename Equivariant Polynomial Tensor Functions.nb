  3.9727458431132383`*^9}},ExpressionUUID->"0550eb99-4698-493a-920c-\
19d38ce253da"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[CapitalPhi]", TraditionalForm]],ExpressionUUID->
  "6aa3e54b-1993-2a46-bbfc-3b084e995c48"],
 " be a tensor. Then"
}], "Text",
 CellChangeTimes->{{3.9811245473560276`*^9,
  3.981124555432873*^9}},ExpressionUUID->"b6eb071a-8b0e-304a-8358-\
484951255a4f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    TemplateBox[{
      RowBox[{"Sym", " ", "\[CapitalPhi]"}],
      RowBox[{
        SubscriptBox["v", "1"], "\[CircleTimes]", "\[Ellipsis]",
        "\[CircleTimes]",
        SubscriptBox["v", "d"]}]},
     "BraKet"],
    RowBox[{" ",
     RowBox[{"=", " "}]}],
    RowBox[{
     FractionBox[
      SuperscriptBox[
       RowBox[{"(",
        RowBox[{"-", "1"}], ")"}], "d"],
      RowBox[{"d", "!"}]],
     RowBox[{
      UnderscriptBox["\[Sum]",
       RowBox[{"A", "\[SubsetEqual]",
        RowBox[{"{",
         RowBox[{"1", ",", "\[Ellipsis]", ",", "d"}], "}"}]}]],
      RowBox[{
       SuperscriptBox[
        RowBox[{"(",
         RowBox[{"-", "1"}], ")"}],
        RowBox[{"\[LeftBracketingBar]", "A", "\[RightBracketingBar]"}]],
       RowBox[{"\[Phi]", "(",
        RowBox[{
         UnderscriptBox["\[Sum]",
          RowBox[{"a", "\[Element]", "A"}]],
         SubscriptBox["v", "a"]}], ")"}]}]}]}]}], ",", "\[IndentingNewLine]",

   RowBox[{
    RowBox[{"\[Phi]", "(", "v", ")"}], ":=",
    RowBox[{
     TemplateBox[{"\[CapitalPhi]",
       SuperscriptBox["v",
        RowBox[{"\[CircleTimes]", "d"}]]},
      "BraKet"], "."}]}]}], TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.972476057685408*^9, 3.972476310591394*^9},
   3.972476352207329*^9, {3.981124557849783*^9, 3.9811245918603115`*^9}},
 TextAlignment->Center,ExpressionUUID->"32f05232-3f6e-4c3d-8ff3-54ee05188ee7"]
}, Open  ]]
}, Open  ]],

