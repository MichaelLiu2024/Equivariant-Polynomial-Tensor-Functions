Cell["Algorithm (Evaluation scheme)", "Subsubsection",
 CellChangeTimes->{{3.9811273889818954`*^9,
  3.981127394638994*^9}},ExpressionUUID->"9c5ceb64-f972-ea4e-9359-\
5766df02f4ee"],

Cell[CellGroupData[{

Cell["Theorem 4 (Evaluation scheme, continued)", "Subsubsection",
 CellChangeTimes->{{3.981128025325899*^9,
  3.9811280442318687`*^9}},ExpressionUUID->"84ede733-98a8-134b-95b2-\
88ff19228ff9"],

Cell["From [TODO], we have", "Text",
 CellChangeTimes->{{3.981128061779169*^9,
  3.981128070399275*^9}},ExpressionUUID->"28ec3161-317a-d24e-bfd6-\
f4b785196813"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"Sym", "(",
     RowBox[{
      SubsuperscriptBox["h", "1",
       RowBox[{"\[CircleTimes]",
        SubscriptBox["d", "1"]}]], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]",
      SubsuperscriptBox["h", "m",
       RowBox[{"\[CircleTimes]",
        SubscriptBox["d", "m"]}]]}], ")"}],
    RowBox[{" ",
     RowBox[{"=", " "}]}],
    RowBox[{
     RowBox[{
      RowBox[{
       FractionBox["1", "C"],
       RowBox[{
        UnderscriptBox["\[Sum]",
         RowBox[{"0", "<=",
          SubscriptBox["a", "i"], "<=",
          SubscriptBox["d", "i"]}]],
        RowBox[{
         SuperscriptBox[
          RowBox[{"(",
           RowBox[{
            RowBox[{
             RowBox[{
              SubscriptBox["h", "1"], "+",
              RowBox[{
               SubsuperscriptBox["\[Zeta]", "2",
                SubscriptBox["a", "2"]],
               SubscriptBox["h", "2"]}]}], "..."}], "+",
            RowBox[{
             SubsuperscriptBox["\[Zeta]", "m",
              SubscriptBox["a", "m"]],
             SubscriptBox["h", "m"]}]}], ")"}], "d"],
         SubsuperscriptBox["\[Zeta]", "2",
          SubscriptBox["a", "2"]]}]}]}], "..."}],
     SubsuperscriptBox["\[Zeta]", "m",
      SubscriptBox["a", "m"]]}]}], ",", "\[IndentingNewLine]",
   RowBox[{"C", ":=",
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", GridBox[{
          {"d"},
          {
           RowBox[{
            SubscriptBox["d", "1"], ",", "...", ",",
            SubscriptBox["d", "m"]}]}
         }], ")"}],
       RowBox[{"(",
        RowBox[{
         SubscriptBox["d", "1"], "+", "1"}], ")"}]}], "..."}],
     RowBox[{
      RowBox[{"(",
       RowBox[{
        SubscriptBox["d", "m"], "+", "1"}], ")"}], "."}]}]}]}],
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.981128075287319*^9, 3.981128233350628*^9}},
 TextAlignment->Center,ExpressionUUID->"7dc13a74-8cb7-f640-b3ea-4ede88059816"],

Cell["Thus, ", "Text",
 CellChangeTimes->{{3.98112824346579*^9,
  3.9811282439447174`*^9}},ExpressionUUID->"16926a96-33e0-9d4d-be0e-\
c10cd946a0c8"]
}, Open  ]]
}, Open  ]],

