Cell[BoxData[{
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["e", 
     SubscriptBox["\[Pi]", "\[Lambda]"]], "(", 
    SubsuperscriptBox["H", "\[Lambda]", 
     RowBox[{"\[CircleTimes]", 
      SubscriptBox["d", "\[Lambda]"]}]], ")"}], "\[TildeFullEqual]", 
   RowBox[{
    SubscriptBox["r", 
     SubscriptBox["\[Pi]", "\[Lambda]"]], "(", 
    RowBox[{
     SubscriptBox["c", 
      SubscriptBox["\[Pi]", "\[Lambda]"]], "(", 
     SubsuperscriptBox["H", "\[Lambda]", 
      RowBox[{"\[CircleTimes]", 
       SubscriptBox["d", "\[Lambda]"]}]], ")"}], ")"}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"\[TildeFullEqual]", 
   RowBox[{
    SubscriptBox["r", 
     SubscriptBox["\[Pi]", "\[Lambda]"]], "(", 
    RowBox[{
     UnderscriptBox["\[CircleTimes]", "p"], 
     RowBox[{
      SuperscriptBox["\[CapitalLambda]", 
       SubscriptBox["\[Pi]", 
        RowBox[{"\[Lambda]", ",", "p"}]]], "(", 
      SubscriptBox["H", "\[Lambda]"], ")"}]}], ")"}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   OverscriptBox["\[TildeFullEqual]", 
    RowBox[{"apply", " ", "Hom"}]], 
   RowBox[{
    SubscriptBox["r", 
     SubscriptBox["\[Pi]", "\[Lambda]"]], "(", 
    RowBox[{
     UnderscriptBox["\[CircleTimes]", "p"], 
     RowBox[{
      UnderscriptBox["\[CirclePlus]", 
       SubscriptBox["\[Xi]", 
        RowBox[{"\[Lambda]", ",", "p"}]]], 
      RowBox[{
       SubscriptBox["H", 
        SubscriptBox["\[Xi]", 
         RowBox[{"\[Lambda]", ",", "p"}]]], "\[CircleTimes]", 
       RowBox[{
        SubscriptBox["Hom", "G"], "(", 
        RowBox[{
         SubscriptBox["H", 
          SubscriptBox["\[Xi]", 
           RowBox[{"\[Lambda]", ",", "p"}]]], ",", 
         RowBox[{
          SuperscriptBox["\[CapitalLambda]", 
           SubscriptBox["\[Pi]", 
            RowBox[{"\[Lambda]", ",", "p"}]]], "(", 
          SubscriptBox["H", "\[Lambda]"], ")"}]}], ")"}]}]}]}], ")"}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   OverscriptBox["\[TildeFullEqual]", 
    RowBox[{"rearrange", " ", "\[CircleTimes]"}]], 
   RowBox[{
    RowBox[{
     SubscriptBox["r", 
      SubscriptBox["\[Pi]", "\[Lambda]"]], "(", 
     RowBox[{
      UnderscriptBox["\[CirclePlus]", 
       SubscriptBox[
        RowBox[{"(", 
         SubscriptBox["\[Xi]", 
          RowBox[{"\[Lambda]", ",", "p"}]], ")"}], "p"]], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         UnderscriptBox["\[CircleTimes]", "p"], 
         SubscriptBox["H", 
          SubscriptBox["\[Xi]", 
           RowBox[{"\[Lambda]", ",", "p"}]]]}], ")"}], "\[CircleTimes]", 
       RowBox[{"(", 
        RowBox[{
         UnderscriptBox["\[CircleTimes]", "p"], 
         RowBox[{
          SubscriptBox["Hom", "G"], "(", 
          RowBox[{
           SubscriptBox["H", 
            SubscriptBox["\[Xi]", 
             RowBox[{"\[Lambda]", ",", "p"}]]], ",", 
           RowBox[{
            SuperscriptBox["\[CapitalLambda]", 
             SubscriptBox["\[Pi]", 
              RowBox[{"\[Lambda]", ",", "p"}]]], "(", 
            SubscriptBox["H", "\[Lambda]"], ")"}]}], ")"}]}], ")"}]}]}], 
