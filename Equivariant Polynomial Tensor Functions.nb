  3.9725644342705994`*^9, 3.9725644571812954`*^9}, {3.980270365547306*^9, 
  3.9802703679513645`*^9}},ExpressionUUID->"f25bd2e3-9259-e840-b29b-\
3b058cd5a155"],

Cell[CellGroupData[{

Cell["\<\
Lemma A1 (Identifying the covariant module with the space of equivariant \
polynomial functions)\
\>", "Subsubsection",
 CellChangeTimes->{{3.9710035146751137`*^9, 3.971003536956476*^9}, {
  3.9725632765974045`*^9, 
  3.972563310615017*^9}},ExpressionUUID->"89ae3a93-648e-fc44-8cc6-\
be738a091180"],

Cell["There is an isomorphism of vector spaces", "Text",
 CellChangeTimes->{{3.971003544616583*^9, 3.971003550193693*^9}, {
  3.9710035847269936`*^9, 3.97100359680641*^9}, {3.9725633003890953`*^9, 
  3.97256330118589*^9}},ExpressionUUID->"d47b1d21-5b95-4d4b-97f6-\
aaaf53f4fc6b"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[ScriptCapitalS]", "(", 
       SuperscriptBox["X", "*"], ")"}], "\[CircleTimes]", "Y"}], ")"}], "G"], 
   "\[TildeFullEqual]", 
   RowBox[{"{", 
    RowBox[{
    "equivariant", " ", "polynomial", " ", "functions", " ", "from", " ", "X",
      " ", "to", " ", "Y"}], "}"}]}], TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.971002790255043*^9, 3.9710027918797283`*^9}, {
  3.971002973488472*^9, 3.971002973663662*^9}, {3.97100307613105*^9, 
  3.9710030766647224`*^9}, {3.971003613612816*^9, 3.9710036365823917`*^9}},
 TextAlignment->Center,ExpressionUUID->"aa2f7923-52e3-424c-8f78-3ca5ab085d12"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Proof", "Subsubsection",
 CellChangeTimes->{{3.9710035411683083`*^9, 
  3.971003541571047*^9}},ExpressionUUID->"6d68c39d-4f81-d446-a79e-\
24830acc5d36"],

Cell[TextData[{
 "Consider the pairing ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"\[ScriptCapitalS]", "(", 
        SuperscriptBox["X", "*"], ")"}], "\[CircleTimes]", "Y"}], ")"}], "\[Cross]",
      "X"}], "->", "Y"}], TraditionalForm]],ExpressionUUID->
  "cf31cc08-f5f3-5e4e-ad11-75ddd6e69b8b"],
 " defined on elementary tensors (which correspond to the component functions \
of the polynomial) by"
}], "Text",
 CellChangeTimes->{{3.9620655704713078`*^9, 3.9620656118013153`*^9}, {
   3.96211416575548*^9, 3.9621141743737946`*^9}, {3.962116772983818*^9, 
   3.9621167730867767`*^9}, {3.962203842893463*^9, 3.9622038592620926`*^9}, {
   3.96236279128685*^9, 3.962362802794325*^9}, {3.962982784666952*^9, 
   3.962982784761032*^9}, 3.9710035122346096`*^9, 3.971003669879862*^9, 
   3.9725611394912567`*^9},
 Background->None,ExpressionUUID->"74566bde-4276-b24c-975e-937c73c731cd"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"\[CurlyPhi]", "\[CircleTimes]", "y"}], ",", "x"}], ")"}], "\[Function]", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"\[CurlyPhi]", "\[CircleTimes]", "y"}], ")"}], 
     RowBox[{"(", "x", ")"}]}], ":=", 
    RowBox[{
     RowBox[{"\[CurlyPhi]", "(", "x", ")"}], "y"}]}]}], 
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.962039374843857*^9, 3.9620394190790253`*^9}, {
  3.962039580576721*^9, 3.962039596152975*^9}, {3.962039726275709*^9, 
  3.962039765601347*^9}, {3.9621141645999374`*^9, 3.9621141780982666`*^9}},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"4a1a011d-9d29-6b4a-b45c-36af04b5b910"],

Cell[TextData[{
 "and extended linearly to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalS]", "(", 
     SuperscriptBox["X", "*"], ")"}], "\[CircleTimes]", "Y"}], 
   TraditionalForm]],
  CellChangeTimes->{{3.962039374843857*^9, 3.9620394190790253`*^9}, {
   3.962039580576721*^9, 3.962039596152975*^9}, {3.962039726275709*^9, 
   3.962039765601347*^9}},
  TextAlignment->Center,ExpressionUUID->
  "1bf50887-5b01-4a47-a3e9-3e17c154150f"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CurlyPhi]", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "6afe6048-9632-be4f-b1ae-2269742dfeca"],
 " is defined by writing"
}], "Text",
 CellChangeTimes->{{3.962034864173525*^9, 3.9620348693218117`*^9}, {
   3.962035004131426*^9, 3.962035058051111*^9}, {3.9620368690909767`*^9, 
   3.962036879713932*^9}, {3.9620393234480457`*^9, 3.9620393707673645`*^9}, {
   3.9620394265259323`*^9, 3.9620394290029926`*^9}, {3.9620395976171017`*^9, 
   3.9620396020036697`*^9}, {3.9620397819003963`*^9, 3.962039787979561*^9}, {
   3.9620398201528683`*^9, 3.962039833106035*^9}, {3.9620656149730015`*^9, 
   3.962065615454159*^9}, {3.9620659326799984`*^9, 3.9620659349767895`*^9}, 
   3.9621141693960285`*^9, {3.962114207954767*^9, 3.962114208851349*^9}, {
   3.9621143098303146`*^9, 3.9621143172238693`*^9}, {3.9621143781002083`*^9, 
   3.9621144269170647`*^9}, {3.9621147210243645`*^9, 3.962114722173399*^9}, {
   3.962203721053314*^9, 3.9622037254103336`*^9}},
 Background->None,ExpressionUUID->"a248ce92-4c82-7b41-8794-46b09fd70d4f"],

Cell[BoxData[
 FormBox[
  RowBox[{"\[CurlyPhi]", "=", 
   RowBox[{
    UnderoverscriptBox["\[CirclePlus]", 
     RowBox[{"d", "=", "0"}], "D"], 
    RowBox[{
     UnderoverscriptBox["\[CirclePlus]", 
      RowBox[{
       SubscriptBox["j", "1"], ",", "\[Ellipsis]", ",", 
       RowBox[{
        SubscriptBox["j", "d"], "=", "1"}]}], 
      RowBox[{"dim", " ", 
       SuperscriptBox["X", "*"]}]], 
     RowBox[{
      SubscriptBox["\[CurlyPhi]", 
       RowBox[{
        SubscriptBox["j", "1"], 
        SubscriptBox["\[Ellipsis]j", "d"]}]], 
      RowBox[{
       SubsuperscriptBox["e", 
        SubscriptBox["j", "1"], "*"], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
       SubsuperscriptBox["e", 
        SubscriptBox["j", "d"], "*"]}]}]}]}]}], 
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.962114724644085*^9, 3.962114751530184*^9}, {
   3.962114809956051*^9, 3.962114862676119*^9}, {3.962114965675766*^9, 
   3.962114992219759*^9}, {3.962115051516407*^9, 3.9621150524417706`*^9}, {
   3.9622918683942127`*^9, 3.9622918735152187`*^9}, 3.96229204090106*^9},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"79721679-60a5-f843-a22b-724b99dba4da"],

Cell[TextData[{
 "in terms of a basis ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    RowBox[{"{", 
     SubsuperscriptBox["e", "j", "*"], "}"}], 
    RowBox[{"j", "=", "1"}], 
    RowBox[{"dim", " ", 
     SuperscriptBox["X", "*"]}]], TraditionalForm]],ExpressionUUID->
  "28cdc4d6-d8fe-9648-b044-966caebe63e6"],
 " for ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["X", "*"], TraditionalForm]],ExpressionUUID->
  "95e4d7bf-d6c8-0f42-8936-f321e8400b74"],
 " and declaring that"
}], "Text",
 CellChangeTimes->{{3.9621149019744797`*^9, 3.962114921035713*^9}, {
  3.9621149676473846`*^9, 3.9621150013962994`*^9}, {3.9621151412470417`*^9, 
  3.9621151479497776`*^9}, {3.9622037429051666`*^9, 3.9622037475807495`*^9}},
 Background->None,ExpressionUUID->"e6b289e7-3727-f54c-a96d-d82ab7f665af"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"\[CurlyPhi]", "(", "x", ")"}], ":=", 
   RowBox[{
    UnderoverscriptBox["\[CirclePlus]", 
     RowBox[{"d", "=", "0"}], "D"], 
    RowBox[{
     UnderoverscriptBox["\[CirclePlus]", 
      RowBox[{
       SubscriptBox["j", "1"], ",", "\[Ellipsis]", ",", 
       RowBox[{
        SubscriptBox["j", "d"], "=", "1"}]}], 
      RowBox[{"dim", " ", 
       SuperscriptBox["X", "*"]}]], 
     RowBox[{
      SubscriptBox["\[CurlyPhi]", 
       RowBox[{
        SubscriptBox["j", "1"], 
        SubscriptBox["\[Ellipsis]j", "d"]}]], 
      RowBox[{
       SubsuperscriptBox["e", 
        SubscriptBox["j", "1"], "*"], "(", "x", ")"}], "*", "\[Ellipsis]", "*", 
      RowBox[{
       RowBox[{
        SubsuperscriptBox["e", 
         SubscriptBox["j", "d"], "*"], "(", "x", ")"}], "."}]}]}]}]}], 
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.962039374843857*^9, 3.9620394190790253`*^9}, {
   3.962039580576721*^9, 3.962039596152975*^9}, {3.962039726275709*^9, 
   3.962039765601347*^9}, {3.9621141645999374`*^9, 3.9621141780982666`*^9}, {
   3.9621150066181087`*^9, 3.962115054725666*^9}, 3.9621151172011147`*^9, {
   3.9622037914192486`*^9, 3.9622037914479866`*^9}, {3.962291874851818*^9, 
   3.962291876709038*^9}, 3.962292041859825*^9},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"0c95d3aa-b928-c74c-933d-51e48e2eb8a2"],

Cell[TextData[{
 "Note that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CurlyPhi]", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "da67678c-1ad4-d74a-aa20-eeb0c2ae1961"],
 " is a degree ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "858a2bb8-14db-0c4a-90f4-8e30c990d175"],
 " polynomial in the entries of ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "93949e99-1097-4f41-bdc9-bd58c8e88091"],
 " selected by the ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["e", "j", "*"], TraditionalForm]],ExpressionUUID->
  "e83430cb-e738-5545-9140-16bb5c2e748e"],
 "."
}], "Text",
 CellChangeTimes->{{3.962115118821308*^9, 3.962115157911236*^9}, {
  3.962115256355633*^9, 3.9621153336299343`*^9}, {3.962203800861923*^9, 
  3.9622038204332314`*^9}, {3.962203851156069*^9, 3.962203854525055*^9}, {
  3.962292045319828*^9, 3.962292045319828*^9}},
 Background->None,ExpressionUUID->"5397343b-09a5-964d-9c84-38e094351dcb"],

Cell[TextData[{
 "Fix ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "\[Element]", "G"}], TraditionalForm]],ExpressionUUID->
  "7685e4fd-bdaa-6343-afcf-acb914fa9421"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderscriptBox["\[Sum]", "i"], 
     RowBox[{
      SubscriptBox["\[CurlyPhi]", "i"], "\[CircleTimes]", 
      SubscriptBox["y", "i"]}]}], "\[Element]", 
    RowBox[{
     RowBox[{"\[ScriptCapitalS]", "(", 
      SuperscriptBox["X", "*"], ")"}], "\[CircleTimes]", "Y"}]}], 
   TraditionalForm]],ExpressionUUID->"4736a864-4488-6548-a08d-10d0fedacb0a"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", "X"}], TraditionalForm]],ExpressionUUID->
  "8fc58222-42b5-e647-9df6-71d65b0f5211"],
 ". Observe that"
}], "Text",
 CellChangeTimes->{{3.962115118821308*^9, 3.962115157911236*^9}, {
  3.962115256355633*^9, 3.9621153336299343`*^9}, {3.962203800861923*^9, 
  3.9622038204332314`*^9}, {3.962203851156069*^9, 3.9622038673852177`*^9}, {
  3.962204041064398*^9, 3.962204083061754*^9}, {3.9710036874084263`*^9, 
  3.971003688486368*^9}},
 Background->None,ExpressionUUID->"d0d04cc0-d8b2-6a42-9072-a44dff808c5e"],

Cell[BoxData[{
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      UnderscriptBox["\[Sum]", "i"], 
      RowBox[{
       SubscriptBox["\[CurlyPhi]", "i"], "\[CircleTimes]", 
       SubscriptBox["y", "i"]}]}], ")"}], 
    RowBox[{"(", 
     RowBox[{"g", " ", "x"}], ")"}]}], "=", 
   RowBox[{"g", "(", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       UnderscriptBox["\[Sum]", "i"], 
       RowBox[{
        SubscriptBox["\[CurlyPhi]", "i"], "\[CircleTimes]", 
        SubscriptBox["y", "i"]}]}], ")"}], 
     RowBox[{"(", "x", ")"}]}], ")"}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"\[DoubleLongLeftRightArrow]", 
    RowBox[{
     UnderscriptBox["\[Sum]", "i"], 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CurlyPhi]", "i"], "(", 
       RowBox[{"g", " ", "x"}], ")"}], 
      SubscriptBox["y", "i"]}]}]}], "=", 
   RowBox[{"g", "(", 
    RowBox[{
     UnderscriptBox["\[Sum]", "i"], 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CurlyPhi]", "i"], "(", "x", ")"}], 
      SubscriptBox["y", "i"]}]}], ")"}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"\[DoubleLongLeftRightArrow]", 
    RowBox[{
     UnderscriptBox["\[Sum]", "i"], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["g", 
         RowBox[{"-", "1"}]], 
        SubscriptBox["\[CurlyPhi]", "i"]}], ")"}], 
      RowBox[{"(", "x", ")"}], 
      SubscriptBox["y", "i"]}]}]}], "=", 
   RowBox[{
    UnderscriptBox["\[Sum]", "i"], 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CurlyPhi]", "i"], "(", "x", ")"}], "g", " ", 
     SubscriptBox["y", "i"]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"\[DoubleLongLeftRightArrow]", 
     RowBox[{"(", 
      RowBox[{
       UnderscriptBox["\[Sum]", "i"], 
       RowBox[{
        SuperscriptBox["g", 
         RowBox[{"-", "1"}]], 
        RowBox[{
         SubscriptBox["\[CurlyPhi]", "i"], "\[CircleTimes]", 
         SubscriptBox["y", "i"]}]}]}], ")"}]}], 
    RowBox[{"(", "x", ")"}]}], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      UnderscriptBox["\[Sum]", "i"], 
      RowBox[{
       RowBox[{
        SubscriptBox["\[CurlyPhi]", "i"], "\[CircleTimes]", "g"}], " ", 
       SubscriptBox["y", "i"]}]}], ")"}], 
    RowBox[{
     RowBox[{"(", "x", ")"}], "."}]}]}], TraditionalForm]}], "DisplayFormula",
 CellChangeTimes->{{3.962115335989311*^9, 3.962115523640129*^9}, {
  3.9621157082009506`*^9, 3.962115731965809*^9}, {3.9621157657852917`*^9, 
  3.962115801149458*^9}, {3.9621158336876545`*^9, 3.962115847640524*^9}, {
  3.9621159548599358`*^9, 3.9621159568259125`*^9}, {3.962116042495701*^9, 
  3.962116075628874*^9}, {3.9622040500812683`*^9, 3.962204072393633*^9}, {
  3.962204896270733*^9, 3.9622049265966454`*^9}},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"35dfff07-0699-0a41-a8bd-34b2856cd0b5"],

Cell[TextData[{
 "Thus, we conclude that the polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["\[Sum]", "i"], 
    RowBox[{
     SubscriptBox["\[CurlyPhi]", "i"], "\[CircleTimes]", 
     SubscriptBox["y", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "048a540b-59ca-0a46-972e-c2cc4fde3ff1"],
 " is equivariant iff ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"g", 
     RowBox[{
      UnderscriptBox["\[Sum]", "i"], 
      RowBox[{
       SubscriptBox["\[CurlyPhi]", "i"], "\[CircleTimes]", 
       SubscriptBox["y", "i"]}]}]}], "=", 
    RowBox[{
     UnderscriptBox["\[Sum]", "i"], 
     RowBox[{
      SubscriptBox["\[CurlyPhi]", "i"], "\[CircleTimes]", 
      SubscriptBox["y", "i"]}]}]}], TraditionalForm]],ExpressionUUID->
  "94d838d2-e06f-ca45-9a01-6188eb25ee25"],
 " for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "\[Element]", "G"}], TraditionalForm]],ExpressionUUID->
  "da8cd430-2976-1748-bc87-8913cb32f535"],
 " iff ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderscriptBox["\[Sum]", "i"], 
     RowBox[{
      SubscriptBox["\[CurlyPhi]", "i"], "\[CircleTimes]", 
      SubscriptBox["y", "i"]}]}], "\[Element]", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"\[ScriptCapitalS]", "(", 
        SuperscriptBox["X", "*"], ")"}], "\[CircleTimes]", "Y"}], ")"}], 
     "G"]}], TraditionalForm]],ExpressionUUID->
  "47be8cbf-f3ff-134b-be1e-37018b3252e3"],
 "."
}], "Text",
 CellChangeTimes->{{3.962115850437252*^9, 3.9621159055638523`*^9}, {
  3.962116081828148*^9, 3.962116086674597*^9}, {3.96211619989254*^9, 
  3.9621162469588223`*^9}, {3.9622049590921*^9, 3.962204967182167*^9}, {
  3.962205036520693*^9, 3.9622050372540417`*^9}, {3.9623630870972996`*^9, 
  3.9623630893091335`*^9}, {3.9710037814146023`*^9, 3.9710037960822315`*^9}},
 Background->None,ExpressionUUID->"6fa2a077-891b-d742-8575-59862be92200"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Lemma (Isotypic decomposition of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalLambda]", "d"], "(", 
    SubscriptBox["H", "\[Lambda]"], ")"}], TraditionalForm]],ExpressionUUID->
  "92354784-5053-d349-8f6b-fb08bb8a4380"],
 ")"
}], "Subsubsection",
 CellChangeTimes->{{3.9712832037042303`*^9, 3.971283215208564*^9}, {
  3.9713665884732637`*^9, 
  3.971366589207942*^9}},ExpressionUUID->"146f42ae-32f4-554f-99f4-\
163e6d182526"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", ",", 
    RowBox[{"d", "<=", "3"}]}], TraditionalForm]],ExpressionUUID->
  "b95e756f-4d28-d647-9d60-1c8b4d19e67b"],
 ". Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"dim", " ", 
    RowBox[{
     SubscriptBox["Hom", "G"], "(", 
     RowBox[{
      SubscriptBox["H", "\[Mu]"], ",", 
      RowBox[{
       SuperscriptBox["\[CapitalLambda]", "d"], "(", 
       SubscriptBox["H", "\[Lambda]"], ")"}]}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9bc1df64-6b19-b24c-9f99-fa12ac5aaa0d"],
 " is either ",
 Cell[BoxData[
  FormBox["0", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c586f828-3f0c-0b4f-8238-14101e7cebe5"],
 " or ",
 Cell[BoxData[
  FormBox["1", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9dd9ec05-768e-444e-9f7b-69f8e0ac4e63"],
 ". Moreover, if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "=", "3"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4b867b24-e2f1-2547-a93e-8bb523bde910"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"dim", " ", 
     RowBox[{
      SubscriptBox["Hom", "G"], "(", 
      RowBox[{
       SubscriptBox["H", "\[Mu]"], ",", 
       RowBox[{
        SuperscriptBox["\[CapitalLambda]", "d"], "(", 
        SubscriptBox["H", "\[Lambda]"], ")"}]}], ")"}]}], "=", "1"}], 
   TraditionalForm]],ExpressionUUID->"0bb6c5ba-af54-ba4e-ba6f-d6949ac4007b"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"\[Lambda]", ",", 
     RowBox[{
      RowBox[{"2", 
       RowBox[{"\[LeftFloor]", 
        FractionBox[
         RowBox[{"Abs", "[", 
          RowBox[{"\[Lambda]", "-", "\[Mu]"}], "]"}], "2"], 
        "\[RightFloor]"}]}], "+", "1"}], ",", "\[Mu]"}], "}"}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3b33c9b1-2c0a-7746-9c09-007fb58cec8c"],
 " is a nonzero path."
}], "Text",
 CellChangeTimes->{{3.971366555159462*^9, 3.971366556023088*^9}, {
  3.9713666142472963`*^9, 3.971366626167646*^9}, {3.9713667662321577`*^9, 
  3.971366771351701*^9}, {3.9811250147156315`*^9, 3.981125048047083*^9}, {
  3.9811251167191067`*^9, 3.9811251230159416`*^9}, {3.9811252050632324`*^9, 
  3.9811252188031673`*^9}, {3.9811252524119625`*^9, 3.981125304506706*^9}, {
  3.9811253538251*^9, 3.9811254104160004`*^9}, {3.981125457877573*^9, 
  3.9811254887699814`*^9}},ExpressionUUID->"7c37a597-1fbb-8b4a-9258-\
1077a7b984fb"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Lemma (Isotypic decomposition of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalS]", "d"], "(", 
    SubscriptBox["H", "\[Lambda]"], ")"}], TraditionalForm]],ExpressionUUID->
  "32309311-9277-c24b-bf9e-5f6d9134a5a9"],
 ")"
}], "Subsubsection",
 CellChangeTimes->{{3.9712832037042303`*^9, 3.971283215208564*^9}, {
  3.9713665884732637`*^9, 3.971366589207942*^9}, {3.981125498100912*^9, 
  3.981125498766613*^9}},ExpressionUUID->"6a39f381-5437-f74d-b82e-\
45db8909ca59"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", ",", 
    RowBox[{"d", "<=", "3"}]}], TraditionalForm]],ExpressionUUID->
  "5fa35091-dc75-df49-8f79-80054b0da6d3"],
 ". Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"dim", " ", 
    RowBox[{
     SubscriptBox["Hom", "G"], "(", 
     RowBox[{
      SubscriptBox["H", "\[Mu]"], ",", 
      RowBox[{
       SuperscriptBox["\[ScriptCapitalS]", "d"], "(", 
       SubscriptBox["H", "\[Lambda]"], ")"}]}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "25baf3a2-3f73-cd43-9923-461b4d421da4"],
 " is either ",
 Cell[BoxData[
  FormBox["0", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b089fce3-b4be-b145-9920-17498554e373"],
 " or ",
 Cell[BoxData[
  FormBox["1", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2dd4927e-2f25-e64e-b95e-9c6baad5060d"],
 ". Moreover, if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "=", "3"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "47020887-5e8f-9644-91ac-7f4036cfcbfb"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"dim", " ", 
     RowBox[{
      SubscriptBox["Hom", "G"], "(", 
      RowBox[{
       SubscriptBox["H", "\[Mu]"], ",", 
       RowBox[{
        SuperscriptBox["\[ScriptCapitalS]", "d"], "(", 
        SubscriptBox["H", "\[Lambda]"], ")"}]}], ")"}]}], "=", "1"}], 
   TraditionalForm]],ExpressionUUID->"ab4861ef-2d74-804e-bb10-79a9b7fb35d6"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"\[Lambda]", ",", 
     RowBox[{"2", 
      RowBox[{"\[LeftFloor]", 
       FractionBox[
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{"\[Lambda]", "-", "\[Mu]"}], "]"}], "+", "1"}], "2"], 
       "\[RightFloor]"}]}], ",", "\[Mu]"}], "}"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "208d299c-f6b1-f345-b946-4a718ffb3c52"],
 " is a nonzero path."
}], "Text",
 CellChangeTimes->{{3.971366555159462*^9, 3.971366556023088*^9}, {
  3.9713666142472963`*^9, 3.971366626167646*^9}, {3.9713667662321577`*^9, 
  3.971366771351701*^9}, {3.9811250147156315`*^9, 3.981125048047083*^9}, {
  3.9811251167191067`*^9, 3.9811251230159416`*^9}, {3.9811252050632324`*^9, 
  3.9811252188031673`*^9}, {3.9811252524119625`*^9, 3.981125304506706*^9}, {
  3.9811253538251*^9, 3.9811254104160004`*^9}, {3.981125457877573*^9, 
  3.981125524150219*^9}},ExpressionUUID->"72eafc9d-6611-bd4b-a2c5-\
c11da336469e"]
}, Open  ]],

