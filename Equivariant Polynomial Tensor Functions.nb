Cell[CellGroupData[{

Cell["Theorem (Schur-Weyl duality)", "Subsubsection",
 CellChangeTimes->{{3.9710171836722946`*^9, 3.971017187543579*^9}, {
  3.971017271454151*^9, 
  3.971017271543373*^9}},ExpressionUUID->"3bbf38b1-1026-f04d-b6e9-\
308cba83beb3"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "f2777a1e-1b0f-1d43-bbd0-fc8ad2e41d87"],
 " be a finite dimensional vector space, let the general linear group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"GL", "(", "V", ")"}], TraditionalForm]],ExpressionUUID->
  "2eaf09c3-2281-7f48-af4e-745045b40aeb"],
 " act diagonally on ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["V", 
    RowBox[{"\[CircleTimes]", "d"}]], TraditionalForm]],ExpressionUUID->
  "351f9511-da46-6b48-a12e-6573627f25fa"],
 ", and let the symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[GothicCapitalS]", "d"], TraditionalForm]],ExpressionUUID->
  "dcdba359-0023-a34a-afb6-19532eaa978d"],
 " act via factor permutation on ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["V", 
    RowBox[{"\[CircleTimes]", "d"}]], TraditionalForm]],ExpressionUUID->
  "c995bc14-33c3-a74f-9fb6-6f66ca10eacc"],
 ". Then"
}], "Text",
 CellChangeTimes->{{3.9710172765469704`*^9, 3.9710173594120407`*^9}, {
  3.9712825061082497`*^9, 3.9712825249409246`*^9}, {3.9779245768930225`*^9, 
  3.9779245768930225`*^9}},ExpressionUUID->"8f823ae3-bf30-b842-9a24-\
15ed0fc8e1bc"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SuperscriptBox["V", 
     RowBox[{"\[CircleTimes]", "d"}]], "\[TildeFullEqual]", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", "\[Pi]"], 
     RowBox[{
      RowBox[{
       SubscriptBox["e", "\[Pi]"], "(", 
       SuperscriptBox["V", 
        RowBox[{"\[CircleTimes]", "d"}]], ")"}], "\[CircleTimes]", 
      RowBox[{"[", "\[Pi]", "\[VeryThinSpace]", "]"}]}]}], "\[TildeFullEqual]", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", "\[Pi]"], 
     RowBox[{
      RowBox[{
       SubsuperscriptBox["e", "\[Pi]", "*"], "(", 
       SuperscriptBox["V", 
        RowBox[{"\[CircleTimes]", "d"}]], ")"}], "\[CircleTimes]", 
      SuperscriptBox[
       RowBox[{"[", "\[Pi]", "\[VeryThinSpace]", "]"}], "*"]}]}]}], ","}], 
  TraditionalForm]], "DisplayFormula",
