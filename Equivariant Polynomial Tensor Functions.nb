  RowBox[{
   RowBox[{
    SubscriptBox["H", 
     SubscriptBox["\[Lambda]", "1"]], "\[CircleTimes]", 
    SubscriptBox["H", 
     SubscriptBox["\[Lambda]", "2"]]}], "\[TildeFullEqual]", 
   RowBox[{
    UnderoverscriptBox["\[CirclePlus]", 
     RowBox[{
      SubscriptBox["\[Gamma]", "2"], "=", 
      RowBox[{"\[LeftBracketingBar]", 
       RowBox[{
        SubscriptBox["\[Lambda]", "1"], "-", 
        SubscriptBox["\[Lambda]", "2"]}], "\[RightBracketingBar]"}]}], 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], "+", 
      SubscriptBox["\[Lambda]", "2"]}]], 
    RowBox[{
     SubscriptBox["H", 
      SubscriptBox["\[Gamma]", "2"]], "\[CircleTimes]", 
     RowBox[{
      RowBox[{
       SubscriptBox["Hom", "G"], "(", 
       RowBox[{
        SubscriptBox["H", 
         SubscriptBox["\[Gamma]", "2"]], ",", 
        RowBox[{
         SubscriptBox["H", 
          SubscriptBox["\[Lambda]", "1"]], "\[CircleTimes]", 
         SubscriptBox["H", 
          SubscriptBox["\[Lambda]", "2"]]}]}], ")"}], "."}]}]}]}], 
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
  3.9630770753080597`*^9, 3.963077080156849*^9}, {3.9630886760630875`*^9, 
  3.9630886760630875`*^9}, {3.963334237475191*^9, 3.963334237475191*^9}, {
  3.96333432456596*^9, 3.9633343428223953`*^9}, {3.9635025685698624`*^9, 
  3.963502589460739*^9}, {3.9648990659278145`*^9, 3.9648990728059845`*^9}, {
  3.9657345259987183`*^9, 3.9657345285015583`*^9}, {3.9710065399967213`*^9, 
  3.971006553243681*^9}},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"bd0453eb-7863-2240-9db9-2248ff8445de"],

Cell[TextData[{
 "Moreover, a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(", 
    RowBox[{
     SubscriptBox["H", 
      SubscriptBox["\[Gamma]", "2"]], ",", 
     RowBox[{
      SubscriptBox["H", 
       SubscriptBox["\[Lambda]", "1"]], "\[CircleTimes]", 
      SubscriptBox["H", 
       SubscriptBox["\[Lambda]", "2"]]}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"3770a4af-da40-fb40-8a9f-4244f2bd449d"],
 " is given by the single Clebsch-Gordan tensor ",
 Cell[BoxData[
  FormBox[
   RowBox[{"CG", "(", 
    RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}], TraditionalForm]],
  ExpressionUUID->"787e46bb-0169-da4e-a26e-dea756109070"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",", 
      SubscriptBox["\[Lambda]", "2"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"f0dc6c66-72e5-c147-8fef-a79265dfc2cb"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",", 
      SubscriptBox["\[Gamma]", "2"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"0772298b-2155-764a-9d4e-4e92029d8ef6"],
 "."
}], "Text",
 CellChangeTimes->{{3.971006243931774*^9, 3.9710062670095043`*^9}, {
  3.971006324297764*^9, 3.971006324297764*^9}, {3.9710065582320232`*^9, 
  3.9710065716286125`*^9}, {3.9710070682615585`*^9, 3.971007095419674*^9}, {
  3.97101474815493*^9, 3.971014772026308*^9}, {3.971015075705839*^9, 
  3.9710150895117035`*^9}, {3.9778465933095837`*^9, 
  3.977846595328287*^9}},ExpressionUUID->"edbd3f8e-e1c7-2746-8310-\
32a2bbab6f88"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Theorem (Isotypic decomposition of the tensor product of multiple ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "d6606b09-1845-c04c-ad22-319a377e0ad8"],
 "-irreps)"
}], "Subsubsection",
 CellChangeTimes->{{3.971006141381256*^9, 3.971006148155653*^9}, {
  3.9710064104919815`*^9, 3.971006461362095*^9}, {3.971014803559967*^9, 
  3.9710148044087086`*^9}, {3.9779232308094883`*^9, 
  3.9779232310196877`*^9}},ExpressionUUID->"300d1668-0911-ab4e-a69d-\
afa63dd518bf"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H", 
     SubscriptBox["\[Lambda]", "1"]], ",", "...", ",", 
    SubscriptBox["H", 
     SubscriptBox["\[Lambda]", "d"]]}], TraditionalForm]],
  CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
   3.9630770753080597`*^9, 3.963077080156849*^9}, {3.9630886760630875`*^9, 
   3.9630886760630875`*^9}, {3.963334237475191*^9, 3.963334237475191*^9}, {
   3.96333432456596*^9, 3.9633343428223953`*^9}},
  TextAlignment->Center,ExpressionUUID->
  "a4065806-b610-054e-b22f-dcbc8dbb8d49"],
 " be ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "e8083c3a-5c2e-5947-ba1f-efc9a044b518"],
 "-irreps. Then"
}], "Text",
 CellChangeTimes->{{3.9710148553622265`*^9, 
  3.9710148633449*^9}},ExpressionUUID->"e5ecca4b-e428-9549-84a4-503629ea63e2"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["H", 
      SubscriptBox["\[Lambda]", "1"]], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
     SubscriptBox["H", 
      SubscriptBox["\[Lambda]", "d"]]}], "\[TildeFullEqual]", 
    RowBox[{
     UnderoverscriptBox["\[CirclePlus]", 
      RowBox[{"\[Mu]", "=", 
       RowBox[{"Max", "[", 
        RowBox[{"0", ",", 
         RowBox[{
          RowBox[{"2", "m"}], "-", "s"}]}], "]"}]}], "s"], 
     RowBox[{
      SubscriptBox["H", "\[Mu]"], "\[CircleTimes]", 
      RowBox[{
       SubscriptBox["Hom", "G"], "(", 
       RowBox[{
        SubscriptBox["H", "\[Mu]"], ",", 
        RowBox[{
         SubscriptBox["H", 
          SubscriptBox["\[Lambda]", "1"]], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
         SubscriptBox["H", 
          SubscriptBox["\[Lambda]", "d"]]}]}], ")"}]}]}]}], ","}], 
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
  3.9630770753080597`*^9, 3.963077080156849*^9}, {3.9630886760630875`*^9, 
  3.9630886760630875`*^9}, {3.963334237475191*^9, 3.963334237475191*^9}, {
  3.96333432456596*^9, 3.9633343428223953`*^9}, {3.9635025685698624`*^9, 
  3.963502589460739*^9}, {3.9648990659278145`*^9, 3.9648990728059845`*^9}, {
  3.9657345259987183`*^9, 3.9657345285015583`*^9}, {3.9710065399967213`*^9, 
  3.971006553243681*^9}, {3.971014869025137*^9, 3.9710149138404007`*^9}, {
  3.9710149540234833`*^9, 3.971014964251524*^9}},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"fad7b919-dee8-b44b-909e-d07cfe18fc5e"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"s", ":=", 
    RowBox[{
     SubscriptBox["\[Lambda]", "1"], "+", "\[Ellipsis]", "+", 
     SubscriptBox["\[Lambda]", "d"]}]}], TraditionalForm]],ExpressionUUID->
  "34f48a57-0828-614c-95f1-7751fe53c0ad"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", ":=", 
    RowBox[{"Max", "[", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Lambda]", "d"]}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"6541bf9f-403f-2748-a52f-7659e410501a"],
 ". Moreover, a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(", 
    RowBox[{
     SubscriptBox["H", "\[Mu]"], ",", 
     RowBox[{
      SubscriptBox["H", 
       SubscriptBox["\[Lambda]", "1"]], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
      SubscriptBox["H", 
       SubscriptBox["\[Lambda]", "d"]]}]}], ")"}], TraditionalForm]],
  CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
   3.9630770753080597`*^9, 3.963077080156849*^9}, {3.9630886760630875`*^9, 
   3.9630886760630875`*^9}, {3.963334237475191*^9, 3.963334237475191*^9}, {
   3.96333432456596*^9, 3.9633343428223953`*^9}, {3.9635025685698624`*^9, 
   3.963502589460739*^9}, {3.9648990659278145`*^9, 3.9648990728059845`*^9}, {
   3.9657345259987183`*^9, 3.9657345285015583`*^9}, {3.9710065399967213`*^9, 
   3.971006553243681*^9}, {3.971014869025137*^9, 3.9710149138404007`*^9}, {
   3.9710149540234833`*^9, 3.971014964251524*^9}},
  TextAlignment->Center,
  Background->None,ExpressionUUID->"d0d7b432-9bdc-c846-a97c-cedfb844bb0b"],
 " is given by the Clebsch-Gordan tensors ",
 Cell[BoxData[
  FormBox[
   RowBox[{"CG", "(", 
    RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}], TraditionalForm]],
  ExpressionUUID->"f965f716-35da-5a4c-b4b6-00f05e4e8673"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Lambda]", "d"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"281b5477-5c23-8d44-a43b-48f0fb24ba45"],
 ", and ",
 Cell[BoxData[
  FormBox["\[Gamma]", TraditionalForm]],ExpressionUUID->
  "3df24508-f1f3-4641-b198-5e22e91e6006"],
 " ranges over all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Gamma]", "1"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[Gamma]", "d"]}], ")"}], "\[Element]", 
     SuperscriptBox["\[CapitalLambda]", "d"]}]}], TraditionalForm]],
  ExpressionUUID->"05df0652-f558-1a44-a0cf-3cea37ab3ff7"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      SubscriptBox["\[Lambda]", "j"], "-", 
      SubscriptBox["\[Lambda]", 
       RowBox[{"j", "+", "1"}]]}], "\[RightBracketingBar]"}], "<=", 
    SubscriptBox["\[Gamma]", 
     RowBox[{"j", "+", "1"}]], "<=", 
    RowBox[{
     SubscriptBox["\[Lambda]", "j"], "+", 
     SubscriptBox["\[Lambda]", 
      RowBox[{"j", "+", "1"}]]}]}], TraditionalForm]],ExpressionUUID->
  "81c173aa-b2cc-db4e-bcd6-4f2351062630"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Gamma]", "d"], "=", "\[Mu]"}], TraditionalForm]],
  ExpressionUUID->"b3766896-66d1-3946-ba17-cb98a36fd2f6"],
 "."
}], "Text",
 CellChangeTimes->{{3.9660929300457573`*^9, 3.966093047346157*^9}, {
  3.9677354613386*^9, 3.967735497912756*^9}, {3.971014966848055*^9, 
  3.9710150108708324`*^9}, {3.9710150669306087`*^9, 3.9710150727486134`*^9}, {
  3.971015111565445*^9, 3.971015161614685*^9}, {3.977846582980732*^9, 
  3.977846589917078*^9}, {3.977846622134674*^9, 
  3.97784666045315*^9}},ExpressionUUID->"080ce997-ace6-614e-9f75-\
c54e4be23f67"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Remark", "Subsubsection",
 CellChangeTimes->{{3.971006747404461*^9, 3.971006749053339*^9}, {
   3.9710069051427784`*^9, 3.971006908904007*^9}, 
   3.9778461385807304`*^9},ExpressionUUID->"c6832814-53fa-2e49-bd90-\
c8efc291b991"],

Cell[TextData[{
 "The coordinates of the Clebsch-Gordan tensor in the angular momentum basis \
are well known. For any ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], ",", 
    SubscriptBox["\[Lambda]", "2"], ",", 
    RowBox[{
     SubscriptBox["\[Lambda]", "3"], "\[Element]", "\[CapitalLambda]"}]}], 
   TraditionalForm]],ExpressionUUID->"05b06487-13a6-fe48-8130-0b52320c0f27"],
 " and any ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "1"], ",", 
    SubscriptBox["m", "2"], ",", 
    RowBox[{
     SubscriptBox["m", "3"], "\[Element]", 
     TemplateBox[{},
      "Integers"]}]}], TraditionalForm]],ExpressionUUID->
  "5ff9db6b-536c-d04a-9341-d738ee9e9353"],
 ", denote by"
}], "Text",
 CellChangeTimes->{{3.971006949112484*^9, 3.971006967328972*^9}, {
  3.9710070085718346`*^9, 3.971007051351015*^9}, {3.971013070580021*^9, 
  3.9710130854220257`*^9}, {3.971013126048889*^9, 3.9710131270550156`*^9}, {
  3.9710131995006676`*^9, 3.9710132173894405`*^9}, {3.9710133498945255`*^9, 
  3.9710133526336517`*^9}, {3.977846145461401*^9, 3.9778461578710537`*^9}, {
  3.9779236250048676`*^9, 
  3.977923630979969*^9}},ExpressionUUID->"7b077ca8-0999-d64c-bb53-\
96abd82727b7"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"(", GridBox[{
      {
       SubscriptBox["\[Lambda]", "1"], 
       SubscriptBox["\[Lambda]", "2"], 
       SubscriptBox["\[Lambda]", "3"]},
      {
       SubscriptBox["m", "1"], 
       SubscriptBox["m", "2"], 
       SubscriptBox["m", "3"]}
     }], ")"}], "\[Element]", 
   TemplateBox[{},
    "Reals"]}], TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
   3.9630770753080597`*^9, 3.963077080156849*^9}, {3.9630886760630875`*^9, 
   3.9630886760630875`*^9}, {3.963334237475191*^9, 3.963334237475191*^9}, {
   3.96333432456596*^9, 3.9633343428223953`*^9}, {3.9635025685698624`*^9, 
   3.963502589460739*^9}, {3.9648990659278145`*^9, 3.9648990728059845`*^9}, {
   3.9657345259987183`*^9, 3.9657345285015583`*^9}, {3.9681523539586983`*^9, 
   3.968152420351982*^9}, {3.968152552203848*^9, 3.9681526612255497`*^9}, {
   3.971006737591732*^9, 3.9710067399290867`*^9}, {3.971006863156561*^9, 
   3.971006881008383*^9}, {3.9710069781897106`*^9, 3.971006979743969*^9}, {
   3.9710070200535927`*^9, 3.9710070456999893`*^9}, {3.9710130886461067`*^9, 
   3.9710130896048985`*^9}, 3.9710132029628105`*^9, {3.9778440303577824`*^9, 
   3.9778440409718895`*^9}},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"0f313ec2-a702-ec43-8504-0c0e6bc67ad9"],

Cell[TextData[{
 "the corresponding ",
 StyleBox["Clebsch-Gordan coefficient",
  FontSlant->"Italic"],
 ", which can be computed using the ClebschGordan function in Mathematica. \
Note that the Clebsch-Gordan coefficient is nonzero iff ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], "-", 
      SubscriptBox["\[Lambda]", "2"]}], "\[RightBracketingBar]"}], "<=", 
    SubscriptBox["\[Lambda]", "3"], "<=", 
    RowBox[{
     SubscriptBox["\[Lambda]", "1"], "+", 
     SubscriptBox["\[Lambda]", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "ad77c8ce-7138-9d40-bf50-1cbf221a3fbf"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", 
     SubscriptBox["m", "j"], "\[RightBracketingBar]"}], "<=", 
    SubscriptBox["\[Lambda]", "j"]}], TraditionalForm]],ExpressionUUID->
  "1b51c065-f12a-9148-a816-b953649c1e5e"],
 " for all ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "4ba6a310-de7b-1f41-a39c-160d388d101d"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "3"], "=", 
    RowBox[{
     SubscriptBox["m", "1"], "+", 
     SubscriptBox["m", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "b13c8f24-f5ad-fe43-b013-1724609ee239"],
 ". Then for any valid ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", ",", 
    RowBox[{"\[Gamma]", "\[Element]", 
     SuperscriptBox["\[CapitalLambda]", "d"]}]}], TraditionalForm]],
  ExpressionUUID->"51d78268-b75b-964f-aed8-3b8039e5cf0a"],
 ", we have in coordinates"
}], "Text",
 CellChangeTimes->{{3.9710130909515247`*^9, 3.971013095042532*^9}, {
   3.9710131314310246`*^9, 3.9710131327823067`*^9}, {3.9710132197187767`*^9, 
   3.9710132203108025`*^9}, {3.971013354571657*^9, 3.971013354886324*^9}, 
   3.971013740397934*^9, {3.9725622359635506`*^9, 3.972562268663*^9}, {
   3.977844052163862*^9, 3.977844072008341*^9}, {3.977846177310774*^9, 
   3.9778461948871193`*^9}, {3.9779233776763573`*^9, 
   3.9779233889421043`*^9}, {3.9780958032161465`*^9, 
   3.9780958098347073`*^9}},ExpressionUUID->"d4538447-fa8b-404c-be57-\
940811e9c282"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"CG", "(", 
     RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[Product]", 
       RowBox[{"j", "=", "1"}], 
       RowBox[{"d", "-", "1"}]], 
      RowBox[{"(", GridBox[{
         {
          SubscriptBox["\[Gamma]", "j"], 
          SubscriptBox["\[Lambda]", 
           RowBox[{"j", "+", "1"}]], 
          SubscriptBox["\[Gamma]", 
           RowBox[{"j", "+", "1"}]]},
         {
          SubscriptBox["s", "j"], 
          SubscriptBox["m", 
           RowBox[{"j", "+", "1"}]], 
          SubscriptBox["s", 
           RowBox[{"j", "+", "1"}]]}
        }], ")"}]}], "\[Element]", 
     RowBox[{
      SuperscriptBox[
       TemplateBox[{},
        "Reals"], 
       RowBox[{
        RowBox[{"2", 
         SubscriptBox["\[Lambda]", "1"]}], "+", "1"}]], "\[CircleTimes]", 
      "\[Ellipsis]", "\[CircleTimes]", 
      SuperscriptBox[
       TemplateBox[{},
        "Reals"], 
       RowBox[{
        RowBox[{"2", 
         SubscriptBox["\[Lambda]", "d"]}], "+", "1"}]], "\[CircleTimes]", 
      SuperscriptBox[
       TemplateBox[{},
        "Reals"], 
       RowBox[{
        RowBox[{"2", 
         SubscriptBox["\[Gamma]", "d"]}], "+", "1"}]]}]}]}], ","}], 
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
   3.9630770753080597`*^9, 3.963077080156849*^9}, {3.9630886760630875`*^9, 
   3.9630886760630875`*^9}, {3.963334237475191*^9, 3.963334237475191*^9}, {
   3.96333432456596*^9, 3.9633343428223953`*^9}, {3.9635025685698624`*^9, 
   3.963502589460739*^9}, {3.9648990659278145`*^9, 3.9648990728059845`*^9}, {
   3.9657345259987183`*^9, 3.9657345285015583`*^9}, {3.9681523539586983`*^9, 
   3.968152420351982*^9}, {3.968152552203848*^9, 3.9681526612255497`*^9}, {
   3.971006737591732*^9, 3.9710067399290867`*^9}, {3.971006863156561*^9, 
   3.971006881008383*^9}, {3.9710069781897106`*^9, 3.971006979743969*^9}, {
   3.9710133805749264`*^9, 3.971013414312376*^9}, 3.9710140215956345`*^9, {
   3.9725625184735107`*^9, 3.972562689140465*^9}, 3.9778462227172623`*^9},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"6dc2b178-b9d5-1e41-9bbe-cde46c2f45bb"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["s", "j"], ":=", 
    RowBox[{
     SubscriptBox["m", "1"], "+", "\[Ellipsis]", "+", 
     SubscriptBox["m", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "24b9ffc4-07e2-8d44-bb1a-7cd837613254"],
 ", and the free indices are ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "1"], ",", "\[Ellipsis]", ",", 
    SubscriptBox["m", "d"]}], TraditionalForm]],ExpressionUUID->
  "e82a1f0c-2fc2-4340-9a2d-c46b4e446a1b"],
 " along with the last index ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["s", "d"], TraditionalForm]],ExpressionUUID->
  "2f174180-8c15-cb48-be54-693d5822aaec"],
 ", which is completely determined by the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "j"], TraditionalForm]],ExpressionUUID->
  "90c8899d-b515-ab4b-9668-80b3f8439ea2"],
 ". Note that the Clebsch-Gordan tensor ",
 Cell[BoxData[
  FormBox[
   RowBox[{"CG", "(", 
    RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}], TraditionalForm]],
  ExpressionUUID->"6f90bbc4-ccec-c748-a23d-2b5ed5d446b0"],
 " is nonzero iff ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      SubscriptBox["\[Gamma]", "j"], "-", 
      SubscriptBox["\[Gamma]", 
       RowBox[{"j", "+", "1"}]]}], "\[RightBracketingBar]"}], "<=", 
    SubscriptBox["\[Lambda]", 
     RowBox[{"j", "+", "1"}]], "<=", 
    RowBox[{
     SubscriptBox["\[Gamma]", "j"], "+", 
     SubscriptBox["\[Gamma]", 
      RowBox[{"j", "+", "1"}]]}]}], TraditionalForm]],ExpressionUUID->
  "08fbd5a1-9157-0a4b-bcac-0b25bf999da7"],
 " for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "<=", "j", "<=", 
    RowBox[{"d", "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "33afe1d9-442d-ab4b-adbc-2f64a3ff76fa"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[LeftBracketingBar]", 
      SubscriptBox["m", "j"], "\[RightBracketingBar]"}], "<=", 
     SubscriptBox["\[Lambda]", "j"]}], " ", ",", 
    RowBox[{
     RowBox[{"\[LeftBracketingBar]", 
      SubscriptBox["s", "j"], "\[RightBracketingBar]"}], "<=", 
     SubscriptBox["\[Gamma]", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "ca3f0edc-ed7a-fe49-b13c-94a2eecaad71"],
 " for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "<=", "j", "<=", "d"}], TraditionalForm]],ExpressionUUID->
  "6623e79c-0c83-0640-bec1-ed7b6557a5f2"],
 ". Moreover, it is always the case that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", ",", "2"}], ")"}], 
     RowBox[{"CG", "(", 
      RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      SubscriptBox["\[Gamma]", "2"]], 
     RowBox[{"CG", "(", 
      RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"df76e79e-999d-a64d-8348-13726627bca5"],
 "."
}], "Text",
 CellChangeTimes->{{3.971014022953123*^9, 3.9710140233214607`*^9}, {
   3.972562424790661*^9, 3.9725624360710697`*^9}, {3.9725626857045383`*^9, 
   3.9725626939187527`*^9}, 3.972562745323324*^9, {3.978095850535099*^9, 
   3.97809590384062*^9}},ExpressionUUID->"8f2be3e5-9634-7d42-bf53-\
d2041db5a2fa"]
}, Open  ]],

