Cell[TextData[{
 "The isotypic data tree representing ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox["\[CirclePlus]", 
     RowBox[{"D", "=", "0"}], "3"], 
    RowBox[{
     SubscriptBox["Hom", "G"], "(", 
     RowBox[{
      SubscriptBox["H", "0"], ",", 
      RowBox[{
       SuperscriptBox["\[ScriptCapitalS]", "D"], "(", 
       SuperscriptBox["X", "*"], ")"}]}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0cc4a4b6-34de-b843-a6bf-b7143a51a54c"],
 " according to Eq. (1) is then"
}], "Text",
 CellChangeTimes->{{3.981120534388571*^9, 
