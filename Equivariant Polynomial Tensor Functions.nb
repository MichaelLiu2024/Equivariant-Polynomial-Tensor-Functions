3334a1f110a1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Definition (Young symmetrizer)", "Subsubsection",
 CellChangeTimes->{{3.971017265109833*^9, 
  3.9710172695365353`*^9}},ExpressionUUID->"ec754421-1876-1841-a70d-\
ecfff171c37f"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[Pi]", TraditionalForm]],ExpressionUUID->
  "19cdcca6-c963-b347-ac23-61979b6360b8"],
 " be an integer partition of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "\[Element]", "\[DoubleStruckCapitalN]"}], TraditionalForm]],
  ExpressionUUID->"5c8eccbc-fa6f-884f-a50a-ffa7060f590c"],
 ", and let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "\[Pi]"], TraditionalForm]],ExpressionUUID->
  "47344d47-b46a-8b44-ae50-bf368a375c67"],
 " be the associated standard Young tableau filled in English-reading order. \
Define"
}], "Text",
 CellChangeTimes->{{3.963085273008539*^9, 3.9630853669347687`*^9}, {
  3.963085433880514*^9, 3.9630854454088573`*^9}, {3.9630854793595467`*^9, 
  3.963085658336643*^9}, {3.9630880738647194`*^9, 3.9630881461384106`*^9}, {
  3.9630881908155403`*^9, 3.9630881949978237`*^9}, {3.963088676078766*^9, 
  3.963088676126631*^9}, {3.9631942978630543`*^9, 3.9631943001346855`*^9}, {
  3.9633315120444202`*^9, 3.9633315193775578`*^9}, {3.963332640347378*^9, 
  3.9633326762040615`*^9}, {3.963332719396036*^9, 3.963332719396036*^9}, {
  3.9646147627111797`*^9, 3.964614781978733*^9}, {3.964614999310545*^9, 
  3.9646150006784515`*^9}, {3.9665178153078747`*^9, 3.9665178170134144`*^9}, {
  3.971017413198841*^9, 3.9710174154541473`*^9}, {3.971282650763308*^9, 
  3.971282660315783*^9}, {3.9725649985141544`*^9, 3.972565009999399*^9}, {
  3.9779240354235*^9, 3.977924036427601*^9}},
 Background->None,ExpressionUUID->"8ec6c464-7d66-f74c-b360-280f2f695948"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["R", "\[Pi]"], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Sigma]", "\[Element]", 
       SubscriptBox["\[GothicCapitalS]", "d"]}], "|", 
      RowBox[{
      "\[Sigma]", " ", "preserves", " ", "every", " ", "row", " ", "of", " ", 
       SubscriptBox["T", "\[Pi]"]}]}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{
    SubscriptBox["C", "\[Pi]"], ":=", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Sigma]", "\[Element]", 
        SubscriptBox["\[GothicCapitalS]", "d"]}], "|", 
       RowBox[{
       "\[Sigma]", " ", "preserves", " ", "every", " ", "column", " ", "of", " ", 
        SubscriptBox["T", "\[Pi]"]}]}], "}"}], "."}]}]}], 
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
  3.9630770753080597`*^9, 3.963077080156849*^9}, {3.963085636997587*^9, 
  3.963085679066036*^9}, {3.9630859576108856`*^9, 3.9630859805296955`*^9}, {
  3.9630881179481335`*^9, 3.963088123609167*^9}, {3.963088676126631*^9, 
