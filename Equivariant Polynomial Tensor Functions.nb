a36212b38870"],

Cell["Constitutive modeling", "Text",
 CellChangeTimes->{{3.980955724969612*^9, 
  3.980955728466511*^9}},ExpressionUUID->"704fb4fa-c87b-9644-ba89-\
727759b0ef0d"]
