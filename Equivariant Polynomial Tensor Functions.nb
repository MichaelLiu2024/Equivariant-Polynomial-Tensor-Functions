      SubscriptBox["\[Lambda]", "d"]}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"6541bf9f-403f-2748-a52f-7659e410501a"],
 ". Moreover, a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(",
    RowBox[{
     SubscriptBox["H", "\[Mu]"], ",",
     RowBox[{
      SubscriptBox["H",
       SubscriptBox["\[Lambda]", "1"]], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]",
      SubscriptBox["H",
       SubscriptBox["\[Lambda]", "d"]]}]}], ")"}], TraditionalForm]],
  CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
   3.9630770753080597`*^9, 3.963077080156849*^9}, {3.9630886760630875`*^9,
