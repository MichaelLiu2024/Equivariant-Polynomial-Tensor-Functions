Cell[BoxData[{
 RowBox[{
  RowBox[{"SpinListToSpinTree", "[",
   RowBox[{"{",
    RowBox[{"\[Lambda]s_List", ",", "\[Gamma]s_List"}], "}"}], "]"}], ":=",
  "\[IndentingNewLine]",
  RowBox[{"If", "[", "\[IndentingNewLine]",
   RowBox[{
    RowBox[{
     RowBox[{"Depth", "[", "\[Lambda]s", "]"}], ">", "2"}], ",",
    "\[IndentingNewLine]",
    RowBox[{"SpinListToSpinTree", "[",
     RowBox[{"{",
      RowBox[{
       RowBox[{"SpinListToSpinTree",
        RowBox[{" ",
         RowBox[{"/@", " "}]}], "\[Lambda]s"}], ",", "\[Gamma]s"}], "}"}],
     "]"}], ",", "\[IndentingNewLine]",
    RowBox[{"Fold", "[",
     RowBox[{
      RowBox[{
       RowBox[{"Tree", "[",
        RowBox[{
         RowBox[{"Last",
          RowBox[{" ",
           RowBox[{"@", " "}]}], "#2"}], ",",
         RowBox[{"{",
          RowBox[{"#1", ",",
           RowBox[{"First",
            RowBox[{" ",
             RowBox[{"@", " "}]}], "#2"}]}], "}"}]}], "]"}], "&"}], ",",
      RowBox[{"First", "[", "\[Lambda]s", "]"}], ",",
      RowBox[{"Rest",
       RowBox[{" ",
        RowBox[{"@", " "}]}],
       RowBox[{"Transpose", "[",
        RowBox[{"{",
         RowBox[{"\[Lambda]s", ",", "\[Gamma]s"}], "}"}], "]"}]}]}], "]"}]}],
   "\[IndentingNewLine]", "]"}]}], "\n",
 RowBox[{
  RowBox[{"SpinListToSpinTree", "[", "\[Gamma]s_List", "]"}], ":=",
  RowBox[{"With", "[",
   RowBox[{
    RowBox[{"{",
     RowBox[{"\[Lambda]",
      RowBox[{" ",
       RowBox[{"=", " "}]}],
      RowBox[{"First",
       RowBox[{" ",
        RowBox[{"@", " "}]}], "\[Gamma]s"}]}], "}"}], ",",
    RowBox[{"If", "[",
     RowBox[{
      RowBox[{
       RowBox[{"Length", "[", "\[Gamma]s", "]"}], "==", "1"}], ",",
      RowBox[{"Tree", "[",
       RowBox[{"\[Lambda]", ",",
        RowBox[{"{", "\[Lambda]", "}"}]}], "]"}], ",",
      RowBox[{"Fold", "[",
       RowBox[{
        RowBox[{
         RowBox[{"Tree", "[",
          RowBox[{"#2", ",",
           RowBox[{"{",
            RowBox[{"#1", ",", "\[Lambda]"}], "}"}]}], "]"}], "&"}], ",",
        "\[Gamma]s"}], "]"}]}], "]"}]}], "]"}]}]}], "Input",
