  3.971006553243681*^9}},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"bd0453eb-7863-2240-9db9-2248ff8445de"],

Cell[TextData[{
 "Moreover, a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(",
    RowBox[{
     SubscriptBox["H",
      SubscriptBox["\[Gamma]", "2"]], ",",
     RowBox[{
      SubscriptBox["H",
       SubscriptBox["\[Lambda]", "1"]], "\[CircleTimes]",
      SubscriptBox["H",
       SubscriptBox["\[Lambda]", "2"]]}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"3770a4af-da40-fb40-8a9f-4244f2bd449d"],
 " is given by the single Clebsch-Gordan tensor ",
 Cell[BoxData[
  FormBox[
   RowBox[{"CG", "(",
    RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}], TraditionalForm]],
  ExpressionUUID->"787e46bb-0169-da4e-a26e-dea756109070"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", ":=",
    RowBox[{"(",
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",",
      SubscriptBox["\[Lambda]", "2"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"f0dc6c66-72e5-c147-8fef-a79265dfc2cb"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", ":=",
    RowBox[{"(",
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",",
      SubscriptBox["\[Gamma]", "2"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"0772298b-2155-764a-9d4e-4e92029d8ef6"],
 "."
}], "Text",
 CellChangeTimes->{{3.971006243931774*^9, 3.9710062670095043`*^9}, {
