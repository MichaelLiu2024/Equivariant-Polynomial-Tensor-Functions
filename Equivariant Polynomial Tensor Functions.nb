Cell[CellGroupData[{

Cell[TextData[{
 "Example 1 (Basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox["\[CirclePlus]", 
     RowBox[{"D", "=", "0"}], "3"], 
    RowBox[{
     SubscriptBox["Hom", "G"], "(", 
     RowBox[{
      SubscriptBox["H", "0"], ",", 
      RowBox[{
       SuperscriptBox["\[ScriptCapitalS]", "D"], "(", 
       RowBox[{
        SubscriptBox["H", "1"], "\[CirclePlus]", 
        SubscriptBox["H", "1"], "\[CirclePlus]", 
        SubscriptBox["H", "2"]}], ")"}]}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "061aab79-6295-1447-8921-c357b4d47606"],
 ")"
}], "Subsubsection",
 CellChangeTimes->{{3.980958974049465*^9, 3.980959020797922*^9}, {
  3.980959421662031*^9, 3.980959437618311*^9}, {3.9809595987087193`*^9, 
  3.980959620601492*^9}, {3.9809596760063477`*^9, 3.980959679174967*^9}, {
  3.9811180743046665`*^9, 3.9811180770669785`*^9}, {3.9811182055668087`*^9, 
  3.981118223276478*^9}, {3.98111981297056*^9, 3.9811198714131355`*^9}, {
  3.9811204064735928`*^9, 
  3.981120406601097*^9}},ExpressionUUID->"6d0d8038-7d5c-d44b-83ec-\
5f6675d1e548"],

Cell[TextData[{
 "Suppose we wish to enumerate a basis for the space of ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "e2414354-afa7-3943-8aff-edd67ee0db75"],
 "-invariant polynomials of degree at most ",
 Cell[BoxData[
  FormBox["3", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1fb831ca-97d7-7b4b-a3af-60d5cd5e4d1d"],
 " acting on two vectors and one harmonic tensor as inputs. In our setting, \
this corresponds to the data ",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["H", "1"], "\[CircleTimes]", 
       SuperscriptBox[
        TemplateBox[{},
         "Complexes"], "2"]}], ")"}], "\[CirclePlus]", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["H", "2"], "\[CircleTimes]", 
       SuperscriptBox[
        TemplateBox[{},
         "Complexes"], "1"]}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e30f5d71-c822-9944-9298-fc5b6c668b01"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Y", "=", 
    SubscriptBox["H", "0"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "da816978-360e-c54f-b019-29dd6002eafd"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"D", "=", "3"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "deca6e36-7faa-d34d-8420-fe45c93ee754"],
 ". We represent this data as follows."
}], "Text",
 CellChangeTimes->{{3.973426763249817*^9, 3.9734268646720257`*^9}, {
  3.97342691454208*^9, 3.973426915037445*^9}, {3.9734269504216614`*^9, 
  3.9734269514417133`*^9}, {3.9737740898468895`*^9, 3.9737741174629593`*^9}, {
