Cell[CellGroupData[{

Cell["\<\
Lemma A1 (Identifying the covariant module with the space of equivariant \
polynomial functions)\
\>", "Subsubsection",
 CellChangeTimes->{{3.9710035146751137`*^9, 3.971003536956476*^9}, {
  3.9725632765974045`*^9,
  3.972563310615017*^9}},ExpressionUUID->"89ae3a93-648e-fc44-8cc6-\
be738a091180"],

Cell["There is an isomorphism of vector spaces", "Text",
 CellChangeTimes->{{3.971003544616583*^9, 3.971003550193693*^9}, {
  3.9710035847269936`*^9, 3.97100359680641*^9}, {3.9725633003890953`*^9,
  3.97256330118589*^9}},ExpressionUUID->"d47b1d21-5b95-4d4b-97f6-\
aaaf53f4fc6b"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox[
    RowBox[{"(",
     RowBox[{
      RowBox[{"\[ScriptCapitalS]", "(",
       SuperscriptBox["X", "*"], ")"}], "\[CircleTimes]", "Y"}], ")"}], "G"],
   "\[TildeFullEqual]",
   RowBox[{"{",
    RowBox[{
    "equivariant", " ", "polynomial", " ", "functions", " ", "from", " ", "X",
      " ", "to", " ", "Y"}], "}"}]}], TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.971002790255043*^9, 3.9710027918797283`*^9}, {
  3.971002973488472*^9, 3.971002973663662*^9}, {3.97100307613105*^9,
