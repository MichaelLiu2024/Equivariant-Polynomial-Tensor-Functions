Cell[CellGroupData[{

Cell["Definition (Iterated Clebsch-Gordan tensor)", "Subsubsection",
 CellChangeTimes->{{3.971006577122019*^9, 3.9710065823838882`*^9}, {
  3.977844237099571*^9,
  3.9778442379579525`*^9}},ExpressionUUID->"37b0adf8-ad6d-4442-ac5b-\
a3ed53d92f0f"],

Cell[TextData[{
 "For any ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Lambda]", ":=",
     RowBox[{"(",
      RowBox[{
       SubscriptBox["\[Lambda]", "1"], ",", "\[Ellipsis]", ",",
       SubscriptBox["\[Lambda]", "d"]}], ")"}]}], ",",
    RowBox[{"\[Gamma]", ":=",
     RowBox[{
      RowBox[{"(",
       RowBox[{
        SubscriptBox["\[Gamma]", "1"], ",", "\[Ellipsis]", ",",
        SubscriptBox["\[Gamma]", "d"]}], ")"}], "\[Element]",
      SuperscriptBox["\[CapitalLambda]", "d"]}]}]}], TraditionalForm]],
  ExpressionUUID->"6eb888ab-d37f-b64e-b5b7-b9dcc4d08c5b"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"],
    RowBox[{" ",
     RowBox[{"=", " "}]}],
    SubscriptBox["\[Gamma]", "1"]}], TraditionalForm]],ExpressionUUID->
  "ceee791f-bf4d-2840-af91-05fac5c44675"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]",
     RowBox[{
      SubscriptBox["\[Lambda]", "j"], "-",
      SubscriptBox["\[Lambda]",
       RowBox[{"j", "+", "1"}]]}], "\[RightBracketingBar]"}], "<=",
    SubscriptBox["\[Gamma]",
     RowBox[{"j", "+", "1"}]], "<=",
    RowBox[{
     SubscriptBox["\[Lambda]", "j"], "+",
     SubscriptBox["\[Lambda]",
      RowBox[{"j", "+", "1"}]]}]}], TraditionalForm]],ExpressionUUID->
  "134a9c9f-31bb-3443-9638-558266e07837"],
 " for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "<=", "j", "<=",
    RowBox[{"d", "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "f3fa4115-e620-bb45-92a7-f5a5dac0b53f"],
 ", the ",
 StyleBox["Clebsch-Gordan tensor",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"CG", "(",
    RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}], TraditionalForm]],
  ExpressionUUID->"8ec767f2-4789-f445-80e1-2bc5bdb49314"],
 " is the unique element in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(",
     RowBox[{
      SubscriptBox["H",
       SubscriptBox["\[Lambda]", "1"]], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]",
      SubscriptBox["H",
       SubscriptBox["\[Lambda]", "d"]], "\[CircleTimes]",
      SubscriptBox["H",
       SubscriptBox["\[Gamma]", "d"]]}], ")"}], "G"], TraditionalForm]],
  ExpressionUUID->"157ed7d4-650f-754e-b253-d0e9d6cb9883"],
 " with the tensor train factorization"
}], "Text",
 CellChangeTimes->{{3.971006619536833*^9, 3.9710066430040836`*^9}, {
  3.9710066781060104`*^9, 3.9710067221026955`*^9}, {3.9710069235613403`*^9,
  3.97100692749271*^9}, {3.9710137024596615`*^9, 3.9710137210363636`*^9}, {
  3.971015845836649*^9, 3.9710158531522713`*^9}, {3.972562389141632*^9,
  3.9725623939795647`*^9}, {3.9778441120931396`*^9, 3.977844113449047*^9}, {
  3.9778453245612373`*^9, 3.9778453520887356`*^9}, {3.977845788118374*^9,
  3.977845828185961*^9}, {3.977845932243593*^9, 3.9778460371561527`*^9}, {
  3.9779231124167423`*^9,
  3.9779231197816925`*^9}},ExpressionUUID->"0b18156d-e149-2f47-99c9-\
de0c82bc57b0"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"CG", "(",
     RowBox[{"\[Lambda]", ",", "\[Gamma]"}], ")"}], ":=",
    RowBox[{
     UnderoverscriptBox["\[Product]",
      RowBox[{"j",
       RowBox[{" ",
        RowBox[{"=", " "}]}], "1"}],
      RowBox[{"d", "-", "1"}]],
     RowBox[{"CG", "(",
      RowBox[{
       RowBox[{"(",
        RowBox[{
         SubscriptBox["\[Gamma]", "j"], ",",
         SubscriptBox["\[Lambda]",
          RowBox[{"j", "+", "1"}]]}], ")"}], ",",
       RowBox[{"(",
        RowBox[{
         SubscriptBox["\[Gamma]", "j"], ",",
         SubscriptBox["\[Gamma]",
          RowBox[{"j", "+", "1"}]]}], ")"}]}], ")"}]}]}], ","}],
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.963076926654972*^9, 3.9630769619863453`*^9}, {
   3.9630770753080597`*^9, 3.963077080156849*^9}, {3.9630886760630875`*^9,
   3.9630886760630875`*^9}, {3.963334237475191*^9, 3.963334237475191*^9}, {
   3.96333432456596*^9, 3.9633343428223953`*^9}, {3.9635025685698624`*^9,
   3.963502589460739*^9}, {3.9648990659278145`*^9, 3.9648990728059845`*^9}, {
   3.9657345259987183`*^9, 3.9657345285015583`*^9}, {3.9681523539586983`*^9,
   3.968152420351982*^9}, {3.968152552203848*^9, 3.9681526612255497`*^9}, {
   3.971006737591732*^9, 3.9710067399290867`*^9}, {3.971006863156561*^9,
   3.971006881008383*^9}, {3.9710069781897106`*^9, 3.971006979743969*^9}, {
   3.9710133805749264`*^9, 3.971013414312376*^9}, 3.9710140215956345`*^9, {
   3.971015736833439*^9, 3.971015792786257*^9}, {3.9725627799813786`*^9,
   3.9725627805814304`*^9}, 3.9725628765923386`*^9, 3.977846070729208*^9},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"34fcf0ae-0fd3-0d42-a402-1003015f8a93"],

