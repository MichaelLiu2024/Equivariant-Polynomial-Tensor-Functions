   3.981120822110779*^9}},ExpressionUUID->"93191cf2-6d8a-994d-9a31-\
236c8e77774e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"polys", "=", 
   RowBox[{"Chop", "@", 
    RowBox[{"FullSimplify", "@", 
     RowBox[{"Flatten", "@", 
      RowBox[{"SphericalBasisToMonomialBasis", "@", 
       RowBox[{"EvaluateVectorSpaceBases", "[", 
        RowBox[{"alg", ",", 
         RowBox[{"generateVariables", "[", 
          RowBox[{"\[Lambda]s", ",", "m\[Lambda]s"}], "]"}]}], 
        "]"}]}]}]}]}]}], ";"}]], "Input",
