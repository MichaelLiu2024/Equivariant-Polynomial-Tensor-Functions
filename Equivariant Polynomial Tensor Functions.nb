   3.9623649285245*^9}, {3.962364984441248*^9, 3.962364988954792*^9}, 
   3.9630899195097256`*^9, {3.964053090357477*^9, 3.9640531100814342`*^9}, {
   3.964053321424219*^9, 3.964053384687031*^9}, {3.964053626438263*^9, 
