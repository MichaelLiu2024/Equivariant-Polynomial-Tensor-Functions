Cell["Proof", "Subsubsection",
 CellChangeTimes->{{3.980958203962511*^9, 
  3.980958204444048*^9}},ExpressionUUID->"d2784090-2060-3640-a993-\
dd18785894c2"],

Cell["See Appendix B.", "Text",
 CellChangeTimes->{{3.9809582064489975`*^9, 3.980958222272806*^9}, {
  3.9809585107411785`*^9, 
  3.980958510853672*^9}},ExpressionUUID->"8790bd7e-560f-9441-86dc-\
7faeadd391c6"]
