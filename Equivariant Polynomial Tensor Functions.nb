Cell[BoxData[
 RowBox[{
  RowBox[{"PivotColumns", "[",
   RowBox[{"matrix_", "?", "MatrixQ"}], "]"}], ":=", "\n", " ",
  RowBox[{"Module", "[", "\n", "  ",
   RowBox[{
    RowBox[{"{",
     RowBox[{"q", ",", "r", ",", "p"}], "}"}], ",", "\n", "  ", "\n", "  ",
    RowBox[{
     RowBox[{"If", "[",
      RowBox[{
       RowBox[{"matrix", "==",
        RowBox[{"{",
         RowBox[{"{", "}"}], "}"}]}], ",",
       RowBox[{"Return", "[",
        RowBox[{"{", "}"}], "]"}]}], "]"}], ";", "\n", "  ", "\n", "  ",
     RowBox[{
      RowBox[{"{",
       RowBox[{"q", ",", "r", ",", "p"}], "}"}],
      RowBox[{" ",
       RowBox[{"=", " "}]}],
      RowBox[{"QRDecomposition", "[",
       RowBox[{"matrix", ",",
        RowBox[{"Pivoting", "->", "True"}]}], "]"}]}], ";", "\n", "  ", "\n",
     "  ",
     RowBox[{"r", " ", "=", " ",
      RowBox[{"Abs", "@",
       RowBox[{"Diagonal", " ", "@", " ", "r"}]}]}], ";", "\n", "  ",
     RowBox[{"p",
      RowBox[{" ",
       RowBox[{"=", " "}]}],
      RowBox[{
       RowBox[{"PermutationMatrix", "[", "p", "]"}],
       "[", "\"\<PermutationList\>\"", "]"}]}], ";", "\n", "  ", "\n", "  ",
     RowBox[{"Take", "[",
      RowBox[{"p", ",",
       RowBox[{"Count", "[",
        RowBox[{"r", ",",
         RowBox[{"i_", "/;",
          RowBox[{"i", ">=",
           RowBox[{
            RowBox[{"10", "^",
             RowBox[{"-", "10"}]}], "*",
            RowBox[{"Max",
             RowBox[{" ",
              RowBox[{"@", " "}]}], "r"}]}]}]}]}], "]"}]}], "]"}]}]}], "\n",
   " ", "]"}]}]], "Input",
 CellChangeTimes->{{3.981559874683441*^9,
  3.981559875752136*^9}},ExpressionUUID->"cb2cc4e8-6cf7-1848-82e7-\
aec6ee1002db"],

