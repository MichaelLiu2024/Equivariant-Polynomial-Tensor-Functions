Cell["The isotypic data tree stores the following information:", "Text",
 CellChangeTimes->{{3.973080922141182*^9, 3.9730809315510693`*^9}, {
  3.973081286546116*^9, 3.9730812889456177`*^9}, {3.9730817367238007`*^9,
