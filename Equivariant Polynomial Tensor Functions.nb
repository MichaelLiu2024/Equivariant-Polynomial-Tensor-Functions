   3.978101339869423*^9}},ExpressionUUID->"0cd0baf1-fbdd-2d46-8da0-\
db155932bd53"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox["x", 
    RowBox[{"\[CircleTimes]", "D"}]], "=", 
   RowBox[{
    UnderscriptBox["\[CirclePlus]", 
     SubscriptBox[
      RowBox[{"(", 
       SubscriptBox["d", "\[Lambda]"], ")"}], "\[Lambda]"]], 
    RowBox[{
     RowBox[{"(", GridBox[{
        {"D"},
        {
         SubscriptBox[
          RowBox[{"(", 
           SubscriptBox["d", "\[Lambda]"], ")"}], "\[Lambda]"]}
       }], ")"}], 
     RowBox[{"(", 
      RowBox[{
       UnderscriptBox["\[CircleTimes]", "\[Lambda]"], 
       SubsuperscriptBox["x", "\[Lambda]", 
        RowBox[{"\[CircleTimes]", 
         SubscriptBox["d", "\[Lambda]"]}]]}], ")"}]}]}]}], 
  TraditionalForm]], "DisplayFormula",
