Cell[CellGroupData[{

Cell["Lemma (Nakayama)", "Subsubsection",
 CellChangeTimes->{{3.970591204020267*^9,
  3.970591208831131*^9}},ExpressionUUID->"7203615c-537e-f94b-ac08-\
907b85042dc3"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M",
    RowBox[{" ",
     RowBox[{"=", " "}]}],
    RowBox[{
     UnderscriptBox["\[CirclePlus]",
      RowBox[{"D", "\[Element]",
       SubscriptBox["\[DoubleStruckCapitalN]", "0"]}]],
     SubscriptBox["M", "D"]}]}], TraditionalForm]],ExpressionUUID->
  "281054b4-0ca7-174a-a1ca-de3828b19f6a"],
 " be a finitely generated graded module over a graded ring ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R",
    RowBox[{" ",
     RowBox[{"=", " "}]}],
    RowBox[{
     UnderscriptBox["\[CirclePlus]",
      RowBox[{"D", "\[Element]",
       SubscriptBox["\[DoubleStruckCapitalN]", "0"]}]],
     SubscriptBox["R", "D"]}]}], TraditionalForm]],ExpressionUUID->
  "74c0f393-b679-9b46-adae-add79f0b850e"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["R", "0"],
    RowBox[{" ",
     RowBox[{"=", " "}]}],
    TemplateBox[{},
     "Reals"]}], TraditionalForm]],ExpressionUUID->
  "63960a69-f1c9-e94f-97b2-fd3e46e4c541"],
 ". Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", ":=",
    RowBox[{
     UnderscriptBox["\[CirclePlus]",
      RowBox[{"D", "\[Element]", "\[DoubleStruckCapitalN]"}]],
     SubscriptBox["R", "D"]}]}], TraditionalForm]],ExpressionUUID->
  "8d66ed9f-989e-d54f-9929-da25c39945a6"],
 " be the ideal generated by the positively graded elements of ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "fe2ac0b8-8868-cf4e-868c-5982ea3dfb61"],
 ". Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "\[SubsetEqual]", "M"}], TraditionalForm]],ExpressionUUID->
  "7839dead-08ec-a843-b059-b92cf209cc25"],
 ". Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"L", "/", "I"}], " ", "M"}], TraditionalForm]],ExpressionUUID->
  "90532a83-6835-e546-99e4-6879c9dcba5d"],
 " is a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"M", "/", "I"}], " ", "M"}], TraditionalForm]],ExpressionUUID->
  "c45c615b-8c30-b44b-b0e2-512349895672"],
 " as an ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{},
    "Reals"], TraditionalForm]],ExpressionUUID->
  "933112a4-a0c2-9342-b041-19b69863a1ae"],
 "-vector space iff ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "7b94745e-c5d7-d646-a631-fec499646f59"],
 " is a minimal generating set for ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "a9681b16-b0e2-1046-8288-4c82006570f8"],
 " as an ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "1d441cd6-7018-e248-90cd-f113adb6201a"],
 "-module."
}], "Text",
 CellChangeTimes->{{3.962129668612282*^9, 3.9621296747287807`*^9}, {
   3.9621297503205833`*^9, 3.9621298237213955`*^9}, {3.9621299280910873`*^9,
   3.962129971367256*^9}, {3.9621301573876896`*^9, 3.962130157771385*^9}, {
   3.962130525252926*^9, 3.9621305512452106`*^9}, {3.962131627882841*^9,
   3.9621316290302677`*^9}, {3.962132876754242*^9, 3.9621329044074745`*^9}, {
   3.9621329541851845`*^9, 3.9621330024194717`*^9}, {3.9621330689469223`*^9,
   3.9621331346068497`*^9}, {3.962133215232111*^9, 3.9621332286006145`*^9}, {
   3.9621835164727383`*^9, 3.9621836385589542`*^9}, {3.962183959240654*^9,
   3.9621839860922527`*^9}, {3.96218406150753*^9, 3.9621840622742386`*^9}, {
   3.962184159804365*^9, 3.9621841715267067`*^9}, {3.9622077331986465`*^9,
   3.962207733320841*^9}, {3.9622112383946266`*^9, 3.9622112384842834`*^9}, {
   3.9622790322498856`*^9, 3.9622790978275223`*^9}, {3.962279151335987*^9,
   3.962279159762314*^9}, {3.9623639689226074`*^9, 3.9623639689352417`*^9}, {
