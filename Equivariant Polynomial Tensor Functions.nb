Cell[TextData[{
 "Next, we contract the tensor tree with the Young-symmetrized SSYT monomial \
in the input tensors to obtain an equivariant polynomial. This produces a \
basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Hom", "G"], "(", 
    RowBox[{
     SubscriptBox["H", "0"], ",", 
     RowBox[{
      SuperscriptBox["\[ScriptCapitalS]", "3"], "(", 
      RowBox[{
       SubscriptBox["H", "1"], "\[CirclePlus]", 
       SubscriptBox["H", "2"]}], ")"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"978cd5ea-4baa-344f-9e96-027ca6e13232"],
 "."
}], "Text",
 CellChangeTimes->{{3.973080766972595*^9, 3.973080787698328*^9}, 
   3.9730815967630863`*^9, {3.973081656553087*^9, 3.973081683886854*^9}, {
   3.973603476166535*^9, 3.9736035264686947`*^9}, {3.974197786033388*^9, 
   3.974197962894581*^9}, {3.9741980368336697`*^9, 3.9741980562500553`*^9}, {
