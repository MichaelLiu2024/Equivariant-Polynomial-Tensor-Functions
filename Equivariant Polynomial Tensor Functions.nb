   3.962283887351219*^9, 3.9622839432175922`*^9}, {3.9622842597635403`*^9, 
   3.962284301884348*^9}, {3.9623657985460453`*^9, 3.9623658078038883`*^9}, {
   3.962365842093237*^9, 3.962365867016329*^9}, {3.9623661174686966`*^9, 
   3.9623662941804485`*^9}, {3.9623663424415874`*^9, 
   3.9623663919513874`*^9}, {3.962366431921814*^9, 3.9623664327757225`*^9}, {
   3.962366583168289*^9, 3.9623665849824276`*^9}, {3.962366639284136*^9, 
   3.962366648090788*^9}, {3.964056393157261*^9, 3.964056438257578*^9}, {
   3.964056509466675*^9, 3.964056523586031*^9}, {3.964056713514305*^9, 
   3.9640567297682743`*^9}, {3.9640567647614536`*^9, 
   3.9640568513858967`*^9}, {3.9640568897679176`*^9, 
   3.9640569233959064`*^9}, {3.9641009635098763`*^9, 3.96410096375881*^9}, {
   3.96410105766667*^9, 3.9641010585659847`*^9}, 3.9641014045809174`*^9, {
   3.9641014721579323`*^9, 3.9641014721579323`*^9}, {3.964101670059269*^9, 
   3.9641016714342957`*^9}, {3.9641017033857307`*^9, 3.964101712418438*^9}, {
   3.9652982486673985`*^9, 3.9652982486673985`*^9}},
 Background->None,ExpressionUUID->"c2ec06f9-fb92-864c-8613-c68f045f8957"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["R", 
    RowBox[{"D", "+", "1"}]], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox["I", 
      RowBox[{"D", "+", "1"}]], "\[SubsetEqual]", 
     RowBox[{
      RowBox[{
       SubscriptBox["Span", 
        TemplateBox[{},
         "Reals"]], "(", 
       SubscriptBox["L", 
        RowBox[{"D", "+", "1"}]], ")"}], "+", 
      SubscriptBox[
       RowBox[{"(", 
        SuperscriptBox["I", "2"], ")"}], 
       RowBox[{"D", "+", "1"}]]}]}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["Span", 
       TemplateBox[{},
        "Reals"]], "(", 
      SubscriptBox["L", 
       RowBox[{"D", "+", "1"}]], ")"}], "+", 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       RowBox[{"1", "<=", 
        RowBox[{"D", "'"}], "<=", "D"}]], 
      RowBox[{
       SubscriptBox["I", 
        RowBox[{"D", "'"}]], 
       RowBox[{
        SubscriptBox["I", 
         RowBox[{"D", "+", "1", "-", 
          RowBox[{"D", "'"}]}]], "."}]}]}]}]}]}], 
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.962283946202675*^9, 3.962284042293188*^9}, {
   3.9622840830090313`*^9, 3.962284096576391*^9}, {3.9622841747199287`*^9, 
   3.9622841748266735`*^9}, {3.962364940891279*^9, 3.9623649418560505`*^9}, {
   3.962366536799816*^9, 3.9623665373322296`*^9}, {3.9623665724531975`*^9, 
   3.9623665895186005`*^9}, {3.962366651790884*^9, 3.962366665373993*^9}, 
   3.9623667123890247`*^9, {3.964057000237276*^9, 3.9640570095897675`*^9}, {
   3.9640570764651394`*^9, 3.9640570789379864`*^9}, {3.9641017878986683`*^9, 
   3.9641017887467117`*^9}},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"83009ba3-e643-3240-892d-91a32f8e06d9"],

Cell[TextData[{
 "Clearly, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["Span", 
      TemplateBox[{},
       "Reals"]], "(", 
     SubscriptBox["L", 
      RowBox[{"D", "+", "1"}]], ")"}], "\[SubsetEqual]", 
    RowBox[{
     TemplateBox[{},
      "Reals"], "[", "L", "]"}]}], TraditionalForm]],ExpressionUUID->
  "a2a4d8d0-2aa6-eb45-8202-c949544c8f25"],
 ", and by the inductive hypothesis, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["I", "1"], ",", "...", ",", 
    RowBox[{
     SubscriptBox["I", "D"], "\[SubsetEqual]", 
     SubscriptBox["R", 
      RowBox[{"<=", "D"}]], "\[SubsetEqual]", 
     RowBox[{
      TemplateBox[{},
       "Reals"], "[", "L", "]"}]}]}], TraditionalForm]],ExpressionUUID->
  "eb7e5a53-9761-d740-9a60-3974c5c3c91b"],
 ". Thus, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "=", 
    RowBox[{
     TemplateBox[{},
      "Reals"], "[", "L", "]"}]}], TraditionalForm]],ExpressionUUID->
  "3ce41928-ba57-2c49-82ae-624192a585d6"],
 ". To see that ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "91d560c0-5a77-0844-8d12-bdeab3cc39f2"],
 " is minimal, note that if any ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "\[SubsetEqual]", "I"}], TraditionalForm]],ExpressionUUID->
  "f295fe5c-bc42-8443-95bd-76497dbbf85f"],
 " generates ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "fc88c714-d435-3040-a47a-5d354142e2ef"],
 " as an ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{},
    "Reals"], TraditionalForm]],ExpressionUUID->
  "bfe760c8-4be2-6044-8965-2393fbd43554"],
 "-algebra, then ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "1dd76f17-5a91-814a-be34-95b34ff526a0"],
 " generates ",
 Cell[BoxData[
  FormBox["I", TraditionalForm]],ExpressionUUID->
  "ae327e47-0f3f-e248-9300-9fad6fb0dbe6"],
 " as an ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "9cb86129-f4f7-a845-85ba-393113afd572"],
 "-module, so ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "/", 
    SuperscriptBox["I", "2"]}], TraditionalForm]],ExpressionUUID->
  "d3237dda-243f-2f49-8377-3808f0badb10"],
 " generates ",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", "/", 
    SuperscriptBox["I", "2"]}], TraditionalForm]],ExpressionUUID->
  "7db26e7b-31c0-9041-8115-70afafcdcc92"],
 " as an ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{},
    "Reals"], TraditionalForm]],ExpressionUUID->
  "599c6805-6918-8048-b208-70493e0b0442"],
 "-module. Thus, since our given ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "7e939210-f325-664c-826e-5adf8f4d2589"],
 " makes ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "/", 
    SuperscriptBox["I", "2"]}], TraditionalForm]],ExpressionUUID->
  "4aa5c05d-c079-6841-92c4-93cdb577aa69"],
 " a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", "/", 
    SuperscriptBox["I", "2"]}], TraditionalForm]],ExpressionUUID->
  "e4b1d958-5749-7b47-bc83-2bcc0227adc1"],
 ", our given ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "5cf00091-d101-864e-bd92-6628a6206975"],
 " is a minimal generating set for ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
