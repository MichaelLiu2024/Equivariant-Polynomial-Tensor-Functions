Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", ":=", 
    RowBox[{"SO", "(", "3", ")"}]}], TraditionalForm]],ExpressionUUID->
  "3ebdb0ab-a661-8949-a2d5-2b2e374a93b9"],
 ", let ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "78239771-ac86-f74f-b4da-73a854fbe78a"],
 " and ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a225fcec-0e2c-ec4c-a14f-538348705809"],
 " be finite dimensional ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "c8400873-28cf-d940-9195-e82353368477"],
 "-representations, let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", ":=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"\[ScriptCapitalS]", "(", 
        SuperscriptBox["X", "*"], ")"}], "\[CircleTimes]", "Y"}], ")"}], 
     "G"]}], TraditionalForm]], "DisplayFormula",
  CellChangeTimes->{{3.971002790255043*^9, 3.9710027918797283`*^9}, {
   3.971002973488472*^9, 3.971002973663662*^9}, {3.97100307613105*^9, 
   3.9710030766647224`*^9}},
  TextAlignment->Center,ExpressionUUID->
  "89ed2873-2dec-a149-aeac-df595fc47432"],
 " be the covariant module of ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "64cea1ee-ad20-7c45-b022-14ee5d6bfb75"],
 "-equivariant polynomials from ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],
  FontSlant->"Plain",ExpressionUUID->"5d5b64d0-0a1b-8440-8d96-f196423773da"],
 " to ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],
  FontSlant->"Plain",ExpressionUUID->"f21b44b7-f9f5-f141-834d-31543074af4b"],
 ", and let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", ":=", 
    SuperscriptBox[
     RowBox[{"\[ScriptCapitalS]", "(", 
      SuperscriptBox["X", "*"], ")"}], "G"]}], TraditionalForm]],
  ExpressionUUID->"788adc12-2bf2-4a4f-aeba-84b97c358824"],
 " be the ",
 "invariant algebra of",
 " ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "bd5271c0-a298-c14a-9093-8af6ba81ca4d"],
 "-invariant polynomials on ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8153191b-d990-624c-b3a4-6db228c5dcfd"],
 ". Let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", "\[Lambda]"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4798a7a5-5545-c64b-9035-da2c178abd59"],
 " be the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"SO", "(", "3", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4d67aa08-fb7b-2f48-91b0-7033061d767d"],
 " irrep with label ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Lambda]", "\[Element]", "\[CapitalLambda]"}], ":=", 
    TemplateBox[{},
     "NonNegativeIntegers"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a21fe2be-9a26-2d43-bff3-c92193452295"],
 ", and let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", "\[TildeFullEqual]", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", 
      RowBox[{"\[Lambda]", "\[Element]", "\[CapitalLambda]"}]], 
     RowBox[{
      SubscriptBox["H", "\[Lambda]"], "\[CircleTimes]", 
      RowBox[{
       SubscriptBox["Hom", "G"], "(", 
       RowBox[{
        SubscriptBox["H", "\[Lambda]"], ",", "X"}], ")"}]}]}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7437bd76-c6ec-b244-b3b2-1ab8b408fa39"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Y", "\[TildeFullEqual]", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", 
      RowBox[{"\[Lambda]", "\[Element]", "\[CapitalLambda]"}]], 
     RowBox[{
      SubscriptBox["H", "\[Lambda]"], "\[CircleTimes]", 
      RowBox[{
       SubscriptBox["Hom", "G"], "(", 
       RowBox[{
        SubscriptBox["H", "\[Lambda]"], ",", "Y"}], ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"22d6aa75-873c-4a41-b6da-e40754889b0e"],
 " be the isotypic decompositions of ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1f4a3317-3887-b549-b61a-a0e221af2331"],
 " and ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "235316c3-252c-464a-b02c-543bd04cceee"],
 "."
}], "Text",
 CellChangeTimes->{{3.9710026056734905`*^9, 3.9710026131388264`*^9}, {
