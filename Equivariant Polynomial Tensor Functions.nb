Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox[
    RowBox[{"(", 
     RowBox[{"I", " ", "M"}], ")"}], "D"], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"I", " ", "M"}], "\[Intersection]", 
     SubscriptBox["M", "D"]}], "=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["\[Sum]", 
       RowBox[{"1", "<=", 
        RowBox[{"D", "'"}], "<=", "D"}]], 
      RowBox[{
       SubscriptBox["R", 
        RowBox[{"D", "'"}]], 
       SubscriptBox["M", 
        RowBox[{"D", "-", 
         RowBox[{"D", "'"}]}]]}]}], "=", 
     RowBox[{"Span", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{
           SubscriptBox["r", 
            RowBox[{"D", "'"}]], 
           SubscriptBox["m", 
            RowBox[{"D", "-", 
             RowBox[{"D", "'"}]}]]}], "|", 
          RowBox[{"1", "<=", 
           RowBox[{"D", "'"}], "<=", "D"}]}], ",", 
         RowBox[{
          SubscriptBox["r", 
           RowBox[{"D", "'"}]], "\[Element]", 
          SubscriptBox["\[ScriptCapitalR]", 
           RowBox[{"D", "'"}]]}], ",", 
         RowBox[{
          SubscriptBox["m", 
           RowBox[{"D", "-", 
            RowBox[{"D", "'"}]}]], "\[Element]", 
          SubscriptBox["\[ScriptCapitalM]", 
           RowBox[{"D", "-", 
            RowBox[{"D", "'"}]}]]}]}], "}"}], "."}]}]}]}]}], 
  TraditionalForm]], "DisplayFormula",
