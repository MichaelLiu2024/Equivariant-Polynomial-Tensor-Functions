 TextAlignment->Center,
 Background->None,ExpressionUUID->"71491024-e4c3-3e41-b3a3-4a5e6e75c8ce"],

Cell[TextData[{
 "we can proceed degree-by-degree to obtain a vector space basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"N", "/", "I"}], " ", "N"}], TraditionalForm]],ExpressionUUID->
  "6756dc7d-2ec4-5e4f-9aef-8851d0abe6db"],
 ". Define"
}], "Text",
 CellChangeTimes->{{3.978107854951334*^9, 
  3.978107942344328*^9}},ExpressionUUID->"4f0af067-ec68-3945-852d-\
bba810ff38ca"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["D", "max"], ":=", 
    RowBox[{"max", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"D", "\[Element]", "\[DoubleStruckCapitalN]"}], "|", 
       RowBox[{
        RowBox[{
         SubscriptBox["M", "D"], "/", 
         SubscriptBox[
          RowBox[{"(", 
           RowBox[{"I", " ", "M"}], ")"}], "D"]}], "!=", "0"}]}], "}"}]}]}], 
   ","}], TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.962365445436079*^9, 3.962365484287281*^9}, 
   3.9634953147455597`*^9, {3.9640531284682884`*^9, 3.9640531304019966`*^9}, 
   3.9640554689891434`*^9, {3.964056104637535*^9, 3.964056106522072*^9}, {
   3.964056227947178*^9, 3.964056228026657*^9}, 3.965298257739189*^9},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"b076e6a5-4ef8-6548-8784-48dfd504ddfa"],

Cell["which may be difficult to determine in practice.", "Text",
 CellChangeTimes->{{3.9640559706080666`*^9, 3.9640559710483303`*^9}, {
  3.9640560017183*^9, 3.9640560694236507`*^9}, {3.964056117305832*^9, 
  3.964056192811081*^9}, {3.964056231337963*^9, 3.9640562540694237`*^9}, {
  3.964056322090151*^9, 3.9640563640273*^9}, {3.96410127036734*^9, 
  3.964101278323799*^9}, {3.96410131651593*^9, 3.9641014066847057`*^9}, {
  3.9641014561825504`*^9, 3.964101597842783*^9}, {3.964101639376705*^9, 
  3.9641016429044437`*^9}, {3.965298257739189*^9, 3.9652982577588425`*^9}, {
  3.978107994555935*^9, 3.9781079962674217`*^9}},
 Background->None,ExpressionUUID->"52966ad7-417f-7548-944f-632e9ea7668c"],

Cell[TextData[{
 "For each ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "<=", "D", "<=", 
    SubscriptBox["D", "max"]}], TraditionalForm]],ExpressionUUID->
  "9f5b9305-d800-534f-b535-dab6ab8c85a9"],
 ", compute a basis for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     RowBox[{"I", " ", "M"}], ")"}], "D"], TraditionalForm]],
  CellChangeTimes->{{3.962033156826256*^9, 3.962033192078993*^9}, {
    3.962033265098963*^9, 3.962033265770605*^9}, {3.9620335629499855`*^9, 
    3.9620335736185875`*^9}, {3.9620336707639675`*^9, 
    3.9620336827002754`*^9}, {3.9620344667057934`*^9, 3.962034491615885*^9}, {
    3.9620361748036137`*^9, 3.962036200555958*^9}, {3.962187691157919*^9, 
    3.962187741690794*^9}, {3.962187779755245*^9, 3.9621877836965675`*^9}, {
    3.962187861068098*^9, 3.962187864127739*^9}, 3.962187931783577*^9, {
    3.96218974608667*^9, 3.9621897461983643`*^9}, {3.96220538458926*^9, 
    3.9622053992107944`*^9}, 3.962205512316063*^9, {3.9622751036905384`*^9, 
    3.9622751355568924`*^9}, {3.962279120326744*^9, 3.962279143294874*^9}, {
    3.962279184347843*^9, 3.9622791989352474`*^9}, {3.962281046068918*^9, 
    3.9622810461487217`*^9}, {3.962364531304531*^9, 3.9623645327213*^9}, {
    3.962364574334135*^9, 3.962364574447218*^9}, 3.9623647323552895`*^9, 
    3.9630899195257435`*^9, 3.963495314696455*^9, {3.9640531106782303`*^9, 
    3.9640531119438915`*^9}, {3.9640552473198204`*^9, 
    3.9640552474315605`*^9}, {3.964055862386444*^9, 3.964055938288521*^9}},
  TextAlignment->Center,ExpressionUUID->
  "320041d3-d6e0-b442-8354-6658d8e9806e"],
 " and extend it to a basis for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "D"], TraditionalForm]],ExpressionUUID->
  "266a96de-d276-a14f-b571-302e93f3fa1a"],
 " by adjoining the basis vectors in the set ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "D"], "\[SubsetEqual]", 
    SubscriptBox["M", "D"]}], TraditionalForm]],ExpressionUUID->
  "c653a9ed-9005-9d44-aeca-dbd69571dd18"],
 ". Write ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", ":=", 
    RowBox[{
     UnderscriptBox["\[Union]", 
      RowBox[{"D", "\[Element]", "\[DoubleStruckCapitalN]"}]], 
     SubscriptBox["L", "D"]}]}], TraditionalForm]],ExpressionUUID->
  "e8b00236-5f38-e148-85ae-71863f1ece51"],
 ". Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "D"], "/", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{"I", " ", "M"}], ")"}], "D"]}], TraditionalForm]],
  ExpressionUUID->"860274eb-ebaa-6a4c-9081-38debd1c8ddc"],
 " is a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["M", "D"], "/", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{"I", " ", "M"}], ")"}], "D"]}], TraditionalForm]],
  ExpressionUUID->"28ee9b33-d500-2044-a5ca-c3c7c9e4509c"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"L", "/", "I"}], " ", "M"}], TraditionalForm]],ExpressionUUID->
  "974a7dad-f6ea-814a-8b30-d275c91720ae"],
 " is a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"M", "/", "I"}], " ", "M"}], TraditionalForm]],ExpressionUUID->
  "7e34d8de-b4c6-8d4d-bc0e-c4e69b59105e"],
 ", so by Nakayama\[CloseCurlyQuote]s Lemma, ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "660082cd-e4d2-9c45-8140-3232161392e8"],
 " is a minimal generating set for ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "da92a0b5-fefa-5c4d-ad65-e3376e4911d4"],
 " as an ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "aeaaae4e-5b11-0a43-a0b8-81b4939994bd"],
 "-module."
}], "Text",
 CellChangeTimes->{{3.9640559706080666`*^9, 3.9640559710483303`*^9}, {
  3.9640560017183*^9, 3.9640560694236507`*^9}, {3.964056117305832*^9, 
  3.964056192811081*^9}, {3.964056231337963*^9, 3.9640562540694237`*^9}, {
  3.964056322090151*^9, 3.9640563640273*^9}, {3.96410127036734*^9, 
  3.964101278323799*^9}, {3.96410131651593*^9, 3.9641014066847057`*^9}, {
  3.9641014561825504`*^9, 3.964101597842783*^9}, {3.964101639376705*^9, 
  3.9641016429044437`*^9}, {3.965298257739189*^9, 3.9652982577588425`*^9}, {
  3.978107994555935*^9, 3.978107995664591*^9}, {3.9811236599392986`*^9, 
  3.9811236599392986`*^9}},
 Background->None,ExpressionUUID->"20938d07-188c-8541-9d74-de09eec8c865"],

Cell[TextData[{
 "Next, apply the above algorithm with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "=", "I"}], TraditionalForm]],ExpressionUUID->
  "aa517b3d-19fc-9846-9e8f-99db465cfbdd"],
 ". Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{},
     "Reals"], "[", "L", "]"}], TraditionalForm]],ExpressionUUID->
  "2d772dd6-73d4-314a-8379-26337d57d8b3"],
 " be the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{},
    "Reals"], TraditionalForm]],ExpressionUUID->
  "3446a7a2-0e05-1b41-be64-1aaca6a4c301"],
 "-algebra generated by ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "b27d0711-72f3-ab46-8f45-c55fbc56af6d"],
 ". Clearly, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{},
     "Reals"], "\[SubsetEqual]", 
    RowBox[{
     TemplateBox[{},
      "Reals"], "[", "L", "]"}]}], TraditionalForm]],ExpressionUUID->
  "b9071822-29ee-b84a-9ad9-275cbf048a52"],
 ". Now, write ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["R", 
     RowBox[{"<=", "D"}]], ":=", 
    RowBox[{
     SubscriptBox["R", "0"], "\[CirclePlus]", "\[Ellipsis]", "\[CirclePlus]", 
     SubscriptBox["R", "D"]}]}], TraditionalForm]],ExpressionUUID->
  "5178cccb-921c-2e45-b4ef-278e163ef33f"],
 ", and suppose that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["R", 
     RowBox[{"<=", "D"}]], "\[SubsetEqual]", 
    RowBox[{
     TemplateBox[{},
      "Reals"], "[", "L", "]"}]}], TraditionalForm]],ExpressionUUID->
  "95e3aef6-7e70-2d42-b490-3c339a6fb0c6"],
 ". Then"
}], "Text",
 CellChangeTimes->{{3.9621838326925087`*^9, 3.962183924279604*^9}, {
   3.962184007326376*^9, 3.962184009001236*^9}, {3.962184219063093*^9, 
   3.9621843034479923`*^9}, {3.9621903075254383`*^9, 
   3.9621903690635796`*^9}, {3.962190412594702*^9, 3.9621904192381096`*^9}, {
   3.9621904615962696`*^9, 3.9621904783477516`*^9}, {3.9621907058608665`*^9, 
   3.96219079535935*^9}, {3.9622069400287304`*^9, 3.9622070682275257`*^9}, {
   3.962207131273054*^9, 3.9622071391058598`*^9}, {3.9622077369401608`*^9, 
   3.9622077377242165`*^9}, {3.9622083670789967`*^9, 3.962208545499323*^9}, {
   3.9622085909586277`*^9, 3.9622086198280315`*^9}, {3.9622107307606964`*^9, 
