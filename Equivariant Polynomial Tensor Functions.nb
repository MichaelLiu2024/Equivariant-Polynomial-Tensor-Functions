Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["R",
    RowBox[{"D", "+", "1"}]],
   RowBox[{" ",
    RowBox[{"=", " "}]}],
   RowBox[{
    RowBox[{
     SubscriptBox["I",
      RowBox[{"D", "+", "1"}]], "\[SubsetEqual]",
     RowBox[{
      RowBox[{
       SubscriptBox["Span",
        TemplateBox[{},
         "Reals"]], "(",
       SubscriptBox["L",
        RowBox[{"D", "+", "1"}]], ")"}], "+",
      SubscriptBox[
       RowBox[{"(",
        SuperscriptBox["I", "2"], ")"}],
       RowBox[{"D", "+", "1"}]]}]}],
    RowBox[{" ",
     RowBox[{"=", " "}]}],
    RowBox[{
     RowBox[{
      SubscriptBox["Span",
       TemplateBox[{},
        "Reals"]], "(",
      SubscriptBox["L",
       RowBox[{"D", "+", "1"}]], ")"}], "+",
     RowBox[{
      UnderscriptBox["\[Sum]",
       RowBox[{"1", "<=",
        RowBox[{"D", "'"}], "<=", "D"}]],
      RowBox[{
       SubscriptBox["I",
        RowBox[{"D", "'"}]],
       RowBox[{
        SubscriptBox["I",
         RowBox[{"D", "+", "1", "-",
          RowBox[{"D", "'"}]}]], "."}]}]}]}]}]}],
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.962283946202675*^9, 3.962284042293188*^9}, {
