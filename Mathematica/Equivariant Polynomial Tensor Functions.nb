  3.9811236599392986`*^9}},
 Background->None,ExpressionUUID->"20938d07-188c-8541-9d74-de09eec8c865"],

Cell[TextData[{
 "Next, apply the above algorithm with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "=", "I"}], TraditionalForm]],ExpressionUUID->
  "aa517b3d-19fc-9846-9e8f-99db465cfbdd"],
 ". Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{},
     "Reals"], "[", "L", "]"}], TraditionalForm]],ExpressionUUID->
  "2d772dd6-73d4-314a-8379-26337d57d8b3"],
 " be the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{},
    "Reals"], TraditionalForm]],ExpressionUUID->
  "3446a7a2-0e05-1b41-be64-1aaca6a4c301"],
 "-algebra generated by ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "b27d0711-72f3-ab46-8f45-c55fbc56af6d"],
 ". Clearly, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{},
     "Reals"], "\[SubsetEqual]", 
    RowBox[{
     TemplateBox[{},
      "Reals"], "[", "L", "]"}]}], TraditionalForm]],ExpressionUUID->
  "b9071822-29ee-b84a-9ad9-275cbf048a52"],
 ". Now, write ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["R", 
     RowBox[{"<=", "D"}]], ":=", 
    RowBox[{
     SubscriptBox["R", "0"], "\[CirclePlus]", "\[Ellipsis]", "\[CirclePlus]", 
     SubscriptBox["R", "D"]}]}], TraditionalForm]],ExpressionUUID->
  "5178cccb-921c-2e45-b4ef-278e163ef33f"],
 ", and suppose that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["R", 
     RowBox[{"<=", "D"}]], "\[SubsetEqual]", 
    RowBox[{
     TemplateBox[{},
      "Reals"], "[", "L", "]"}]}], TraditionalForm]],ExpressionUUID->
  "95e3aef6-7e70-2d42-b490-3c339a6fb0c6"],
 ". Then"
}], "Text",
