Cell[TextData[{
 "Clearly, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["Span", 
      TemplateBox[{},
       "Reals"]], "(", 
     SubscriptBox["L", 
      RowBox[{"D", "+", "1"}]], ")"}], "\[SubsetEqual]", 
    RowBox[{
     TemplateBox[{},
      "Reals"], "[", "L", "]"}]}], TraditionalForm]],ExpressionUUID->
  "a2a4d8d0-2aa6-eb45-8202-c949544c8f25"],
 ", and by the inductive hypothesis, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["I", "1"], ",", "...", ",", 
    RowBox[{
     SubscriptBox["I", "D"], "\[SubsetEqual]", 
     SubscriptBox["R", 
      RowBox[{"<=", "D"}]], "\[SubsetEqual]", 
     RowBox[{
      TemplateBox[{},
       "Reals"], "[", "L", "]"}]}]}], TraditionalForm]],ExpressionUUID->
  "eb7e5a53-9761-d740-9a60-3974c5c3c91b"],
 ". Thus, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "=", 
    RowBox[{
     TemplateBox[{},
      "Reals"], "[", "L", "]"}]}], TraditionalForm]],ExpressionUUID->
  "3ce41928-ba57-2c49-82ae-624192a585d6"],
 ". To see that ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "91d560c0-5a77-0844-8d12-bdeab3cc39f2"],
 " is minimal, note that if any ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "\[SubsetEqual]", "I"}], TraditionalForm]],ExpressionUUID->
  "f295fe5c-bc42-8443-95bd-76497dbbf85f"],
 " generates ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "fc88c714-d435-3040-a47a-5d354142e2ef"],
 " as an ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{},
    "Reals"], TraditionalForm]],ExpressionUUID->
  "bfe760c8-4be2-6044-8965-2393fbd43554"],
 "-algebra, then ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "1dd76f17-5a91-814a-be34-95b34ff526a0"],
 " generates ",
 Cell[BoxData[
  FormBox["I", TraditionalForm]],ExpressionUUID->
  "ae327e47-0f3f-e248-9300-9fad6fb0dbe6"],
 " as an ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "9cb86129-f4f7-a845-85ba-393113afd572"],
 "-module, so ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "/", 
    SuperscriptBox["I", "2"]}], TraditionalForm]],ExpressionUUID->
  "d3237dda-243f-2f49-8377-3808f0badb10"],
 " generates ",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", "/", 
    SuperscriptBox["I", "2"]}], TraditionalForm]],ExpressionUUID->
  "7db26e7b-31c0-9041-8115-70afafcdcc92"],
 " as an ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{},
    "Reals"], TraditionalForm]],ExpressionUUID->
  "599c6805-6918-8048-b208-70493e0b0442"],
 "-module. Thus, since our given ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "7e939210-f325-664c-826e-5adf8f4d2589"],
 " makes ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "/", 
    SuperscriptBox["I", "2"]}], TraditionalForm]],ExpressionUUID->
  "4aa5c05d-c079-6841-92c4-93cdb577aa69"],
 " a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", "/", 
    SuperscriptBox["I", "2"]}], TraditionalForm]],ExpressionUUID->
  "e4b1d958-5749-7b47-bc83-2bcc0227adc1"],
 ", our given ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "5cf00091-d101-864e-bd92-6628a6206975"],
 " is a minimal generating set for ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "5ac339e2-08f7-1b46-931d-2bee614387af"],
 " as an ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{},
    "Reals"], TraditionalForm]],ExpressionUUID->
  "9926b797-4ff9-da4c-b037-e9cee98a7266"],
 "-algebra."
}], "Text",
