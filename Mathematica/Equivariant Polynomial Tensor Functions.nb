  "b95e756f-4d28-d647-9d60-1c8b4d19e67b"],
 ". Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"dim", " ", 
    RowBox[{
     SubscriptBox["Hom", "G"], "(", 
     RowBox[{
      SubscriptBox["H", "\[Mu]"], ",", 
