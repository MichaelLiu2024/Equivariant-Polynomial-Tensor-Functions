Cell[TextData[{
 "For each ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "<=", "D", "<=", 
    SubscriptBox["D", "max"]}], TraditionalForm]],ExpressionUUID->
  "9f5b9305-d800-534f-b535-dab6ab8c85a9"],
 ", compute a basis for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     RowBox[{"I", " ", "M"}], ")"}], "D"], TraditionalForm]],
  CellChangeTimes->{{3.962033156826256*^9, 3.962033192078993*^9}, {
    3.962033265098963*^9, 3.962033265770605*^9}, {3.9620335629499855`*^9, 
    3.9620335736185875`*^9}, {3.9620336707639675`*^9, 
    3.9620336827002754`*^9}, {3.9620344667057934`*^9, 3.962034491615885*^9}, {
    3.9620361748036137`*^9, 3.962036200555958*^9}, {3.962187691157919*^9, 
    3.962187741690794*^9}, {3.962187779755245*^9, 3.9621877836965675`*^9}, {
    3.962187861068098*^9, 3.962187864127739*^9}, 3.962187931783577*^9, {
