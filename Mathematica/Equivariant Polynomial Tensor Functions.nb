3b058cd5a155"],

Cell[CellGroupData[{

Cell["\<\
Lemma A1 (Identifying the covariant module with the space of equivariant \
polynomial functions)\
\>", "Subsubsection",
 CellChangeTimes->{{3.9710035146751137`*^9, 3.971003536956476*^9}, {
  3.9725632765974045`*^9, 
  3.972563310615017*^9}},ExpressionUUID->"89ae3a93-648e-fc44-8cc6-\
be738a091180"],

Cell["There is an isomorphism of vector spaces", "Text",
 CellChangeTimes->{{3.971003544616583*^9, 3.971003550193693*^9}, {
  3.9710035847269936`*^9, 3.97100359680641*^9}, {3.9725633003890953`*^9, 
  3.97256330118589*^9}},ExpressionUUID->"d47b1d21-5b95-4d4b-97f6-\
aaaf53f4fc6b"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[ScriptCapitalS]", "(", 
       SuperscriptBox["X", "*"], ")"}], "\[CircleTimes]", "Y"}], ")"}], "G"], 
   "\[TildeFullEqual]", 
   RowBox[{"{", 
    RowBox[{
    "equivariant", " ", "polynomial", " ", "functions", " ", "from", " ", "X",
      " ", "to", " ", "Y"}], "}"}]}], TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.971002790255043*^9, 3.9710027918797283`*^9}, {
  3.971002973488472*^9, 3.971002973663662*^9}, {3.97100307613105*^9, 
  3.9710030766647224`*^9}, {3.971003613612816*^9, 3.9710036365823917`*^9}},
 TextAlignment->Center,ExpressionUUID->"aa2f7923-52e3-424c-8f78-3ca5ab085d12"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Proof", "Subsubsection",
 CellChangeTimes->{{3.9710035411683083`*^9, 
  3.971003541571047*^9}},ExpressionUUID->"6d68c39d-4f81-d446-a79e-\
24830acc5d36"],

Cell[TextData[{
 "Consider the pairing ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"\[ScriptCapitalS]", "(", 
        SuperscriptBox["X", "*"], ")"}], "\[CircleTimes]", "Y"}], ")"}], "\[Cross]",
      "X"}], "->", "Y"}], TraditionalForm]],ExpressionUUID->
  "cf31cc08-f5f3-5e4e-ad11-75ddd6e69b8b"],
 " defined on elementary tensors (which correspond to the component functions \
of the polynomial) by"
}], "Text",
 CellChangeTimes->{{3.9620655704713078`*^9, 3.9620656118013153`*^9}, {
   3.96211416575548*^9, 3.9621141743737946`*^9}, {3.962116772983818*^9, 
   3.9621167730867767`*^9}, {3.962203842893463*^9, 3.9622038592620926`*^9}, {
   3.96236279128685*^9, 3.962362802794325*^9}, {3.962982784666952*^9, 
   3.962982784761032*^9}, 3.9710035122346096`*^9, 3.971003669879862*^9, 
   3.9725611394912567`*^9},
 Background->None,ExpressionUUID->"74566bde-4276-b24c-975e-937c73c731cd"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"\[CurlyPhi]", "\[CircleTimes]", "y"}], ",", "x"}], ")"}], "\[Function]", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"\[CurlyPhi]", "\[CircleTimes]", "y"}], ")"}], 
     RowBox[{"(", "x", ")"}]}], ":=", 
    RowBox[{
     RowBox[{"\[CurlyPhi]", "(", "x", ")"}], "y"}]}]}], 
  TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.962039374843857*^9, 3.9620394190790253`*^9}, {
  3.962039580576721*^9, 3.962039596152975*^9}, {3.962039726275709*^9, 
  3.962039765601347*^9}, {3.9621141645999374`*^9, 3.9621141780982666`*^9}},
 TextAlignment->Center,
 Background->None,ExpressionUUID->"4a1a011d-9d29-6b4a-b45c-36af04b5b910"],

Cell[TextData[{
 "and extended linearly to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalS]", "(", 
     SuperscriptBox["X", "*"], ")"}], "\[CircleTimes]", "Y"}], 
   TraditionalForm]],
  CellChangeTimes->{{3.962039374843857*^9, 3.9620394190790253`*^9}, {
   3.962039580576721*^9, 3.962039596152975*^9}, {3.962039726275709*^9, 
   3.962039765601347*^9}},
  TextAlignment->Center,ExpressionUUID->
  "1bf50887-5b01-4a47-a3e9-3e17c154150f"],
 ", where ",
