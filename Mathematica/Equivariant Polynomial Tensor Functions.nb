  FormBox[
   RowBox[{
    RowBox[{"dim", " ", 
     RowBox[{
      SubscriptBox["Hom", "G"], "(", 
      RowBox[{
       SubscriptBox["H", "\[Mu]"], ",", 
       RowBox[{
        SuperscriptBox["\[CapitalLambda]", "d"], "(", 
        SubscriptBox["H", "\[Lambda]"], ")"}]}], ")"}]}], "=", "1"}], 
   TraditionalForm]],ExpressionUUID->"0bb6c5ba-af54-ba4e-ba6f-d6949ac4007b"],
