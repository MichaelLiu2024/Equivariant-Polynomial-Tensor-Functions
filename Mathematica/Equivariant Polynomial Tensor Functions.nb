Cell[TextData[{
 "we can proceed degree-by-degree to obtain a vector space basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"N", "/", "I"}], " ", "N"}], TraditionalForm]],ExpressionUUID->
  "6756dc7d-2ec4-5e4f-9aef-8851d0abe6db"],
