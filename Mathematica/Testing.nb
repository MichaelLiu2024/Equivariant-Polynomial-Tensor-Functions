Cell[BoxData[
 RowBox[{
  RowBox[{"IsotypicMultiplicitiesFromGeneratingFunction", "[", 
   RowBox[{"f_", ",", "m_"}], "]"}], ":=", 
  RowBox[{"-", 
   RowBox[{"Differences", "[", 
    RowBox[{"Append", "[", 
     RowBox[{
      RowBox[{"Reverse", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"SeriesCoefficient", "[", 
          RowBox[{
           RowBox[{"Series", "[", 
            RowBox[{"f", ",", 
             RowBox[{"{", 
              RowBox[{"q", ",", "0", ",", "m"}], "}"}]}], "]"}], ",", "#"}], 
          "]"}], "&"}], "/@", 
        RowBox[{"Range", "[", 
         RowBox[{"0", ",", "m"}], "]"}]}], "]"}], ",", "0"}], "]"}], 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9826822349726486`*^9, 3.982682254073551*^9}, {
