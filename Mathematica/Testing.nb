Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "SSYTMaxMultiplicity", ",", "VectorSpaceRestrictionCounts", ",", 
     "ExtractedBasisRestrictionCounts"}], "]"}], ";"}], "\[IndentingNewLine]",
   "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "largest", " ", "multiplicity", " ", "index", " ", "that", " ", "appears", 
    " ", "in", " ", "the", " ", "tableau"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SSYTMaxMultiplicity", "[", 
     RowBox[{"{", "}"}], "]"}], ":=", "0"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SSYTMaxMultiplicity", "[", "ssyt_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"t", "=", "ssyt"}], "}"}], ",", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "t", "]"}], "==", "1"}], ",", 
         RowBox[{"t", "=", 
          RowBox[{"First", "[", "t", "]"}]}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Max", "[", 
        RowBox[{"0", ",", 
         RowBox[{"Cases", "[", 
          RowBox[{
           RowBox[{"First", "[", "t", "]"}], ",", 
           RowBox[{
            RowBox[{"x_", "?", "NumericQ"}], ":>", 
            RowBox[{"Round", "[", "x", "]"}]}], ",", "Infinity"}], "]"}]}], 
        "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "counts", " ", "for", " ", "a", " ", "raw", " ", "VectorSpaceBasis"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"VectorSpaceRestrictionCounts", "[", 
    RowBox[{"vectorSpaceBasis_List", ",", "m\[Lambda]s_List"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Association", "@", 
    RowBox[{"Table", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"m", "->", "\[IndentingNewLine]", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Total", "[", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Length", "[", 
              RowBox[{"#", "[", "\"\<interiorTensorTrains\>\"", "]"}], "]"}], 
             "*", "\[IndentingNewLine]", 
             RowBox[{"Times", "@@", 
              RowBox[{"MapThread", "[", "\[IndentingNewLine]", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"Count", "[", 
                   RowBox[{"#1", ",", 
                    RowBox[{"t_", "/;", 
                    RowBox[{
                    RowBox[{"SSYTMaxMultiplicity", "[", "t", "]"}], "<=", 
                    "#2"}]}]}], "]"}], "*", 
                  RowBox[{"Length", "[", 
                   RowBox[{"#3", "[", "\"\<leafObjects\>\"", "]"}], "]"}]}], 
                 "&"}], ",", "\[IndentingNewLine]", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"#", "[", "\"\<SSYT\[Lambda]s\>\"", "]"}], ",", "m",
                   ",", 
                  RowBox[{"#", "[", "\"\<leafObjects\>\"", "]"}]}], "}"}]}], 
               "\[IndentingNewLine]", "]"}]}]}], "&"}], "/@", 
           RowBox[{"vectorSpaceBasis", "[", 
            RowBox[{"[", "d", "]"}], "]"}]}], "\[IndentingNewLine]", "]"}], ",",
          "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"d", ",", "1", ",", 
           RowBox[{"Length", "[", "vectorSpaceBasis", "]"}]}], "}"}]}], 
        "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"m", ",", 
        RowBox[{"Tuples", "[", 
         RowBox[{"Range", "[", 
          RowBox[{"0", ",", "m\[Lambda]s"}], "]"}], "]"}]}], "}"}]}], 
     "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "counts", " ", "for", " ", "AlgebraBasis", " ", "or", " ", "ModuleBasis"}],
    "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"ExtractedBasisRestrictionCounts", "[", 
   RowBox[{"basis_List", ",", "m\[Lambda]s_List"}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"Association", "@", 
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"m", "->", "\[IndentingNewLine]", 
      RowBox[{"Table", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Count", "[", 
         RowBox[{
          RowBox[{"basis", "[", 
           RowBox[{"[", "d", "]"}], "]"}], ",", 
          RowBox[{"b_", "/;", 
           RowBox[{"And", "@@", 
            RowBox[{"MapThread", "[", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"SSYTMaxMultiplicity", "[", "#1", "]"}], "<=", "#2"}],
                "&"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"b", "[", "\"\<SSYT\[Lambda]s\>\"", "]"}], ",", "m"}],
                "}"}]}], "]"}]}]}]}], "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"d", ",", "1", ",", 
          RowBox[{"Length", "[", "basis", "]"}]}], "}"}]}], 
       "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"m", ",", 
       RowBox[{"Tuples", "[", 
        RowBox[{"Range", "[", 
         RowBox[{"0", ",", "m\[Lambda]s"}], "]"}], "]"}]}], "}"}]}], 
    "\[IndentingNewLine]", "]"}]}]}]}], "Input",
