  3.9736153980405693`*^9, 3.973615426311119*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"a39dd05b-d043-4e71-976f-bd333fd79c18"],

Cell[BoxData[
 RowBox[{
  RowBox[{"DisplaySpinTrees", "[", "assoc_Association", "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{"assoc", ",", 
    RowBox[{"Outer", "[", 
     RowBox[{
      RowBox[{"SpinListToSpinTree", "@*", "List"}], ",", 
      RowBox[{"Tuples", "[", 
       RowBox[{"assoc", "[", 
        RowBox[{"[", "\"\<leafPaths\>\"", "]"}], "]"}], "]"}], ",", 
      RowBox[{"assoc", "[", 
       RowBox[{"[", "\"\<corePaths\>\"", "]"}], "]"}], ",", "1"}], "]"}]}], 
   "}"}]}]], "Input",
