Cell[BoxData[
 RowBox[{
  RowBox[{"SeparableOuter", "[", 
   RowBox[{"fs_List", ",", "args_List"}], "]"}], ":=", 
  RowBox[{"Fold", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Outer", "[", 
      RowBox[{
       RowBox[{"#2", "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", 
       RowBox[{"#2", "[", 
        RowBox[{"[", "2", "]"}], "]"}], ",", "#1"}], "]"}], "&"}], ",", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"Last", "@", "fs"}], ")"}], "/@", 
     RowBox[{"(", 
      RowBox[{"Last", "@", "args"}], ")"}]}], ",", 
    RowBox[{"Reverse", "@", 
     RowBox[{"Most", "@", 
      RowBox[{"Transpose", "@", 
       RowBox[{"{", 
        RowBox[{"fs", ",", "args"}], "}"}]}]}]}]}], "]"}]}]], "Input",
