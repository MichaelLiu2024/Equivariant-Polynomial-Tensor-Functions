        RowBox[{"[", "1", "]"}], "]"}], ",", 
       RowBox[{"#2", "[", 
        RowBox[{"[", "2", "]"}], "]"}], ",", "#1"}], "]"}], "&"}], ",", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"Last", "@", "fs"}], ")"}], "/@", 
     RowBox[{"(", 
      RowBox[{"Last", "@", "args"}], ")"}]}], ",", 
    RowBox[{"Reverse", "@", 
     RowBox[{"Most", "@", 
      RowBox[{"Transpose", "@", 
       RowBox[{"{", 
        RowBox[{"fs", ",", "args"}], "}"}]}]}]}]}], "]"}]}]], "Input",
