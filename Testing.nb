Cell[BoxData[
 RowBox[{
  RowBox[{"DisplaySpinTrees", "[", "assoc_Association", "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{"assoc", ",", 
    RowBox[{"Outer", "[", 
     RowBox[{
      RowBox[{"SpinListToSpinTree", "@*", "List"}], ",", 
      RowBox[{"Tuples", "[", 
       RowBox[{"assoc", "[", 
        RowBox[{"[", "\"\<leafPaths\>\"", "]"}], "]"}], "]"}], ",", 
      RowBox[{"assoc", "[", 
       RowBox[{"[", "\"\<corePaths\>\"", "]"}], "]"}], ",", "1"}], "]"}]}], 
   "}"}]}]], "Input",
