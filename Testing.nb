         RowBox[{"{", 
          RowBox[{"d", ",", "1", ",", 
           RowBox[{"Length", "[", "vectorSpaceBasis", "]"}]}], "}"}]}], 
        "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"m", ",", 
        RowBox[{"Tuples", "[", 
         RowBox[{"Range", "[", 
          RowBox[{"0", ",", "m\[Lambda]s"}], "]"}], "]"}]}], "}"}]}], 
     "\[IndentingNewLine]", "]"}]}]}], "\n", "\[IndentingNewLine]", 
