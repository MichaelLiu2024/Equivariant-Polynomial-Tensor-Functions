       "\[IndentingNewLine]", 
       RowBox[{"Max", "[", 
        RowBox[{"0", ",", 
         RowBox[{"Cases", "[", 
          RowBox[{
           RowBox[{"First", "[", "t", "]"}], ",", 
           RowBox[{
            RowBox[{"x_", "?", "NumericQ"}], ":>", 
            RowBox[{"Round", "[", "x", "]"}]}], ",", "Infinity"}], "]"}]}], 
        "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
