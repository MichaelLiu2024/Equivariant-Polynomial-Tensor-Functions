  "\[IndentingNewLine]", 
  RowBox[{"If", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Depth", "[", "\[Lambda]s", "]"}], ">", "2"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"SpinListToSpinTree", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"SpinListToSpinTree", "/@", "\[Lambda]s"}], ",", "\[Gamma]s"}],
       "}"}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Fold", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Tree", "[", 
        RowBox[{
         RowBox[{"Last", "@", "#2"}], ",", 
         RowBox[{"{", 
          RowBox[{"#1", ",", 
