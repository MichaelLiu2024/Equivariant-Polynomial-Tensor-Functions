      RowBox[{"Rest", "@", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"\[Lambda]s", ",", "\[Gamma]s"}], "}"}], "]"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}]}], "\n", 
