 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SSYTMaxMultiplicity", "[", 
     RowBox[{"{", "}"}], "]"}], ":=", "0"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SSYTMaxMultiplicity", "[", "ssyt_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"t", "=", "ssyt"}], "}"}], ",", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "t", "]"}], "==", "1"}], ",", 
         RowBox[{"t", "=", 
          RowBox[{"First", "[", "t", "]"}]}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Max", "[", 
        RowBox[{"0", ",", 
         RowBox[{"Cases", "[", 
          RowBox[{
           RowBox[{"First", "[", "t", "]"}], ",", 
           RowBox[{
            RowBox[{"x_", "?", "NumericQ"}], ":>", 
            RowBox[{"Round", "[", "x", "]"}]}], ",", "Infinity"}], "]"}]}], 
        "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "counts", " ", "for", " ", "a", " ", "raw", " ", "VectorSpaceBasis"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"VectorSpaceRestrictionCounts", "[", 
